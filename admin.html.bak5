        function getHubIdDirectly(officeName, wilayaCode) {
          if (!officeName) return null;
          
          console.log('\n🔍 getHubIdDirectly called with:', officeName, 'wilayaCode:', wilayaCode);

          var cleanOffice = officeName
            .replace(/^توصيل للمكتب\s*\(Office\)\s*-\s*/i, '')
            .replace(/^توصيل للمكتب\s*-\s*/i, '')
            .replace(/^التوصيل إلى المكتب\s*\(STOP DESK\)\s*-\s*/i, '')
            .replace(/^التوصيل إلى المكتب\s*-\s*/i, '')
            .replace(/\s*-\s*\(.*?\)/g, '')
            .trim()
            .toLowerCase();
          
          console.log('   Cleaned Office Name:', cleanOffice);

          var targetWilaya = parseInt(wilayaCode || cleanOffice.match(/\b\d+\b/)?.[0] || '16', 10);
          console.log('   Target Wilaya Code:', targetWilaya);

          var bestMatch = null;
          var highestScore = 0;
          var sameWilayaHubs = [];
          
          for (var i = 0; i < ZR_HUBS.length; i++) {
            var hub = ZR_HUBS[i];
            var hubName = (hub.name || '').toLowerCase();
            var score = 0;
            
            var hubWilayaMatch = hubName.match(/\b\d+\b/);
            var hubWilayaCode = hubWilayaMatch ? parseInt(hubWilayaMatch[0], 10) : null;
            
            var wilayaMatches = hubWilayaCode === targetWilaya;
            if (wilayaMatches) {
              sameWilayaHubs.push(hub);
              score += 15; // High priority for correct wilaya
            }
            
            var cleanTokens = function(str) {
              return str.replace(/[^a-zA-Z0-9\u0600-\u06FF]/g, ' ').split(/\s+/).filter(function(t) { return t.length > 1; });
            };
            var officeTokens = cleanTokens(cleanOffice);
            var hubTokens = cleanTokens(hubName);
            
            for (var j = 0; j < officeTokens.length; j++) {
              var token = officeTokens[j];
              if (hubTokens.indexOf(token) !== -1 || hubName.indexOf(token) !== -1) {
                score += 5;
              }
            }
            
            var genericWords = ['hub', 'tri', 'transit', 'مكتب', 'مركز', 'فرز', 'توصيل'];
            for (var k = 0; k < officeTokens.length; k++) {
              var t = officeTokens[k];
              if (genericWords.indexOf(t) === -1 && hubName.indexOf(t) !== -1) {
                score += 10;
              }
            }
            
            if (score > highestScore) {
              highestScore = score;
              bestMatch = hub;
            }
          }
          
          if ((!bestMatch || highestScore < 15) && sameWilayaHubs.length > 0) {
            var preferredHub = null;
            for (var m = 0; m < sameWilayaHubs.length; m++) {
              var h = sameWilayaHubs[m];
              if (h.name.toLowerCase().indexOf('hub') !== -1 || h.name.indexOf('مكتب') !== -1) {
                preferredHub = h;
                break;
              }
            }
            if (!preferredHub) preferredHub = sameWilayaHubs[0];
            
            console.log('   ⚠️ Precise match failed. Falling back to same-wilaya hub:', preferredHub.name);
            return preferredHub ? preferredHub.id : null;
          }
          
          if (bestMatch) {
            console.log('   ✓ Found best match:', bestMatch.name, '(Score:', highestScore, ')');
          } else {
            console.log('   ❌ No match found.');
          }

          return bestMatch ? bestMatch.id : null;
        }

        async function deliverOrderDirectly(orderId) {
          // Removed: this used to call the ZR Express API directly from the browser
          // with hardcoded credentials (a security risk) and could create a duplicate
          // shipment if the main server call merely timed out (e.g. during a VPS
          // reboot) rather than truly failing. Shipping must go through the server's
          // own /deliver endpoint only.
          throw new Error('فشل الاتصال بالسيرفر. الرجاء الانتظار حتى يعود السيرفر للعمل ثم إعادة المحاولة.');
        }

        async function syncOrderStatusDirectly(orderId) {
          // Removed: this used to call the ZR Express API directly from the browser
          // with hardcoded credentials (a security risk), and writing results into
          // localStorage caused the admin dashboard to show stale/duplicate-looking
          // data whenever the server was briefly unreachable (e.g. during a reboot).
          // Syncing must go through the server's own /sync-zr endpoint only.
          throw new Error('فشل الاتصال بالسيرفر. الرجاء الانتظار حتى يعود السيرفر للعمل ثم إعادة المحاولة.');
        }

        /* ─── Deliver: send order to ZR Express ─── */
        window.deliverOrder = async function(orderId) {
          var confirmMsg = ((window.t && window.t('admin_confirm_ship_zr')) || 'هل تريد إرسال الطلب #{id} إلى ZR Express للشحن؟').replace('{id}', orderId);
          if (!confirm(confirmMsg)) return;

          var btn = document.querySelector('[onclick*="deliverOrder(\'' + orderId + '\')"]');
          if (btn) { btn.disabled = true; btn.textContent = '⏳ جاري الشحن...'; }

          try {
            var result = await apiFetch('/api/orders/' + orderId + '/deliver', { method: 'POST' });
            if (result.trackingNumber) {
              var successMsg = ((window.t && window.t('admin_order_shipped_zr')) || '✅ تم الشحن بنجاح!') + '\n' + result.trackingNumber;
              alert(successMsg);
            } else {
              alert((window.t && window.t('admin_order_shipped_zr')) || '✅ تم الشحن بنجاح عبر ZR Express!');
            }
            await loadDashboardStats(true);
            var activeFilter = document.querySelector('.filter-btn.active').getAttribute('data-filter');
            await renderOrdersTable(activeFilter, true);
          } catch(e) {
            console.warn('Backend delivery failed. Attempting direct browser shipment...', e);
            if (btn) btn.textContent = '⏳ محاولة شحن مباشر...';
            try {
              var result = await deliverOrderDirectly(orderId);
              
              var order = (cachedOrders || []).find(function(o) { return String(o.id) === String(orderId); });
              if (order) {
                order.status = 'Confirmed';
                order.trackingNumber = result.trackingNumber;
                order.zrParcelId = result.zrParcelId;
                order.zrStatus = { state: 'OrderReceived', situation: '' };
                order.shippedAt = new Date().toISOString();
                
                var localOrders = JSON.parse(localStorage.getItem('local_orders') || '[]');
                var orderIdx = localOrders.findIndex(function(o) { return String(o.id) === String(orderId); });
                if (orderIdx > -1) {
                  localOrders[orderIdx] = order;
                } else {
                  localOrders.push(order);
                }
                localStorage.setItem('local_orders', JSON.stringify(localOrders));
              }

              alert(((window.t && window.t('admin_order_shipped_direct')) || '✅ تم الشحن بنجاح مباشرة عبر المتصفح!') + '\n' + result.trackingNumber);
              
              await loadDashboardStats(true);
              var activeFilter = document.querySelector('.filter-btn.active').getAttribute('data-filter');
              await renderOrdersTable(activeFilter, true);
            } catch(directError) {
              var errorAlert = document.getElementById('admin-error-alert');
              var errorText = document.getElementById('admin-error-text');
              
              var errMsg = directError.message || e.message || 'ZR Express connection failed.';
              var displayMsg = ((window.t && window.t('admin_error_zr_direct_fail')) || '⚠️ فشل الشحن المباشر: ') + errMsg;
              
              errorText.textContent = displayMsg;
              errorAlert.style.display = 'flex';
              
              setTimeout(function() {
                if (errorAlert.style.display === 'flex') {
                  errorAlert.style.display = 'none';
                }
              }, 6000);
              
              if (btn) { btn.disabled = false; btn.textContent = (window.t && window.t('admin_btn_ship_zr')) || '🚀 شحن ZR'; }
              console.error('Direct delivery failure:', directError);
            }
          }
        };

        /* ─── Sync: pull live ZR status ─── */
        window.syncOrderStatus = async function(orderId) {
          var btn = document.querySelector('[onclick*="syncOrderStatus(\'' + orderId + '\')"]');
          if (btn) { btn.disabled = true; btn.textContent = '⏳...'; }

          try {
            var result = await apiFetch('/api/orders/' + orderId + '/sync-zr', { method: 'POST' });
            if (result.order && result.order.zrStatus) {
              var stateMap = {
                'OrderReceived': 'تم استلام الطلب', 'CourierAssigned': 'تم تعيين ساعي', 'PickupInitiated': 'بدء الاستلام',
                'InTransit': 'في الطريق', 'CustomerCalled': 'تم الاتصال بالعميل', 'Delivered': 'تم التسليم',
                'Returned': 'مُرجع', 'ReturnCreated': 'طلب إرجاع', 'ReturnReceived': 'استلام الإرجاع',
                'Settled': 'مسوّى', 'Cancelled': 'ملغى'
              };
              var stateName = result.order.zrStatus.state || '-';
              alert('📡 حالة الشحنة: ' + (stateMap[stateName] || stateName));
            }
            await loadDashboardStats(true);
            var activeFilter = document.querySelector('.filter-btn.active').getAttribute('data-filter');
            await renderOrdersTable(activeFilter, true);
          } catch(e) {
            console.warn('Backend sync failed. Attempting direct sync...', e);
            try {
              var updatedOrder = await syncOrderStatusDirectly(orderId);
              var stateMap = {
                'OrderReceived': 'تم استلام الطلب', 'CourierAssigned': 'تم تعيين ساعي', 'PickupInitiated': 'بدء الاستلام',
                'InTransit': 'في الطريق', 'CustomerCalled': 'تم الاتصال بالعميل', 'Delivered': 'تم التسليم',
                'Returned': 'مُرجع', 'ReturnCreated': 'طلب إرجاع', 'ReturnReceived': 'استلام الإرجاع',
                'Settled': 'مسوّى', 'Cancelled': 'ملغى'
              };
              var stateName = updatedOrder.zrStatus.state || '-';
              alert('📡 حالة الشحنة (مزامنة مباشرة): ' + (stateMap[stateName] || stateName));
              
              await loadDashboardStats(true);
              var activeFilter = document.querySelector('.filter-btn.active').getAttribute('data-filter');
              await renderOrdersTable(activeFilter, true);
            } catch(directSyncErr) {
              alert('⚠️ تعذّر مزامنة حالة الطلب: ' + (directSyncErr.message || e.message || ''));
              if (btn) { btn.disabled = false; btn.textContent = '🔄 تحديث'; }
              console.error('Direct sync failure:', directSyncErr);
            }
          }
        };
      }

      /* ── Login / Logout ── */
      var loginOverlay = document.getElementById('login-overlay');
      var adminWrapper = document.getElementById('admin-wrapper');
      var loginForm    = document.getElementById('login-form');
      var loginError   = document.getElementById('login-error');
      var pwdInput     = document.getElementById('admin-password');
      var logoutBtn    = document.getElementById('btn-logout');

      function showDashboard() {
        try {
          console.log('🎯 جاري إظهار صفحة الداشبورد...');
          if (loginOverlay) {
            loginOverlay.style.display = 'none';
            console.log('✓ تم إخفاء صفحة تسجيل الدخول');
          }
          if (adminWrapper) {
            adminWrapper.style.display = 'flex';
            console.log('✓ تم عرض الداشبورد');
          }
          console.log('📌 جاري تحميل بيانات الداشبورد...');
          initDashboard().catch(function(err) {
            console.error('❌ خطأ حاد في تحميل الداشبورد:', err);
            alert('⚠️ حدث خطأ: ' + err.message + '\n\nتأكد من:\n1. تشغيل السيرفر (npm start)\n2. فتح الرابط على http://localhost:3000/admin.html');
          });
        } catch(err) {
          console.error('❌ خطأ حاد:', err);
          alert('⚠️ خطأ غير متوقع: ' + err.message);
        }
      }

      if (sessionStorage.getItem('admin_logged_in') === 'true') {
        showDashboard();
      }

      if (loginForm) {
        loginForm.addEventListener('submit', function(e) {
          e.preventDefault();
          var pwd = pwdInput ? pwdInput.value.trim() : '';
          fetch((window.API_BASE_URL || '') + '/api/admin/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password: pwd })
          })
            .then(function(res) { return res.json(); })
            .then(function(data) {
              if (data.success) {
                sessionStorage.setItem('admin_logged_in', 'true');
                sessionStorage.setItem('admin_password', pwd);
                if (loginError) loginError.classList.remove('show');
                if (pwdInput)   pwdInput.style.borderColor = '';
                showDashboard();
              } else {
                if (loginError) {
                  loginError.textContent = (window.t && window.t('admin_login_error')) || 'الرمز السري غير صحيح!';
                  loginError.classList.add('show');
                }
                if (pwdInput)   pwdInput.style.borderColor = '#ef4444';
              }
            })
            .catch(function() {
              if (loginError) {
                loginError.textContent = 'خطأ في الاتصال بالسيرفر';
                loginError.classList.add('show');
              }
            });
        });
      }

      if (logoutBtn) {
        logoutBtn.addEventListener('click', function() {
          sessionStorage.removeItem('admin_logged_in');
          sessionStorage.removeItem('admin_password');
          window.location.reload();
        });
      }

      /* ── Error Alert Close Handler ── */
      var errorCloseBtn = document.getElementById('admin-error-close');
      if (errorCloseBtn) {
        errorCloseBtn.addEventListener('click', function() {
          var errorAlert = document.getElementById('admin-error-alert');
          if (errorAlert) {
            errorAlert.style.display = 'none';
          }
        });
      }
      /* ── Expose Rendering Functions to Window for Language Switching Updates ── */
      window.loadDashboardStats = loadDashboardStats;
      window.renderOrdersTable = renderOrdersTable;
      window.renderAdminProductsList = renderAdminProductsList;
      window.renderLeadsTable = renderLeadsTable;
      window.renderCustomOrdersTable = renderCustomOrdersTable;

    });
  </script>

  <!-- Custom Order Layer Preview Modal -->
  <script src="js/custom-order-preview-modal.js"></script>

</body>
</html>

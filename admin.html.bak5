  <!-- ============================================================
       SCRIPTS FOR ADMIN DASHBOARD
  ============================================ -->
  <script>
    // Fallback quick login handler in case DOMContentLoaded listeners are delayed
    window.adminQuickLogin = function(e) {
      if (e && typeof e.preventDefault === 'function') e.preventDefault();
      var pwdInput = document.getElementById('admin-password');
      var pwd = pwdInput ? pwdInput.value.trim() : '';
      var loginError = document.getElementById('login-error');
      fetch((window.API_BASE_URL || '') + '/api/admin/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pwd })
      })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.success) {
            sessionStorage.setItem('admin_logged_in', 'true');
            sessionStorage.setItem('admin_password', pwd);
            if (loginError) loginError.classList.remove('show');
            if (pwdInput) pwdInput.style.borderColor = '';
            if (typeof window.showDashboard === 'function') {
              window.showDashboard();
            } else {
              window.location.reload();
            }
          } else {
            if (loginError) {
              loginError.textContent = (window.t && window.t('admin_login_error')) || 'الرمز السري غير صحيح!';
              loginError.classList.add('show');
            }
            if (pwdInput) pwdInput.style.borderColor = '#ef4444';
          }
        })
        .catch(function() {
          if (loginError) {
            loginError.textContent = 'خطأ في الاتصال بالسيرفر';
            loginError.classList.add('show');
          }
        });
    };
  </script>
  <!-- Central API Config (MUST be first) -->
  <script src="js/config.js"></script>
  <script src="js/products.js"></script>
  <script src="js/i18n.js"></script>
  <script>
    // Sidebar toggle handler (mobile) — also toggle nav/footer display for reliability
    document.addEventListener('DOMContentLoaded', function() {
      var toggle = document.getElementById('sidebar-toggle');
      var sidebar = document.querySelector('.admin-sidebar');
      if (!toggle || !sidebar) return;
      var navList = document.querySelector('.sidebar-nav ul');
      var footer = document.querySelector('.sidebar-footer');
      toggle.addEventListener('click', function (e) {
        e.preventDefault();
        var collapsed = sidebar.classList.toggle('collapsed');
        toggle.setAttribute('aria-expanded', (!collapsed).toString());
        try {
          if (navList) navList.style.display = collapsed ? 'none' : '';
          if (footer) footer.style.display = collapsed ? 'none' : '';
        } catch (err) { /* ignore */ }
      });
    });
  </script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {

      /* ════════════════════════════════════════════
         API HELPER — كل الطلبات تمر عبر API_BASE_URL
         لا يوجد أي fallback إلى localStorage للبيانات
      ════════════════════════════════════════════ */
      function apiUrl(path) {
        return (window.API_BASE_URL || '') + path;
      }

      function resolveAssetUrl(url) {
        if (!url) return '';
        if (url.indexOf('data:') === 0 || url.indexOf('http://') === 0 || url.indexOf('https://') === 0) {
          return url;
        }
        if (window.location.protocol === 'file:') {
          if (url.indexOf('/uploads/') === 0) {
            return '.' + url;
          }
          if (url.indexOf('uploads/') === 0) {
            return './' + url;
          }
        }
        var base = window.API_BASE_URL || '';
        if (url.indexOf('/') === 0) {
          return base + url;
        }
        return base + '/' + url;
      }
      window.resolveAssetUrl = resolveAssetUrl;

      function getAreaLabel(area) {
        if (!area) return 'غير محدد / Non défini';
        var areaNames = {
          'Center': 'وسط الصدر / Centre',
          'ChestLeft': 'صدر يسار / Gauche',
          'ChestRight': 'صدر يمين / Droite',
          'Back': 'الظهر / Dos',
          'SleeveRight': 'الكم الأيمن / Manche Droite',
          'SleeveLeft': 'الكم الأيسر / Manche Gauche',
          'Front': 'الجهة الأمامية / Avant',
          'Left': 'الجهة اليسرى / Gauche',
          'Right': 'الجهة اليمنى / Droite',
          'Sleeve': 'الكم / Manche'
        };
        return areaNames[area] || (area.charAt(0).toUpperCase() + area.slice(1));
      }
      window.getAreaLabel = getAreaLabel;

      async function apiFetch(path, options) {
        options = options || {};
        var controller = new AbortController();
        var timeoutId = setTimeout(function() { controller.abort(); }, 15000); // 15-second timeout
        options.signal = controller.signal;
        try {
          var res = await fetch(apiUrl(path), options);
          clearTimeout(timeoutId);
          var contentType = res.headers.get('content-type') || '';
          var bodyText = await res.text();
          var body = null;
          if (bodyText) {
            try {
              body = JSON.parse(bodyText);
            } catch (e) {
              body = { message: bodyText };
            }
          }
          if (!res.ok) {
            var serverMessage = body && (body.error || body.message || body.details || body.detail);
            throw new Error('API error ' + res.status + ' for ' + path + (serverMessage ? ': ' + serverMessage : ''));
          }
          var dotStatus = document.querySelector('.dot-status');
          var statusText = document.getElementById('server-status-text');
          if (dotStatus) dotStatus.classList.remove('disconnected');
          if (statusText) { statusText.dataset.state = 'connected'; statusText.textContent = (window.t && window.t('admin_profile_status')) || 'لوحة المشرف متصلة'; }
          return body || (contentType.indexOf('application/json') !== -1 ? JSON.parse(bodyText) : null);
        } catch(err) {
          clearTimeout(timeoutId);
          var dotStatus = document.querySelector('.dot-status');
          if (dotStatus) dotStatus.classList.add('disconnected');
          var statusText = document.getElementById('server-status-text');
          if (statusText) {
            statusText.dataset.state = 'disconnected';
            statusText.textContent = (window.t && window.t('admin_server_disconnected')) || 'الخادم غير متصل';
          }
          throw err;
        }
      }

      var cachedOrders = null;
      var cachedLeads = null;

      // Helper to fetch server-only orders (Single Source of Truth)
      async function getOrders(forceRefresh) {
        if (cachedOrders && !forceRefresh) {
          return cachedOrders;
        }
        
        // Try to trigger sync of pending orders on current device first
        if (window.syncPendingOrders) {
          try {
            await window.syncPendingOrders();
          } catch(err) {
            console.warn('Sync pending orders failed:', err);
          }
        }

        var orders = await apiFetch('/api/orders'); // let failures propagate — never silently substitute stale cached data

        cachedOrders = orders;
        return orders;
      }

      // Helper to fetch server-only leads
      async function getLeads(forceRefresh) {
        if (cachedLeads && !forceRefresh) {
          return cachedLeads;
        }

        // Try to trigger sync of pending leads on current device first
        if (window.syncPendingLeads) {
          try {
            await window.syncPendingLeads();
          } catch(err) {
            console.warn('Sync pending leads failed:', err);
          }
        }

        var leads = [];
        try {
          leads = await apiFetch('/api/leads');
        } catch(e) {
          console.warn('Could not load leads from backend server, falling back to localStorage:', e);
          try {
            leads = JSON.parse(localStorage.getItem('local_leads') || '[]');
          } catch(localErr) {
            leads = [];
          }
        }

        cachedLeads = leads;
        return leads;
      }

      // Listen for orders-synced event to refresh dashboard
      window.addEventListener('orders-synced', function() {
        console.log('🔄 Dashboard notified of synced orders, refreshing...');
        getOrders(true).then(function() {
          var activeFilter = document.querySelector('.filter-btn.active') ? document.querySelector('.filter-btn.active').getAttribute('data-filter') : 'all';
          renderOrdersTable(activeFilter || 'all', false);
          loadDashboardStats(false);
        });
      });

      /* ── Order actions (global) ── */
      window.changeOrderStatus = async function(orderId, newStatus) {
        // Optimistic UI update
        var oldOrders = JSON.parse(JSON.stringify(cachedOrders || []));
        var order = (cachedOrders || []).find(function(o) { return String(o.id) === String(orderId); });
        if (order) {
          order.status = newStatus;
        }
        
        // Determine which panel is active
        var activePanel = document.querySelector('.nav-btn.active');
        var targetPanel = activePanel ? activePanel.getAttribute('data-target') : 'panel-orders';
        
        // Render both tables and stats to keep them in sync
        var ordersFilter = document.querySelector('#panel-orders .filter-btn.active') ? document.querySelector('#panel-orders .filter-btn.active').getAttribute('data-filter') : 'all';
        var customFilter = document.querySelector('#panel-custom-orders .filter-btn.active') ? document.querySelector('#panel-custom-orders .filter-btn.active').getAttribute('data-filter') : 'all';
        
        renderOrdersTable(ordersFilter || 'all', false);
        renderCustomOrdersTable(customFilter || 'all', false);
        loadDashboardStats(false);

        try {
          // Try to update on backend first
          await apiFetch('/api/orders/' + orderId + '/status', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: newStatus })
          });
        } catch(e) {
          console.warn('Backend update failed, checking local storage:', e);
          var localOrders = JSON.parse(localStorage.getItem('local_orders') || '[]');
          var idx = localOrders.findIndex(function(o) { return String(o.id) === String(orderId); });
          if (idx > -1) {
            localOrders[idx].status = newStatus;
            localStorage.setItem('local_orders', JSON.stringify(localOrders));
          } else {
            // Rollback optimistic update on failure
            cachedOrders = oldOrders;
            var ordersFilter = document.querySelector('#panel-orders .filter-btn.active') ? document.querySelector('#panel-orders .filter-btn.active').getAttribute('data-filter') : 'all';
            var customFilter = document.querySelector('#panel-custom-orders .filter-btn.active') ? document.querySelector('#panel-custom-orders .filter-btn.active').getAttribute('data-filter') : 'all';
            renderOrdersTable(ordersFilter || 'all', false);
            renderCustomOrdersTable(customFilter || 'all', false);
            loadDashboardStats(false);
            alert((window.t && window.t('admin_err_update_status_server')) || '⚠️ تعذّر تحديث حالة الطلب. تأكد من تشغيل السيرفر.');
            console.error(e);
          }
        }
      };

      window.shipOrderViaZR = async function(orderId) {
        var order = (cachedOrders || []).find(function(o) { return String(o.id) === String(orderId); });
        if (!order) {
          alert('❌ لم يتم العثور على الطلب');
          return;
        }

        try {
          console.log('🚀 جاري شحن الطلب عبر ZR Express:', orderId);
          
          // Call ZR shipping endpoint
          var response = await apiFetch('/api/orders/' + orderId + '/ship-zr', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              orderId: orderId,
              customerName: order.customer.name,
              customerPhone: order.customer.phone,
              wilaya: order.customer.wilaya,
              address: order.customer.address
            })
          });

          if (response && response.success) {
            console.log('✅ تم الشحن عبر ZR:', response);
            
            // Update order with tracking info
            order.trackingNumber = response.trackingNumber || response.parcelId;
            order.zrParcelId = response.parcelId;
            order.zrStatus = response.status || { state: 'OrderReceived', situation: '' };
            order.shippedAt = new Date().toISOString();
            order.status = 'livré';

            // Update local storage
            var localOrders = JSON.parse(localStorage.getItem('local_orders') || '[]');
            var idx = localOrders.findIndex(function(o) { return String(o.id) === String(orderId); });
            if (idx > -1) {
              localOrders[idx] = order;
            } else {
              localOrders.push(order);
            }
            localStorage.setItem('local_orders', JSON.stringify(localOrders));

            // Refresh UI - refresh both tables
            var ordersFilter = document.querySelector('#panel-orders .filter-btn.active') ? document.querySelector('#panel-orders .filter-btn.active').getAttribute('data-filter') : 'all';
            var customFilter = document.querySelector('#panel-custom-orders .filter-btn.active') ? document.querySelector('#panel-custom-orders .filter-btn.active').getAttribute('data-filter') : 'all';
            renderOrdersTable(ordersFilter || 'all', false);
            renderCustomOrdersTable(customFilter || 'all', false);
            loadDashboardStats(false);

            alert('✅ تم شحن الطلب بنجاح عبر ZR Express!\n\nرقم التتبع: ' + order.trackingNumber);
          } else {
            alert('❌ فشل الشحن: ' + (response?.error || 'خطأ غير معروف'));
            console.error('Shipping error:', response);
          }
        } catch(e) {
          console.error('❌ خطأ في الشحن:', e);
          alert('❌ حدث خطأ أثناء الشحن:\n' + e.message);
        }
      };

      window.deleteOrder = async function(orderId) {
        var confirmMsg = ((window.t && window.t('admin_confirm_delete_order')) || 'هل أنت متأكد من حذف الطلب #{id} نهائياً؟').replace('{id}', orderId);
        if (!confirm(confirmMsg)) return;

        // Optimistic UI update
        var oldOrders = JSON.parse(JSON.stringify(cachedOrders || []));
        cachedOrders = (cachedOrders || []).filter(function(o) { return String(o.id) !== String(orderId); });

        // Render both tables instantly
        var ordersFilter = document.querySelector('#panel-orders .filter-btn.active') ? document.querySelector('#panel-orders .filter-btn.active').getAttribute('data-filter') : 'all';
        var customFilter = document.querySelector('#panel-custom-orders .filter-btn.active') ? document.querySelector('#panel-custom-orders .filter-btn.active').getAttribute('data-filter') : 'all';
        renderOrdersTable(ordersFilter || 'all', false);
        renderCustomOrdersTable(customFilter || 'all', false);
        loadDashboardStats(false);

        try {
          // Try to delete from backend first
          await apiFetch('/api/orders/' + orderId, { method: 'DELETE' });
        } catch(e) {
          console.warn('Backend delete failed, checking local storage:', e);
          var localOrders = JSON.parse(localStorage.getItem('local_orders') || '[]');
          var initialLen = localOrders.length;
          localOrders = localOrders.filter(function(o) { return String(o.id) !== String(orderId); });
          if (localOrders.length < initialLen) {
            localStorage.setItem('local_orders', JSON.stringify(localOrders));
          } else {
            // Rollback optimistic update on failure
            cachedOrders = oldOrders;
            var ordersFilter = document.querySelector('#panel-orders .filter-btn.active') ? document.querySelector('#panel-orders .filter-btn.active').getAttribute('data-filter') : 'all';
            var customFilter = document.querySelector('#panel-custom-orders .filter-btn.active') ? document.querySelector('#panel-custom-orders .filter-btn.active').getAttribute('data-filter') : 'all';
            renderOrdersTable(ordersFilter || 'all', false);
            renderCustomOrdersTable(customFilter || 'all', false);
            loadDashboardStats(false);
            alert('⚠️ ' + ((window.t && window.t('admin_error_generic')) || 'حدث خطأ. تأكد من تشغيل السيرفر.'));
            console.error(e);
          }
        }
      };

      /* ── Product actions (global) ── */
      window.deleteProduct = async function(productId) {
        var p = PRODUCTS.find(function(item) { return item.id === productId; });
        if (!p) return;
        var confirmMsg = p.isCustom 
          ? ((window.t && window.t('admin_confirm_delete_product')) || 'هل أنت متأكد من حذف هذا المنتج نهائياً؟')
          : ((window.t && window.t('admin_confirm_delete_product_default')) || 'هل أنت متأكد من حذف هذا المنتج الافتراضي من المتجر؟');
        if (!confirm(confirmMsg)) return;
        
        // Optimistic UI update
        var oldProducts = JSON.parse(JSON.stringify(PRODUCTS || []));
        PRODUCTS = (PRODUCTS || []).filter(function(item) { return item.id !== productId; });
        window.PRODUCTS = PRODUCTS;

        // Render instantly
        renderAdminProductsList(false);
        loadDashboardStats(false);

        try {
          var url = p.isCustom 
            ? ('/api/custom-products/' + productId) 
            : ('/api/default-products/' + productId);
          await apiFetch(url, { method: 'DELETE' });
        } catch(e) {
          // Rollback optimistic update on failure
          PRODUCTS = oldProducts;
          window.PRODUCTS = PRODUCTS;
          renderAdminProductsList(false);
          loadDashboardStats(false);
          alert('⚠️ ' + ((window.t && window.t('admin_error_generic')) || 'تعذّر حذف المنتج.'));
          console.error(e);
        }
      };

      /* ── Lead actions (global) ── */
      window.deleteLead = async function(email) {
        var confirmMsg = ((window.t && window.t('admin_confirm_delete_lead')) || 'هل أنت متأكد من حذف هذا المشترك؟ {email}').replace('{email}', email);
        if (!confirm(confirmMsg)) return;

        // Optimistic UI update
        var oldLeads = JSON.parse(JSON.stringify(cachedLeads || []));
        cachedLeads = (cachedLeads || []).filter(function(l) { return l.email !== email; });

        // Render instantly
        renderLeadsTable(false);
        loadDashboardStats(false);

        try {
          // Try to delete from backend first
          await apiFetch('/api/leads/' + encodeURIComponent(email), { method: 'DELETE' });
        } catch(e) {
          console.warn('Backend delete lead failed, checking local storage:', e);
          var localLeads = JSON.parse(localStorage.getItem('local_leads') || '[]');
          var initialLen = localLeads.length;
          localLeads = localLeads.filter(function(l) { return l.email !== email; });
          if (localLeads.length < initialLen) {
            localStorage.setItem('local_leads', JSON.stringify(localLeads));
          } else {
            // Rollback optimistic update on failure
            cachedLeads = oldLeads;
            renderLeadsTable(false);
            loadDashboardStats(false);
            alert('⚠️ ' + ((window.t && window.t('admin_error_generic')) || 'تعذّر حذف المشترك.'));
            console.error(e);
          }
        }
      };

      /* ── Stats ── */
      async function loadDashboardStats(forceRefresh) {
        console.log('📊 جاري تحميل الإحصائيات...');
        var orders = [], leads = [];

        try {
          orders = await getOrders(forceRefresh);
          console.log('✓ تم تحميل', orders.length, 'طلب');
        } catch(err) {
          console.warn('⚠️ فشل تحميل الطلبات:', err.message);
          orders = [];
        }

        try {
          leads = await getLeads(forceRefresh);
          console.log('✓ تم تحميل', leads.length, 'مشترك');
        } catch(err) {
          console.warn('⚠️ فشل تحميل المشتركين:', err.message);
          leads = [];
        }

        var confirmedOrders = orders.filter(function(o){ return o.status === 'Confirmed' || o.status === 'ReadyToShip' || o.status === 'InDelivery' || o.status === 'confirmé' || o.status === 'livré'; });
        var totalSales = confirmedOrders.reduce(function(acc, o){ return acc + o.total; }, 0);
        var returnedCount = orders.filter(function(o){ return o.status === 'Returned' || o.status === 'retourné'; }).length;
        var deliveredCount = orders.filter(function(o){ return o.status === 'Delivered' || o.status === 'livré'; }).length;

        var statSales = document.getElementById('stat-sales');
        if (statSales) {
          statSales.textContent = totalSales.toLocaleString() + ' DZD';
          console.log('💰 إجمالي المبيعات:', totalSales, 'DZD');
        }
        
        var statOrdersTotal = document.getElementById('stat-orders-total');
        if (statOrdersTotal) statOrdersTotal.textContent = orders.length;

        var badge = document.getElementById('pending-badge');
        if (badge) {
          badge.textContent = 0;
          badge.style.display = 'none';
        }

        try {
          await loadProducts(forceRefresh);
          console.log('✓ تم تحميل', PRODUCTS.length, 'منتج');
        } catch(err) {
          console.warn('⚠️ فشل تحميل المنتجات:', err.message);
          if (!PRODUCTS) window.PRODUCTS = PRODUCTS = [];
        }
        
        var statProductsTotal = document.getElementById('stat-products-total');
        if (statProductsTotal) {
          var productsCount = PRODUCTS && PRODUCTS.length > 0 ? PRODUCTS.length : 0;
          statProductsTotal.textContent = productsCount;
        }

        var returnedTotal = document.getElementById('stat-returned-total');
        if (returnedTotal) returnedTotal.textContent = returnedCount;

        var deliveredTotal = document.getElementById('stat-delivered-total');
        if (deliveredTotal) deliveredTotal.textContent = deliveredCount;

        var leadsTotal = document.getElementById('stat-leads-total');
        if (leadsTotal) leadsTotal.textContent = leads.length;
        var leadsBadge = document.getElementById('leads-badge');
        if (leadsBadge) {
          leadsBadge.textContent = leads.length;
          leadsBadge.style.display = leads.length > 0 ? 'inline-flex' : 'none';
        }

        // Recent orders table
        var recentList = document.getElementById('recent-orders-list');
        if (!recentList) {
          console.warn('⚠️ لم يتم العثور على عنصر recent-orders-list');
          return;
        }
        
        var sortedOrders = orders.slice()
          .sort(function(a,b){ return new Date(b.date || b.createdAt || b.created_at || b.orderDate || 0) - new Date(a.date || a.createdAt || a.created_at || a.orderDate || 0); })
          .slice(0, 5);

        if (sortedOrders.length === 0) {
          recentList.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:2rem;">' + ((window.t && window.t('admin_orders_recent_empty')) || 'لا توجد طلبات مسجّلة بعد.') + '</td></tr>';
          return;
        }

        recentList.innerHTML = sortedOrders.map(function(order) {
          var _tStat = window.t || function(k){ return k; };
          var statusText, statusClass;
          var statusMap = {
            'Confirmed': window.t('status_confirmed') || 'مؤكد',
            'ReadyToShip': window.t('status_ready') || 'جاهز للشحن',
            'InDelivery': window.t('status_delivery') || 'قيد التوصيل',
            'Delivered': window.t('status_delivered') || 'تم التسليم',
            'Returned': window.t('status_returned') || 'مُرجع',
            'Cancelled': window.t('status_cancelled') || 'ملغى',
            'confirmé': 'مؤكد',
            'livré': 'تم التسليم',
            'retourné': 'مُرجع',
            'annulé': 'ملغى'
          };
          statusText = statusMap[order.status] || order.status;
          
          var classMap = {
            'Confirmed': 'status-confirmed', 'ReadyToShip': 'status-ready',
            'InDelivery': 'status-delivery', 'Delivered': 'status-delivered', 'Returned': 'status-returned',
            'Cancelled': 'status-cancelled',
            'confirmé': 'status-confirmed', 'livré': 'status-delivered',
            'retourné': 'status-returned', 'annulé': 'status-cancelled'
          };
          statusClass = classMap[order.status] || 'status-confirmed';
          
          var orderDate = order.date || order.createdAt || order.created_at || order.orderDate;
          var currentLang = localStorage.getItem('aizo_lang') || 'fr';
          var dtLocale = currentLang === 'ar' ? 'ar-DZ' : currentLang === 'fr' ? 'fr-FR' : 'en-US';
          var dt = orderDate ? new Date(orderDate).toLocaleDateString(dtLocale, { hour:'2-digit', minute:'2-digit' }) : '—';
          
          var rawDelivery = order.customer.delivery || order.delivery || order.customer.deliveryType || 'Home';
          var deliveryLabel = rawDelivery;
          if (rawDelivery.toLowerCase().includes('office') || rawDelivery.includes('مكتب')) {
            deliveryLabel = window.t('delivery_office') || 'توصيل للمكتب';
          } else {
            deliveryLabel = window.t('delivery_home') || 'توصيل للمنزل';
          }
          var _tStatRow = window.t || function(k){ return k; };
          return '<tr>'
            + '<td data-label="' + _tStatRow('admin_col_order_id') + '"><strong>#' + order.id + '</strong></td>'
            + '<td data-label="' + _tStatRow('admin_col_date') + '">' + dt + '</td>'
            + '<td data-label="' + _tStatRow('admin_col_customer') + '">' + order.customer.name + '</td>'
            + '<td data-label="' + _tStatRow('admin_col_wilaya') + '">' + order.customer.wilaya + '</td>'
            + '<td data-label="' + _tStatRow('admin_col_phone') + '">' + order.customer.phone + '</td>'
            + '<td data-label="' + _tStatRow('admin_col_delivery') + '">' + deliveryLabel + '</td>'
            + '<td data-label="' + _tStatRow('admin_col_total') + '"><strong>' + order.total.toLocaleString() + ' DZD</strong></td>'
            + '<td data-label="' + _tStatRow('admin_col_status') + '"><span class="status-badge ' + statusClass + '">' + statusText + '</span></td>'
            + '</tr>';
        }).join('');
      }

      // Dropdown toggle window listener to close only when action items are clicked (disabling close-on-click-outside)
      document.addEventListener('click', function(event) {
        if (!event || !event.target || !event.target.closest) return;
        
        var isDropdownItem = event.target.closest('.dropdown-item') || event.target.closest('.dropdown-item-text');
        
        // Only close if we clicked an action item/button inside the menu
        if (isDropdownItem) {
          document.querySelectorAll('.admin-dropdown-menu.show').forEach(function(m) {
            m.classList.remove('show');
          });
        }
      });

      // Block accidental click-through during dropdown cooldown
      document.addEventListener('click', function(event) {
        if (!event || !event.target || !event.target.closest) return;
        var activeMenu = event.target.closest('.admin-dropdown-menu');
        if (activeMenu && activeMenu.classList.contains('dropdown-cooldown')) {
          console.log('[Dropdown] Click blocked during cooldown');
          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
        }
      }, true); // Use capture phase to intercept before inline onclick handlers

      window.toggleActionsDropdown = function(event, btn, orderId) {
        if (event) {
          event.preventDefault();
          event.stopPropagation();
        }
        
        // Handle alternative signature toggleActionsDropdown(event, orderId)
        if (btn && typeof btn === 'string' && !orderId) {
          orderId = btn;
          btn = null;
        }
        
        // If btn is not a DOM node, try to retrieve it from event target
        if (!btn && event && event.target) {
          btn = event.target.closest('.btn-dropdown-toggle');
        }
        
        console.log('[Dropdown] toggleActionsDropdown invoked for orderId:', orderId);
        
        var menu = null;
        if (btn) {
          menu = btn.nextElementSibling || btn.parentNode.querySelector('.admin-dropdown-menu');
        }
        if (!menu && orderId) {
          menu = document.getElementById('dropdown-menu-' + orderId);
        }
        
        if (!menu) {
          console.error('[Dropdown] Menu element NOT found for orderId:', orderId);
          return;
        }
        var isOpen = menu.classList.contains('show');
        console.log('[Dropdown] Menu found. Current isOpen state:', isOpen);
        
        // Close all other dropdowns
        document.querySelectorAll('.admin-dropdown-menu.show').forEach(function(m) {
          if (m !== menu) {
            m.classList.remove('show');
            m.classList.remove('dropdown-cooldown');
          }
        });
        
        if (isOpen) {
          menu.classList.remove('show');
          menu.classList.remove('dropdown-cooldown');
          console.log('[Dropdown] Closed menu');
        } else {
          menu.classList.add('show');
          menu.classList.add('dropdown-cooldown');
          setTimeout(function() {
            menu.classList.remove('dropdown-cooldown');
            console.log('[Dropdown] Cooldown removed');
          }, 350);
          window.__justOpened = true; // Set flag to block immediate click-outside closing
          console.log('[Dropdown] Added "show" class to menu');
          
          // Calculate optimal position synchronously to prevent lag/flicker
          if (btn) {
            var btnRect = btn.getBoundingClientRect();
            var menuRect = menu.getBoundingClientRect();
            
            var topPos = btnRect.bottom + 6;
            var leftPos = btnRect.left - (menuRect.width - btnRect.width) / 2;
            
            // Prevent overflow on right side
            var maxLeftPos = window.innerWidth - menuRect.width - 12;
            if (leftPos > maxLeftPos) {
              leftPos = maxLeftPos;
            }
            
            // Prevent overflow on left side
            if (leftPos < 12) {
              leftPos = 12;
            }
            
            // Check if menu goes below viewport
            var bottomPos = topPos + menuRect.height;
            if (bottomPos > window.innerHeight - 12) {
              topPos = btnRect.top - menuRect.height - 6;
            }
            
            menu.style.top = topPos + 'px';
            menu.style.left = leftPos + 'px';
          }
        }
      };

      window.handleDesignThumbError = function(img) {
        img.onerror = null;
        img.src = 'data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="%23ef4444" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';
      };

      /* ═══════════════════════════════════════════════════════════
         CUSTOM ORDER DETAILS — INTERACTIVE DASHBOARD
         Global SVG Generator + Split-Pane Renderer
      ═══════════════════════════════════════════════════════════ */

      // ── Color name → hex mapper ──
      var CO_COLOR_TO_HEX = {
        'Noir': '#1a1a1a', 'أسود': '#1a1a1a', 'black': '#1a1a1a', 'Black': '#1a1a1a',
        'Blanc': '#FFFFFF', 'white': '#FFFFFF', 'White': '#FFFFFF',
        'Beige': '#D4C5A9', 'beige': '#D4C5A9',
        'Navy': '#1B2A4A', 'Gris': '#4A5568', 'gray': '#4A5568', 'Grey': '#4A5568',
        'Marron': '#5B2C1A', 'Brown': '#5B2C1A'
      };

      // ── Garment type detection from order items ──
      function detectGarmentTypeFromOrder(order) {
        var name = '';
        if (order && order.items && order.items.length > 0) {
          name = (order.items[0].name || '').toLowerCase();
        }
        if (name.indexOf('hoodie') !== -1) return 'hoodie';
        if (name.indexOf('polo') !== -1) return 'polo';
        if (name.indexOf('cap') !== -1 || name.indexOf('casquette') !== -1) return 'cap';
        if (name.indexOf('bob') !== -1) return 'bob';
        if (name.indexOf('jogging') !== -1) return 'jogging';
        if (name.indexOf('short') !== -1) return 'short';
        return 'tshirt';
      }

      // ── Global SVG Garment Generator (mirrors customize.js) ──
      window.adminGenerateGarmentSVG = function(type, area, color) {
        var view = 'front';
        if (area === 'Back') { view = 'back'; }
        else if (area === 'SleeveRight') { view = 'sleeve-right'; }
        else if (area === 'SleeveLeft') { view = 'sleeve-left'; }

        var paths = '';
        var w = 480, h = 520;

        if (type === 'hoodie') {
          if (view === 'front') {
            paths = '<path d="M 120 120 L 160 80 C 180 120, 300 120, 320 80 L 360 120 L 430 420 L 390 435 L 340 230 L 340 460 C 340 470, 330 480, 320 480 L 160 480 C 150 480, 140 470, 140 460 L 140 230 L 90 435 L 50 420 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
              + '<path d="M 170 340 L 310 340 L 330 420 L 150 420 Z" fill="' + color + '" stroke="rgba(0,0,0,0.15)" stroke-width="3" stroke-linejoin="round"/>'
              + '<path d="M 170 340 L 150 420 M 310 340 L 330 420" stroke="rgba(0,0,0,0.3)" stroke-width="2"/>'
              + '<path d="M 160 80 C 140 0, 340 0, 320 80 C 310 100, 170 100, 160 80 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="3"/>'
              + '<path d="M 220 85 C 235 95, 245 95, 260 85" fill="none" stroke="rgba(0,0,0,0.25)" stroke-width="3"/>'
              + '<path d="M 230 90 L 230 180 M 250 90 L 250 170" stroke="#f5f5f5" stroke-width="4" stroke-linecap="round"/>'
              + '<circle cx="230" cy="180" r="3" fill="#888"/><circle cx="250" cy="170" r="3" fill="#888"/>'
              + '<path d="M 140 160 L 90 435 M 340 160 L 390 435" stroke="rgba(0,0,0,0.2)" stroke-width="3"/>'
              + '<rect x="140" y="465" width="200" height="15" fill="rgba(0,0,0,0.1)" stroke="rgba(0,0,0,0.2)" stroke-width="1"/>'
              + '<rect x="50" y="418" width="40" height="12" transform="rotate(-20 50 418)" fill="rgba(0,0,0,0.1)" stroke="rgba(0,0,0,0.2)"/>'
              + '<rect x="390" y="418" width="40" height="12" transform="rotate(20 390 418)" fill="rgba(0,0,0,0.1)" stroke="rgba(0,0,0,0.2)"/>';
          } else if (view === 'back') {
            paths = '<path d="M 120 120 L 160 80 C 180 90, 300 90, 320 80 L 360 120 L 430 420 L 390 435 L 340 230 L 340 460 C 340 470, 330 480, 320 480 L 160 480 C 150 480, 140 470, 140 460 L 140 230 L 90 435 L 50 420 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
              + '<path d="M 160 80 C 180 50, 300 50, 320 80 C 310 170, 170 170, 160 80 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="3"/>'
              + '<path d="M 190 120 C 210 145, 270 145, 290 120" fill="none" stroke="rgba(0,0,0,0.2)" stroke-width="2"/>'
              + '<rect x="140" y="465" width="200" height="15" fill="rgba(0,0,0,0.1)" stroke="rgba(0,0,0,0.2)" stroke-width="1"/>'
              + '<rect x="50" y="418" width="40" height="12" transform="rotate(-20 50 418)" fill="rgba(0,0,0,0.1)" stroke="rgba(0,0,0,0.2)"/>'
              + '<rect x="390" y="418" width="40" height="12" transform="rotate(20 390 418)" fill="rgba(0,0,0,0.1)" stroke="rgba(0,0,0,0.2)"/>';
          } else {
            paths = '<path d="M 240 60 L 130 90 L 150 420 L 330 420 L 350 90 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
              + '<path d="M 130 90 C 200 40, 280 40, 350 90" fill="none" stroke="rgba(0,0,0,0.2)" stroke-width="3"/>'
              + '<rect x="150" y="405" width="180" height="15" fill="rgba(0,0,0,0.1)" stroke="rgba(0,0,0,0.2)" stroke-width="1"/>'
              + '<path d="M 140 180 Q 240 200, 340 180 M 145 280 Q 240 295, 335 280" fill="none" stroke="rgba(0,0,0,0.08)" stroke-width="2"/>';
          }
        } else if (type === 'polo') {
          if (view === 'front') {
            paths = '<path d="M 110 110 L 180 60 C 190 85, 290 85, 300 60 L 370 110 L 420 200 L 370 230 L 340 210 L 340 460 C 340 470, 330 480, 320 480 L 160 480 C 150 480, 140 470, 140 460 L 140 210 L 110 230 L 60 200 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
              + '<path d="M 180 60 L 220 120 L 240 120 L 240 60 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="2"/>'
              + '<path d="M 300 60 L 260 120 L 240 120 L 240 60 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="2"/>'
              + '<path d="M 225 120 L 225 210 L 255 210 L 255 120 Z" fill="rgba(0,0,0,0.05)" stroke="rgba(0,0,0,0.2)" stroke-width="2"/>'
              + '<circle cx="240" cy="140" r="3" fill="#f5f5f5" stroke="#ccc"/><circle cx="240" cy="170" r="3" fill="#f5f5f5" stroke="#ccc"/><circle cx="240" cy="195" r="3" fill="#f5f5f5" stroke="#ccc"/>'
              + '<path d="M 60 200 L 110 230 M 420 200 L 370 230" stroke="rgba(0,0,0,0.25)" stroke-width="2"/>';
          } else if (view === 'back') {
            paths = '<path d="M 110 110 L 180 60 C 190 70, 290 70, 300 60 L 370 110 L 420 200 L 370 230 L 340 210 L 340 460 C 340 470, 330 480, 320 480 L 160 480 C 150 480, 140 470, 140 460 L 140 210 L 110 230 L 60 200 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
              + '<path d="M 180 60 C 210 75, 270 75, 300 60 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="2"/>';
          } else {
            paths = '<path d="M 240 80 L 110 120 L 140 380 L 340 380 L 370 120 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
              + '<path d="M 110 120 C 190 70, 290 70, 370 120" fill="none" stroke="rgba(0,0,0,0.2)" stroke-width="3"/>'
              + '<rect x="140" y="355" width="200" height="25" fill="rgba(0,0,0,0.08)" stroke="rgba(0,0,0,0.2)" stroke-width="1"/>';
          }
        } else if (type === 'cap') {
          if (view === 'front') {
            paths = '<path d="M 160 250 C 150 140, 330 140, 320 250 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
              + '<path d="M 240 142 C 240 180, 240 210, 240 250" fill="none" stroke="rgba(0,0,0,0.15)" stroke-width="2"/>'
              + '<path d="M 160 250 C 190 200, 290 200, 320 250" fill="none" stroke="rgba(0,0,0,0.15)" stroke-width="2"/>'
              + '<path d="M 150 248 C 130 290, 350 290, 330 248 C 290 265, 190 265, 150 248 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="3" stroke-linejoin="round"/>'
              + '<circle cx="240" cy="142" r="8" fill="' + color + '" stroke="#1e1e1e" stroke-width="2"/>';
          } else {
            paths = '<path d="M 160 250 C 150 140, 330 140, 320 250 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
              + '<path d="M 200 250 C 200 220, 280 220, 280 250 Z" fill="#fafaf9" stroke="#1e1e1e" stroke-width="3"/>'
              + '<rect x="202" y="242" width="76" height="8" rx="2" fill="#292524" stroke="#1c1917" stroke-width="1"/>'
              + '<circle cx="240" cy="142" r="8" fill="' + color + '" stroke="#1e1e1e" stroke-width="2"/>';
          }
        } else if (type === 'bob') {
          paths = '<path d="M 180 170 C 190 155, 290 155, 300 170 L 315 225 L 165 225 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
            + '<path d="M 165 225 C 190 230, 290 230, 315 225" fill="none" stroke="rgba(0,0,0,0.15)" stroke-width="2"/>'
            + '<path d="M 165 225 L 130 265 C 170 285, 310 285, 350 265 L 315 225 C 290 235, 190 235, 165 225 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
            + '<path d="M 140 255 C 175 270, 305 270, 340 255" fill="none" stroke="rgba(0,0,0,0.15)" stroke-width="1.5"/>'
            + '<path d="M 150 245 C 180 258, 300 258, 330 245" fill="none" stroke="rgba(0,0,0,0.15)" stroke-width="1.5"/>';
        } else if (type === 'jogging') {
          paths = '<rect x="170" y="110" width="140" height="20" rx="3" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
            + '<path d="M 235 125 L 230 160 M 245 125 L 250 165" stroke="#f5f5f5" stroke-width="3" stroke-linecap="round"/>'
            + '<path d="M 170 125 L 140 280 L 175 450 L 210 450 L 240 230 L 270 450 L 305 450 L 340 280 L 310 125 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
            + '<rect x="175" y="450" width="35" height="15" fill="rgba(0,0,0,0.1)" stroke="#1e1e1e" stroke-width="2"/>'
            + '<rect x="270" y="450" width="35" height="15" fill="rgba(0,0,0,0.1)" stroke="#1e1e1e" stroke-width="2"/>'
            + '<path d="M 240 125 L 240 230" stroke="rgba(0,0,0,0.2)" stroke-width="3"/>';
        } else if (type === 'short') {
          paths = '<rect x="170" y="110" width="140" height="20" rx="3" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
            + '<path d="M 235 125 L 230 160 M 245 125 L 250 165" stroke="#f5f5f5" stroke-width="3" stroke-linecap="round"/>'
            + '<path d="M 170 125 L 145 260 L 225 260 L 240 200 L 255 260 L 335 260 L 310 125 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
            + '<path d="M 240 125 L 240 200" stroke="rgba(0,0,0,0.2)" stroke-width="3"/>';
        } else {
          // DEFAULT: T-Shirt
          if (view === 'front') {
            paths = '<path d="M 110 110 L 175 60 C 195 80, 285 80, 305 60 L 370 110 L 430 190 L 375 220 L 340 200 L 340 460 C 340 470, 330 480, 320 480 L 160 480 C 150 480, 140 470, 140 460 L 140 200 L 105 220 L 50 190 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
              + '<path d="M 175 60 C 195 80, 285 80, 305 60" fill="none" stroke="#1e1e1e" stroke-width="3"/>'
              + '<path d="M 170 55 C 195 75, 285 75, 310 55" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="2"/>'
              + '<path d="M 105 200 Q 120 205, 140 200 M 375 200 Q 360 205, 340 200" fill="none" stroke="rgba(0,0,0,0.15)" stroke-width="2"/>';
          } else if (view === 'back') {
            paths = '<path d="M 110 110 L 175 60 C 195 68, 285 68, 305 60 L 370 110 L 430 190 L 375 220 L 340 200 L 340 460 C 340 470, 330 480, 320 480 L 160 480 C 150 480, 140 470, 140 460 L 140 200 L 105 220 L 50 190 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
              + '<path d="M 175 60 C 195 68, 285 68, 305 60" fill="none" stroke="#1e1e1e" stroke-width="3"/>';
          } else {
            paths = '<path d="M 240 80 L 110 120 L 140 380 L 340 380 L 370 120 Z" fill="' + color + '" stroke="#1e1e1e" stroke-width="4" stroke-linejoin="round"/>'
              + '<path d="M 110 120 C 190 70, 290 70, 370 120" fill="none" stroke="rgba(0,0,0,0.2)" stroke-width="3"/>'
              + '<path d="M 140 370 L 340 370" stroke="rgba(0,0,0,0.25)" stroke-width="2"/>';
          }
        }

        return '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ' + w + ' ' + h + '" width="' + w + '" height="' + h + '">'
          + '<defs><pattern id="co-checkers" width="20" height="20" patternUnits="userSpaceOnUse"><rect width="20" height="20" fill="rgba(255,255,255,0.03)"/><rect x="10" width="10" height="10" fill="rgba(0,0,0,0.03)"/><rect y="10" width="10" height="10" fill="rgba(0,0,0,0.03)"/></pattern></defs>'
          + '<rect width="' + w + '" height="' + h + '" fill="url(#co-checkers)"/>'
          + '<g>' + paths + '</g>'
          + '</svg>';
      };

      // ── Viewport crop presets (CSS class → transform pairs) ──
      var VIEWPORT_CROP_CLASSES = {
        'Center': 'crop-center',
        'ChestLeft': 'crop-chestleft',
        'ChestRight': 'crop-chestright',
        'Back': 'crop-back',
        'SleeveRight': 'crop-sleeveright',
        'SleeveLeft': 'crop-sleeveleft',
        'Front': 'crop-center'
      };

      // ── Glowing zone presets — percentage-based positions on the mockup ──
      var GLOW_ZONE_PRESETS = {
        'Center':     { left: '25%', top: '22%', width: '50%', height: '45%' },
        'ChestLeft':  { left: '50%', top: '22%', width: '25%', height: '28%' },
        'ChestRight': { left: '25%', top: '22%', width: '25%', height: '28%' },
        'Back':       { left: '25%', top: '18%', width: '50%', height: '50%' },
        'SleeveRight':{ left: '5%',  top: '20%', width: '22%', height: '40%' },
        'SleeveLeft': { left: '73%', top: '20%', width: '22%', height: '40%' }
      };

      // ── Main Dashboard Renderer ──
      window.viewCustomOrderDetails = function(orderId) {
        try {
          console.log('[viewCustomOrderDetails] called with orderId=', orderId);
        } catch (e) {}
        var order = (cachedOrders || []).find(function(o) { return String(o.id) === String(orderId); });
        if (!order) {
          // try matching by rowId if available
          order = (cachedOrders || []).find(function(o) { return String(o.rowId) === String(orderId); });
        }
        if (!order || !order.customOrder) return;

        var co = order.customOrder;
        var modal = document.getElementById('custom-order-modal');
        var body = document.getElementById('custom-modal-body');
        var garmentType = detectGarmentTypeFromOrder(order);
        var garmentHex = CO_COLOR_TO_HEX[co.color] || '#1a1a1a';
        var resolvedMockupUrl = window.resolveAssetUrl(co.mockupSnapshot || '');

        // ── Build Left Pane: Mockup Preview and Summary ──
        var layerSummaryHtml = 'لا توجد تصاميم';
        if (co.layers && co.layers.length > 0) {
          layerSummaryHtml = co.layers.map(function(layer, idx) {
            var areaKey = layer.area || 'Center';
            return 'تصميم ' + (idx + 1) + ' — ' + window.getAreaLabel(areaKey);
          }).join('<br/>');
        }

        // Render one mockup preview per design layer using aspect-ratio 480/520 container
        var previewsHtml = '';
        if (co.layers && co.layers.length > 0) {
          (co.layers || []).forEach(function(layer, idx) {
            var areaKey = layer.area || 'Center';
            var svgStr = window.adminGenerateGarmentSVG(garmentType, areaKey, garmentHex);
            var svgDataUrl = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(svgStr)));

            var sX = layer.scaleX || 1;
            var sY = layer.scaleY || 1;
            var angle = Math.round(layer.angle || 0);
            var resolvedImgUrl = window.resolveAssetUrl(layer.img);

            previewsHtml += '<div class="co-mockup-preview" style="margin-bottom:1rem;">'
              + '<div class="co-mockup-canvas-wrapper">'
              + '<div class="co-garment-canvas-container" style="position:relative;width:100%;padding-top:calc(520/480*100%);overflow:hidden;">'
              + '<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">'
              + '<div style="position:relative;width:100%;height:100%;">'
              + '<img src="' + svgDataUrl + '" class="co-mockup-canvas-img" alt="Mockup ' + (idx+1) + '" style="width:100%;height:100%;object-fit:contain;display:block;" />'
              + '<div class="viewport-design-overlay" data-layer-left="' + (layer.left || 0) + '" data-layer-top="' + (layer.top || 0) + '" data-layer-scale-x="' + sX + '" data-layer-scale-y="' + sY + '" data-layer-angle="' + angle + '" style="position:absolute;visibility:hidden;transform-origin:center center;transform:rotate(' + angle + 'deg);">'
              + '<img class="viewport-design-img" src="' + resolvedImgUrl + '" alt="Design ' + (idx+1) + '" style="width:100%;height:100%;object-fit:contain;" />'
              + '</div>'
              + '</div>'
              + '</div>'
              + '</div>'
              + '</div>'
              + '</div>';
          });
        } else {
          // fallback single mockup (no layers)
          var mainSvgStr = window.adminGenerateGarmentSVG(garmentType, 'Center', garmentHex);
          var mainSvgDataUrl = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(mainSvgStr)));
          var mainImgSrc = resolvedMockupUrl || mainSvgDataUrl;
          previewsHtml = '<div class="co-mockup-preview"><div class="co-mockup-canvas-wrapper">'
            + '<img src="' + mainImgSrc + '" class="co-mockup-canvas-img" alt="Custom Mockup" />'
            + '</div></div>';
        }

        var leftPaneHtml = '<div class="co-canvas-column">'
          + '  <div style="display:flex;flex-direction:column;gap:0.9rem;margin-top:0;">'
          + previewsHtml
          + '  </div>'
          + '  <div style="display:flex;flex-direction:column;gap:0.9rem;margin-top:1rem;">'
          + '    <div style="display:flex;justify-content:space-between;align-items:center;">'
          + '      <strong style="font-size:0.95rem;color:#0f172a;">معاينة التصميم</strong>'
          + '      <span style="font-size:0.82rem;color:#475569;">' + ((co.layers || []).length) + ' تصميمات</span>'
          + '    </div>'
          + '    <div style="font-size:0.88rem;color:#475569;line-height:1.5;">'
          + '      ' + layerSummaryHtml + '\n'
          + '    </div>'
          + '  </div>'
          + '</div>';


        // ── Build Right Pane: One Card Per Design Layer ──
        var sideCardsHtml = '';
        (co.layers || []).forEach(function(layer, idx) {
          var areaKey = layer.area || 'Center';
          var areaLabel = window.getAreaLabel(areaKey);
          var cropClass = 'crop-full';
          var svgStr = window.adminGenerateGarmentSVG(garmentType, areaKey, garmentHex);
          var svgDataUrl = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(svgStr)));

          var resolvedImgUrl = window.resolveAssetUrl(layer.img);
          
          var sX = layer.scaleX || 1;
          var sY = layer.scaleY || 1;
          var angle = Math.round(layer.angle || 0);
          var labelText = 'تصميم ' + (idx + 1) + ' — ' + areaLabel;

          sideCardsHtml += '<div class="independent-side-card" data-area="' + areaKey + '" id="side-card-' + areaKey + '-' + idx + '">'
            + '  <div class="side-card-title">'
            + '    <span>📐 ' + labelText + '</span>'
            + '    <span class="side-card-badge side-card-badge--active">✓ مُخصص</span>'
            + '  </div>'
            + '  <div class="cropped-viewport">'
            + '    <div style="position:relative;width:100%;padding-top:calc(520/480*100%);overflow:hidden;">'
            + '      <div style="position:absolute;inset:0;">'
            + '        <img src="' + svgDataUrl + '" class="garment-svg-base" alt="Garment" style="width:100%;height:100%;object-fit:contain;display:block;" />'
            + '        <div class="viewport-design-overlay" data-layer-left="' + (layer.left || 0) + '" data-layer-top="' + (layer.top || 0) + '" data-layer-scale-x="' + sX + '" data-layer-scale-y="' + sY + '" data-layer-angle="' + angle + '" style="position:absolute;visibility:hidden;transform-origin:center center;transform:rotate(' + angle + 'deg);">'
            + '          <img class="viewport-design-img" src="' + resolvedImgUrl + '" alt="Design" style="width:100%;height:100%;object-fit:contain;" />'
            + '        </div>'
            + '      </div>'
            + '    </div>'
            + '  </div>'
            + '  <div class="coordinates-info">'
            + '    <div style="display:flex;justify-content:space-between;gap:0.5rem;flex-wrap:wrap;">'
            + '      <span>🎨 تصميم ' + (idx + 1) + '</span>'
            + '      <span class="co-spec-text-details">مقياس: ' + Math.round(sX * 100) + '% | زاوية: ' + angle + '° | جاري التحميل...</span>'
            + '    </div>'
            + '  </div>'
            + '  <div class="side-card-controls">'
            + '    <label class="btn-upload-side" for="upload-side-' + areaKey + '-' + idx + '">'
            + '      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>'
            + '      رفع صورة لهذه الجهة / Upload Image'
            + '    </label>'
            + '    <input type="file" id="upload-side-' + areaKey + '-' + idx + '" accept="image/*" style="display:none;" data-order-id="' + orderId + '" data-area="' + areaKey + '" data-layer-index="' + idx + '" onchange="window.handleSideUpload(this)" />'
            + '    <button type="button" class="btn-upload-side" onclick="window.downloadSideDesign(\'' + orderId + '\',\'' + areaKey + '\',' + idx + ')" style="color:#2563eb;border-color:#bfdbfe;">'
            + '      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>'
            + '      تحميل التصميم / Download Design'
            + '    </button>'
            + '  </div>'
            + '</div>';
        });

        // If no layers exist, show a placeholder
        if (!co.layers || co.layers.length === 0) {
          sideCardsHtml = '<div class="independent-side-card" style="text-align:center;padding:2rem;">'
            + '<p style="color:#71717a;font-size:0.95rem;">لا توجد تصاميم مرفقة / No designs attached</p>'
            + '</div>';
        }

        // ── Build Specs Panel ──
        var specsHtml = '<div class="co-specs-container">'
          + '  <h4 class="co-specs-title"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> مواصفات الطلب / Specifications</h4>'
          + '  <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">'
          + '    <tr style="border-bottom:1px solid #f1f5f9;"><td style="padding:0.6rem 0.5rem;font-weight:600;color:#64748b;width:40%;">رقم الطلب / Order ID</td><td style="padding:0.6rem 0.5rem;font-weight:700;color:#0f172a;">' + orderId + '</td></tr>'
          + '    <tr style="border-bottom:1px solid #f1f5f9;"><td style="padding:0.6rem 0.5rem;font-weight:600;color:#64748b;">اللون / Color</td><td style="padding:0.6rem 0.5rem;"><span style="display:inline-block;width:14px;height:14px;border-radius:50%;background:' + garmentHex + ';border:2px solid #e4e4e7;vertical-align:middle;margin-left:6px;"></span> ' + co.color + '</td></tr>'
          + '    <tr style="border-bottom:1px solid #f1f5f9;"><td style="padding:0.6rem 0.5rem;font-weight:600;color:#64748b;">المقاس / Size</td><td style="padding:0.6rem 0.5rem;font-weight:600;">' + (co.size || 'M') + '</td></tr>'
          + '    <tr style="border-bottom:1px solid #f1f5f9;"><td style="padding:0.6rem 0.5rem;font-weight:600;color:#64748b;">الخدمة / Service</td><td style="padding:0.6rem 0.5rem;font-weight:600;color:#2563eb;">' + (co.serviceType === 'Embroidery' ? '🧵 تطريز (Embroidery)' : '🖨️ طباعة (Print)') + '</td></tr>'
          + '    <tr style="border-bottom:1px solid #f1f5f9;"><td style="padding:0.6rem 0.5rem;font-weight:600;color:#64748b;">العميل / Client</td><td style="padding:0.6rem 0.5rem;font-weight:600;">' + (co.customer.name || '') + ' ' + (co.customer.surname || '') + '</td></tr>'
          + '    <tr style="border-bottom:1px solid #f1f5f9;"><td style="padding:0.6rem 0.5rem;font-weight:600;color:#64748b;">البريد / Email</td><td style="padding:0.6rem 0.5rem;"><a href="mailto:' + co.customer.email + '" style="color:#2563eb;text-decoration:underline;">' + co.customer.email + '</a></td></tr>'
          + '    <tr style="border-bottom:1px solid #f1f5f9;"><td style="padding:0.6rem 0.5rem;font-weight:600;color:#64748b;">الهاتف / Phone</td><td style="padding:0.6rem 0.5rem;"><a href="tel:' + co.customer.phone + '" style="color:#0284c7;font-weight:600;">' + co.customer.phone + '</a></td></tr>'
          + '    <tr style="border-bottom:1px solid #f1f5f9;"><td style="padding:0.6rem 0.5rem;font-weight:600;color:#64748b;">الولاية / Province</td><td style="padding:0.6rem 0.5rem;">' + (co.customer.province || '—') + '</td></tr>'
          + '    <tr><td style="padding:0.6rem 0.5rem;font-weight:600;color:#64748b;">ملاحظات / Notes</td><td style="padding:0.6rem 0.5rem;font-style:italic;color:#64748b;">' + (co.customer.notes || 'لا توجد ملاحظات') + '</td></tr>'
          + '  </table>'
          + '</div>';

        // ── Assemble Full Dashboard ──
        var dashboardHtml = '<div class="custom-order-details-dashboard">'
          + '  <div class="co-dashboard-grid">'
          + '    ' + leftPaneHtml
          + '    <div class="co-sides-column">' + sideCardsHtml + '</div>'
          + '  </div>'
          + specsHtml
          + '</div>';

        body.innerHTML = dashboardHtml;

        // Dynamically re-adjust and align design overlays based on actual image dimensions
        // The container uses padding-top: 520/480*100% to maintain exact 480x520 aspect ratio
        // so percentage values map exactly to the original Fabric.js canvas coordinates
        var designOverlayImages = body.querySelectorAll('.viewport-design-img');
        console.log('[🎨 Custom Order] Found ' + designOverlayImages.length + ' design images to render. API_BASE_URL=' + window.API_BASE_URL);
        
        designOverlayImages.forEach(function(img, imgIdx) {
          var overlay = img.closest('.viewport-design-overlay');
          if (!overlay) return;

          var sX = parseFloat(overlay.getAttribute('data-layer-scale-x')) || 1;
          var sY = parseFloat(overlay.getAttribute('data-layer-scale-y')) || 1;
          var centerX = parseFloat(overlay.getAttribute('data-layer-left')) || 0;
          var centerY = parseFloat(overlay.getAttribute('data-layer-top')) || 0;
          var angle = parseFloat(overlay.getAttribute('data-layer-angle')) || 0;

          console.log('[🎨 Image ' + (imgIdx + 1) + '] src=' + img.src + ', complete=' + img.complete);

          var updateOverlaySizing = function() {
            console.log('[🎨 Image ' + (imgIdx + 1) + ' LOADED] naturalSize=' + img.naturalWidth + 'x' + img.naturalHeight);
            
            var naturalW = img.naturalWidth || 120;
            var naturalH = img.naturalHeight || 120;

            var wPx = Math.max(20, naturalW * sX);
            var hPx = Math.max(20, naturalH * sY);

            // Constrain massive images (e.g. from simple Vue upload) to fit the garment
            var maxW = 380;
            var maxH = 420;
            if (wPx > maxW || hPx > maxH) {
              var ratio = Math.min(maxW / wPx, maxH / hPx);
              wPx = wPx * ratio;
              hPx = hPx * ratio;
            }

            var cX = centerX;
            var cY = centerY;
            if (cX === 0 && cY === 0) {
              cX = 240;
              cY = 260;
            }

            // Convert center coordinates to top-left (Fabric.js uses center origin)
            var leftPx = cX - (wPx / 2);
            var topPx = cY - (hPx / 2);

            // Apply percentage-based layout relative to 480x520 canvas
            // The parent div uses padding-top: calc(520/480*100%) preserving exact ratio
            // so % calculations map directly to the original canvas space
            overlay.style.left = (leftPx / 480 * 100).toFixed(4) + '%';
            overlay.style.top = (topPx / 520 * 100).toFixed(4) + '%';
            overlay.style.width = (wPx / 480 * 100).toFixed(4) + '%';
            overlay.style.height = (hPx / 520 * 100).toFixed(4) + '%';
            overlay.style.visibility = 'visible';
            console.log('[🎨 Image ' + (imgIdx + 1) + '] pos=(' + leftPx.toFixed(1) + ',' + topPx.toFixed(1) + ') size=(' + wPx.toFixed(1) + 'x' + hPx.toFixed(1) + ') VISIBLE');

            // Update coordinate details text in the side card
            var sideCard = img.closest('.independent-side-card');
            if (sideCard) {
              var specSpan = sideCard.querySelector('.co-spec-text-details');
              if (specSpan) {
                specSpan.innerHTML = 'مقياس: ' + Math.round(sX * 100) + '% | زاوية: ' + angle + '° | الحجم: ' + Math.round(wPx) + 'x' + Math.round(hPx) + 'px | X=' + Math.round(leftPx) + ', Y=' + Math.round(topPx);
              }
            }
          };

          img.onerror = function() {
            console.error('[❌ Image ' + (imgIdx + 1) + ' ERROR] Failed to load: ' + img.src);
            
            // Hide the actual image
            img.style.display = 'none';

            // Create and append placeholder if it doesn't exist
            var placeholder = overlay.querySelector('.co-design-placeholder-fallback');
            if (!placeholder) {
              placeholder = document.createElement('div');
              placeholder.className = 'co-design-placeholder-fallback';
              overlay.appendChild(placeholder);
            }
            placeholder.style.width = '100%';
            placeholder.style.height = '100%';
            placeholder.style.display = 'flex';
            placeholder.style.alignItems = 'center';
            placeholder.style.justifyContent = 'center';
            placeholder.style.color = '#ef4444';
            placeholder.style.fontSize = '0.7rem';
            placeholder.style.fontWeight = 'bold';
            placeholder.style.textAlign = 'center';
            placeholder.style.direction = 'rtl';
            placeholder.textContent = '⚠️ تصميم مفقود';

            // Style the overlay as a dashed border red box
            overlay.style.border = '2px dashed #ef4444';
            overlay.style.background = 'rgba(239, 68, 68, 0.15)';

            // Fallback sizing
            var naturalW = 120;
            var naturalH = 120;
            var wPx = Math.max(20, naturalW * sX);
            var hPx = Math.max(20, naturalH * sY);
            var leftPx = centerX - (wPx / 2);
            var topPx = centerY - (hPx / 2);

            overlay.style.left = (leftPx / 480 * 100).toFixed(4) + '%';
            overlay.style.top = (topPx / 520 * 100).toFixed(4) + '%';
            overlay.style.width = (wPx / 480 * 100).toFixed(4) + '%';
            overlay.style.height = (hPx / 520 * 100).toFixed(4) + '%';
            overlay.style.visibility = 'visible';

            // Update coordinate details text in the side card
            var sideCard = img.closest('.independent-side-card');
            if (sideCard) {
              var specSpan = sideCard.querySelector('.co-spec-text-details');
              if (specSpan) {
                specSpan.innerHTML = '<span style="color:#ef4444;font-weight:bold;">⚠️ الصورة مفقودة / Missing Design</span>';
              }
            }
          };

          img.onload = function() {
            console.log('[✅ Image ' + (imgIdx + 1) + ' onload triggered]');
            updateOverlaySizing();
          };

          if (img.complete) {
            console.log('[✅ Image ' + (imgIdx + 1) + ' already complete, calling updateOverlaySizing immediately]');
            updateOverlaySizing();
          } else {
            console.log('[⏳ Image ' + (imgIdx + 1) + ' waiting for onload...]');
          }
        });

        modal.style.display = 'flex';

        // Store reference for re-render
        window.__coCurrentOrderId = orderId;
      };

      // ── Toggle Preview Placement (Glowing Zones) ──
      window.__previewPlacementActive = false;
      window.togglePreviewPlacement = function() {
        window.__previewPlacementActive = !window.__previewPlacementActive;
        var zones = document.querySelectorAll('.glowing-print-zone');
        var btn = document.getElementById('btn-preview-placement');
        zones.forEach(function(zone) {
          if (window.__previewPlacementActive) {
            zone.classList.add('active-zone');
          } else {
            zone.classList.remove('active-zone');
          }
        });
        if (btn) {
          if (window.__previewPlacementActive) {
            btn.style.background = '#059669';
            btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg> إخفاء المعاينة / Hide Preview';
          } else {
            btn.style.background = '#10b981';
            btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg> معاينة موضع التصميم / Preview Placement';
          }
        }
      };

      // ── Download Design from a Side (robust: fetch as blob then download) ──
      window.downloadSideDesign = async function(orderId, areaKey, layerIndex) {
        try {
          var order = (cachedOrders || []).find(function(o) { return String(o.id) === String(orderId); });
          if (!order || !order.customOrder) return;
          var layers = order.customOrder.layers || [];

          var toDownload = [];
          if (typeof layerIndex === 'number') {
            var layer = layers[layerIndex];
            if (!layer || layer.area !== areaKey) { alert('لا يوجد تصميم لهذه الطبقة'); return; }
            toDownload.push({ layer: layer, idx: layerIndex });
          } else {
            var filtered = layers.filter(function(l) { return l.area === areaKey; });
            if (filtered.length === 0) { alert('لا يوجد تصميم لهذه الجهة'); return; }
            filtered.forEach(function(layer, i) { toDownload.push({ layer: layer, idx: i }); });
          }

          for (var i = 0; i < toDownload.length; i++) {
            var item = toDownload[i];
            var url = window.resolveAssetUrl(item.layer.img);
            try {
              // Try fetching the resource as a blob to force download
              var resp = await fetch(url, { mode: 'cors' });
              if (!resp.ok) throw new Error('Fetch failed');
              var blob = await resp.blob();
              var blobUrl = URL.createObjectURL(blob);
              var a = document.createElement('a');
              a.href = blobUrl;
              a.download = 'design-' + orderId + '-' + areaKey + '-' + item.idx + '.png';
              document.body.appendChild(a);
              a.click();
              document.body.removeChild(a);
              URL.revokeObjectURL(blobUrl);
            } catch (err) {
              // Fallback: open in new tab (may allow manual save)
              var a2 = document.createElement('a');
              a2.href = url;
              a2.target = '_blank';
              document.body.appendChild(a2);
              a2.click();
              document.body.removeChild(a2);
            }
          }
        } catch (e) {
          console.error('Download error', e);
          alert('خطأ أثناء تنزيل التصميم');
        }
      };

      // ── Handle File Upload for Independent Side ──
      window.handleSideUpload = function(input) {
        var file = input.files && input.files[0];
        if (!file) return;
        var orderId = input.getAttribute('data-order-id');
        var areaKey = input.getAttribute('data-area');
        if (!orderId || !areaKey) return;

        var reader = new FileReader();
        reader.onload = function(e) {
          var base64 = e.target.result;

          // Find the layer index for this area in the order
          var order = (cachedOrders || []).find(function(o) { return String(o.id) === String(orderId); });
          if (!order || !order.customOrder) return;
          var layerIndex = parseInt(input.getAttribute('data-layer-index'), 10);
          if (isNaN(layerIndex)) {
            layerIndex = -1;
            (order.customOrder.layers || []).forEach(function(l, idx) {
              if (l.area === areaKey && layerIndex === -1) layerIndex = idx;
            });
          }
          if (layerIndex === -1) return;

          // Send to server
          var updatePayload = { layers: {} };
          updatePayload.layers[layerIndex] = { img: base64 };

          fetch((window.API_BASE_URL || '') + '/api/orders/' + orderId + '/custom-order', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(updatePayload)
          })
          .then(function(res) { return res.json(); })
          .then(function(data) {
            if (data.success) {
              // Update the cached order
              if (data.order) {
                var idx = cachedOrders.findIndex(function(o) { return String(o.id) === String(orderId); });
                if (idx !== -1) cachedOrders[idx] = data.order;
              }
              // Re-render the modal
              window.viewCustomOrderDetails(orderId);
            } else {
              alert('فشل في تحديث التصميم: ' + (data.error || 'Unknown error'));
            }
          })
          .catch(function(err) {
            console.error('Upload error:', err);
            alert('خطأ في الاتصال بالخادم');
          });
        };
        reader.readAsDataURL(file);
      };

      // ── Close Modal ──
      window.closeCustomOrderModal = function() {
        window.__previewPlacementActive = false;
        document.getElementById('custom-order-modal').style.display = 'none';
      };

      // ── Delegated handler: ensure view custom button works even if inline onclick fails ──
      document.addEventListener('click', function(e) {
        var btn = e.target.closest && e.target.closest('.btn-view-custom');
        if (!btn) return;
        e.preventDefault();
        var orderId = btn.getAttribute('data-order-id');
        if (!orderId && btn.getAttribute('onclick')) {
          // try to fallback to parsing onclick argument
          try {
            var m = btn.getAttribute('onclick').match(/viewCustomOrderDetails\(['"`]?([^'"`)]+)['"`]?\)/);
            if (m && m[1]) orderId = m[1];
          } catch (err) { orderId = null; }
        }
        if (orderId && window.viewCustomOrderDetails) {
          window.viewCustomOrderDetails(orderId);
        } else {
          console.warn('viewCustomOrderDetails not available or orderId missing', orderId);
        }
      }, false);


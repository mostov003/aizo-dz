      function updateEditOfficesDropdown(selectedWilaya, selectedOfficeValue) {
        var officeSelect = document.getElementById('edit-cust-office');
        if (!officeSelect) return;
        
        if (!selectedWilaya) {
          officeSelect.innerHTML = '<option value="" disabled selected>يرجى اختيار الولاية أولاً...</option>';
          return;
        }
        
        var wilayaCode = parseInt(selectedWilaya);
        var filtered = ZR_OFFICES.filter(function(off) { return off.wilaya === wilayaCode; });

        if (filtered.length === 0) {
          officeSelect.innerHTML = '<option value="" disabled selected>لا توجد مكاتب توصيل متوفرة في هذه الولاية</option>';
        } else {
          var optionsHtml = '<option value="" disabled selected>اختر مكتب التوصيل...</option>';
          filtered.forEach(function(off) {
            var displayText = off.name + ' - (' + off.address + ')';
            optionsHtml += '<option value="' + displayText + '">' + displayText + '</option>';
          });
          officeSelect.innerHTML = optionsHtml;
          
          if (selectedOfficeValue) {
            var foundValue = '';
            for (var i = 0; i < officeSelect.options.length; i++) {
              if (officeSelect.options[i].value === selectedOfficeValue || 
                  officeSelect.options[i].value.includes(selectedOfficeValue) || 
                  selectedOfficeValue.includes(officeSelect.options[i].value)) {
                foundValue = officeSelect.options[i].value;
                break;
              }
            }
            if (foundValue) {
              officeSelect.value = foundValue;
            }
          }
        }
      }

      function updateDeliveryPricesDisplayOnButtons(selectedWilaya) {
        var form = document.getElementById('edit-customer-form');
        var buttons = form.querySelectorAll('.delivery-option');
        if (!selectedWilaya) return;
        var wilayaCode = parseInt(selectedWilaya);
        
        var homePrice = window.getShippingCost ? window.getShippingCost(wilayaCode, 'home') : 600;
        var officePrice = window.getShippingCost ? window.getShippingCost(wilayaCode, 'office') : 400;
        
        buttons.forEach(function(button) {
          var val = button.dataset.value;
          if (val === 'Home') {
            button.textContent = 'توصيل للمنزل (' + homePrice + ' DZD)';
          } else if (val === 'Office') {
            button.textContent = 'توصيل للمكتب (' + officePrice + ' DZD)';
          }
        });
      }

      /* ── Edit Customer Info Modal ── */
      window.editCustomerInfo = function(orderId) {
        var order = (cachedOrders || []).find(function(o) { return String(o.id) === String(orderId); });
        if (!order) return;
        
        var modal = document.getElementById('edit-customer-modal');
        var form = document.getElementById('edit-customer-form');
        var deliveryInput = document.getElementById('edit-cust-delivery');
        var officeGroup = document.querySelector('.office-group');
        var officeSelect = document.getElementById('edit-cust-office');
        var deliveryButtons = form.querySelectorAll('.delivery-option');
        
        // Populate form with current customer data
        document.getElementById('edit-cust-name').value = order.customer.name || '';
        document.getElementById('edit-cust-phone').value = order.customer.phone || '';
        document.getElementById('edit-cust-email').value = order.customer.email || '';
        
        // Set wilaya dropdown selection
        var wilayaSelect = document.getElementById('edit-cust-wilaya');
        wilayaSelect.value = order.customer.wilaya || '';
        
        document.getElementById('edit-cust-address').value = order.customer.address || '';

        var rawDelivery = order.customer.delivery || order.delivery || order.customer.deliveryType || 'Home';
        var deliveryType = /office|مكتب/i.test(rawDelivery) ? 'Office' : 'Home';
        deliveryInput.value = deliveryType;
        
        // Update offices dropdown for the selected wilaya
        updateEditOfficesDropdown(order.customer.wilaya, order.customer.officeName || '');
        
        if (deliveryType === 'Office') {
          officeGroup.style.display = 'flex';
          document.getElementById('edit-cust-address').removeAttribute('required');
        } else {
          officeGroup.style.display = 'none';
          document.getElementById('edit-cust-address').setAttribute('required', '');
        }

        deliveryButtons.forEach(function(button) {
          button.classList.toggle('active', button.dataset.value === deliveryType);
        });

        // Set prices
        document.getElementById('edit-order-shipping').value = order.shipping || 0;
        document.getElementById('edit-order-total').value = order.total || 0;
        
        // Save current subtotal on form dataset
        form.dataset.subtotal = order.subtotal || (order.total - order.shipping) || 0;
        
        // Update price display on buttons
        updateDeliveryPricesDisplayOnButtons(order.customer.wilaya);
        
        // Store order ID in form
        form.dataset.orderId = orderId;
        
        // Clear any previous messages
        document.getElementById('edit-customer-error').style.display = 'none';
        document.getElementById('edit-customer-success').style.display = 'none';
        
        modal.style.display = 'flex';
      };
      
      function setEditDeliveryType(type) {
        var deliveryInput = document.getElementById('edit-cust-delivery');
        var officeGroup = document.querySelector('.office-group');
        var form = document.getElementById('edit-customer-form');
        var buttons = form.querySelectorAll('.delivery-option');
        
        deliveryInput.value = type;
        buttons.forEach(function(button) {
          button.classList.toggle('active', button.dataset.value === type);
        });
        
        if (type === 'Office') {
          officeGroup.style.display = 'flex';
          document.getElementById('edit-cust-address').removeAttribute('required');
        } else {
          officeGroup.style.display = 'none';
          document.getElementById('edit-cust-address').setAttribute('required', '');
        }
        
        // Update shipping price based on new delivery type
        var selectedWilaya = document.getElementById('edit-cust-wilaya').value;
        if (selectedWilaya) {
          var wilayaCode = parseInt(selectedWilaya);
          var shipping = window.getShippingCost ? window.getShippingCost(wilayaCode, type.toLowerCase()) : 600;
          document.getElementById('edit-order-shipping').value = shipping;
          
          var subtotal = parseFloat(form.dataset.subtotal) || 0;
          document.getElementById('edit-order-total').value = subtotal + shipping;
        }
      }

      window.closeEditCustomerModal = function() {
        document.getElementById('edit-customer-modal').style.display = 'none';
      };

      var editCustomerForm = document.getElementById('edit-customer-form');
      if (editCustomerForm) {
        editCustomerForm.addEventListener('click', function(event) {
          var button = event.target.closest('.delivery-option');
          if (button && editCustomerForm.contains(button)) {
            event.preventDefault();
            setEditDeliveryType(button.dataset.value);
          }
        });
      }
      
      // Listen to change of Wilaya and inputs in edit modal
      document.addEventListener('DOMContentLoaded', function() {
        var wilayaSelect = document.getElementById('edit-cust-wilaya');
        if (wilayaSelect) {
          wilayaSelect.addEventListener('change', function() {
            var selectedWilaya = this.value;
            var deliveryType = document.getElementById('edit-cust-delivery').value || 'Home';
            
            updateEditOfficesDropdown(selectedWilaya, '');
            updateDeliveryPricesDisplayOnButtons(selectedWilaya);
            
            var wilayaCode = parseInt(selectedWilaya);
            var shipping = window.getShippingCost ? window.getShippingCost(wilayaCode, deliveryType.toLowerCase()) : 600;
            document.getElementById('edit-order-shipping').value = shipping;
            
            var form = document.getElementById('edit-customer-form');
            var subtotal = parseFloat(form.dataset.subtotal) || 0;
            document.getElementById('edit-order-total').value = subtotal + shipping;
          });
        }
        
        var shippingInput = document.getElementById('edit-order-shipping');
        var totalInput = document.getElementById('edit-order-total');
        var form = document.getElementById('edit-customer-form');
        
        if (shippingInput) {
          shippingInput.addEventListener('input', function() {
            var shipping = parseFloat(this.value) || 0;
            var subtotal = parseFloat(form.dataset.subtotal) || 0;
            totalInput.value = subtotal + shipping;
          });
        }
        
        if (totalInput) {
          totalInput.addEventListener('input', function() {
            var total = parseFloat(this.value) || 0;
            var shipping = parseFloat(shippingInput.value) || 0;
            form.dataset.subtotal = total - shipping;
          });
        }
      });

      /* ── Save Customer Info Handler ── */
      var editForm = document.getElementById('edit-customer-form');
      if (editForm && !editForm.dataset.listenerAttached) {
        editForm.dataset.listenerAttached = 'true';
        editForm.addEventListener('submit', async function(e) {
          e.preventDefault();
          
          var orderId = this.dataset.orderId;
          if (!orderId) return alert('خطأ: لم يتم العثور على رقم الطلب');
          
          var submitBtn = editForm.querySelector('button[type="submit"]');
          var originalBtnText = submitBtn ? submitBtn.textContent : 'حفظ';
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = '⏳ جاري الحفظ...';
          }
          
          var errorDiv = document.getElementById('edit-customer-error');
          var successDiv = document.getElementById('edit-customer-success');
          errorDiv.style.display = 'none';
          successDiv.style.display = 'none';
          
          var deliveryType = document.getElementById('edit-cust-delivery').value || 'Home';
          var officeName = (deliveryType === 'Office') ? document.getElementById('edit-cust-office').value.trim() : '';
          var addressValue = (deliveryType === 'Home') ? document.getElementById('edit-cust-address').value.trim() : '';
          var wilayaValue = document.getElementById('edit-cust-wilaya').value.trim();
          
          var deliveryString = '';
          if (deliveryType === 'Home') {
            deliveryString = 'التوصيل إلى المنزل (A DOMICILE) — ' + addressValue;
          } else {
            deliveryString = 'التوصيل إلى المكتب (STOP DESK) - ' + officeName;
          }
          
          var total = parseFloat(document.getElementById('edit-order-total').value) || 0;
          var shipping = parseFloat(document.getElementById('edit-order-shipping').value) || 0;
          var subtotal = total - shipping;

          var updateData = {
            name: document.getElementById('edit-cust-name').value.trim(),
            phone: document.getElementById('edit-cust-phone').value.trim(),
            email: document.getElementById('edit-cust-email').value.trim(),
            wilaya: wilayaValue,
            address: addressValue,
            deliveryType: deliveryType.toLowerCase(),
            officeName: officeName,
            delivery: deliveryString,
            total: total,
            shipping: shipping,
            subtotal: subtotal
          };
          
          // Validation
          if (!updateData.name || !updateData.phone || !updateData.wilaya || (deliveryType === 'Home' && !addressValue) || (deliveryType === 'Office' && !officeName)) {
            var validationMessage = '⚠️ الرجاء ملء جميع الحقول المطلوبة (الاسم، الهاتف، الولاية، العنوان)';
            if (deliveryType === 'Office' && !officeName) {
              validationMessage = '⚠️ الرجاء تحديد اسم المكتب عند اختيار توصيل للمكتب';
            }
            if (errorDiv) {
              errorDiv.textContent = validationMessage;
              errorDiv.style.display = 'block';
            }
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = originalBtnText;
            }
            return;
          }
          
          try {
            var response = await apiFetch('/api/orders/' + orderId + '/customer', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(updateData)
            });
            
            if (response && response.success) {
              // Update cached order
              var orderIdx = (cachedOrders || []).findIndex(function(o) { return String(o.id) === String(orderId); });
              if (orderIdx > -1) {
                cachedOrders[orderIdx].customer = cachedOrders[orderIdx].customer || {};
                Object.assign(cachedOrders[orderIdx].customer, {
                  name: updateData.name,
                  phone: updateData.phone,
                  email: updateData.email,
                  wilaya: updateData.wilaya,
                  address: updateData.address,
                  deliveryType: updateData.deliveryType,
                  officeName: updateData.officeName,
                  delivery: updateData.delivery
                });
                cachedOrders[orderIdx].total = updateData.total;
                cachedOrders[orderIdx].shipping = updateData.shipping;
                cachedOrders[orderIdx].subtotal = updateData.subtotal;

                // Update localStorage to keep it in sync
                var localOrders = [];
                try {
                  localOrders = JSON.parse(localStorage.getItem('local_orders') || '[]');
                } catch(errLocal) {
                  console.error('Error reading local orders:', errLocal);
                }
                var lIdx = localOrders.findIndex(function(o) { return String(o.id) === String(orderId); });
                if (lIdx > -1) {
                  localOrders[lIdx].customer = localOrders[lIdx].customer || {};
                  Object.assign(localOrders[lIdx].customer, {
                    name: updateData.name,
                    phone: updateData.phone,
                    email: updateData.email,
                    wilaya: updateData.wilaya,
                    address: updateData.address,
                    deliveryType: updateData.deliveryType,
                    officeName: updateData.officeName,
                    delivery: updateData.delivery
                  });
                  localOrders[lIdx].total = updateData.total;
                  localOrders[lIdx].shipping = updateData.shipping;
                  localOrders[lIdx].subtotal = updateData.subtotal;
                  localStorage.setItem('local_orders', JSON.stringify(localOrders));
                }
              }
              
              // Show success message
              if (successDiv) {
                successDiv.textContent = '✅ تم تحديث معلومات العميل بنجاح!';
                successDiv.style.display = 'block';
              }
              
              // Refresh orders table
              var activeFilter = document.querySelector('.filter-btn.active') ? document.querySelector('.filter-btn.active').getAttribute('data-filter') : 'all';
              renderOrdersTable(activeFilter || 'all', false);
              
              // Close modal after 1.5 seconds
              setTimeout(function() {
                window.closeEditCustomerModal();
              }, 1500);
            } else {
              throw new Error(response.error || 'فشل التحديث');
            }
          } catch(err) {
            console.error('Error updating customer:', err);
            if (errorDiv) {
              errorDiv.textContent = '❌ خطأ: ' + (err.message || 'فشل تحديث البيانات');
              errorDiv.style.display = 'block';
            }
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = originalBtnText;
            }
          }
        });
      }

      /* ── Orders table ── */
      async function renderOrdersTable(filter, forceRefresh) {
        var orders = [];
        try {
          orders = await getOrders(forceRefresh);
        } catch(err) {
          console.error('Error loading orders:', err);
        }

        var tbody = document.getElementById('admin-orders-list');
        if (!tbody) return;

        // Filter out custom orders from the regular orders list
        var regularOrders = orders.filter(function(o) { return !o.customOrder; });

        var list;
        if (filter === 'all') {
          list = regularOrders;
        } else if (filter === 'Confirmed') {
          list = regularOrders.filter(function(o) {
            return o.status === 'Confirmed' || o.status === 'ReadyToShip' || o.status === 'InDelivery' || o.status === 'confirmé' || o.status === 'livré';
          });
        } else if (filter === 'Delivered') {
          list = regularOrders.filter(function(o) { return o.status === 'Delivered' || o.status === 'livré'; });
        } else if (filter === 'Returned') {
          list = regularOrders.filter(function(o) { return o.status === 'Returned' || o.status === 'retourné'; });
        } else if (filter === 'Cancelled') {
          list = regularOrders.filter(function(o) { return o.status === 'Cancelled' || o.status === 'annulé'; });
        } else {
          list = regularOrders.filter(function(o) { return o.status === filter; });
        }
        
        list.sort(function(a,b){ return new Date(b.date || b.createdAt || b.created_at || b.orderDate || 0) - new Date(a.date || a.createdAt || a.created_at || a.orderDate || 0); });

        if (list.length === 0) {
          tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:3rem;">' + ((window.t && window.t('admin_orders_empty')) || 'لا توجد طلبات مطابقة.') + '</td></tr>';
          return;
        }

        function explodeCustomOrderRows(order) {
          if (!order.customOrder || !Array.isArray(order.customOrder.layers) || order.customOrder.layers.length <= 1) {
            return [order];
          }

          return order.customOrder.layers.map(function(layer, idx) {
            return Object.assign({}, order, {
              rowCustomLayer: layer,
              rowLayerIndex: idx,
              rowId: order.id + '-' + (idx + 1)
            });
          });
        }

        var normalizedList = list.flatMap(explodeCustomOrderRows);

        tbody.innerHTML = normalizedList.map(function(order) {
          var statusText, statusClass;
          var statusMap = {
            'Confirmed': window.t('status_confirmed') || 'مؤكد',
            'ReadyToShip': window.t('status_ready') || 'جاهز للشحن',
            'InDelivery': window.t('status_delivery') || 'قيد التوصيل',
            'Delivered': window.t('status_delivered') || 'تم التسليم',
            'Returned': window.t('status_returned') || 'مُرجع',
            'Cancelled': window.t('status_cancelled') || 'ملغى',
            'confirmé': 'مؤكد',
            'livré': 'تم التسليم',
            'retourné': 'مُرجع',
            'annulé': 'ملغى'
          };
          statusText = statusMap[order.status] || order.status;
          
          var classMap = {
            'Confirmed': 'status-confirmed', 'ReadyToShip': 'status-ready',
            'InDelivery': 'status-delivery', 'Delivered': 'status-delivered', 'Returned': 'status-returned',
            'Cancelled': 'status-cancelled',
            'confirmé': 'status-confirmed', 'livré': 'status-delivered',
            'retourné': 'status-returned', 'annulé': 'status-cancelled'
          };
          statusClass = classMap[order.status] || 'status-confirmed';

          var orderDate = order.date || order.createdAt || order.created_at || order.orderDate;
          var currentLang = localStorage.getItem('aizo_lang') || 'fr';
          var dtLocale = currentLang === 'ar' ? 'ar-DZ' : currentLang === 'fr' ? 'fr-FR' : 'en-US';
          var dt = orderDate ? new Date(orderDate).toLocaleDateString(dtLocale, { month:'numeric', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '—';
          
          var rawDelivery = order.customer.delivery || order.delivery || order.customer.deliveryType || 'Home';
          var deliveryLabel = rawDelivery;
          if (rawDelivery.toLowerCase().includes('office') || rawDelivery.includes('مكتب')) {
            deliveryLabel = window.t('delivery_office') || 'توصيل للمكتب';
          } else {
            deliveryLabel = window.t('delivery_home') || 'توصيل للمنزل';
          }

          var itemsHtml = order.items.map(function(item) {
            var col = item.color ? ' <span class="txt-color">(' + item.color + ')</span>' : '';
            var sz  = item.size  ? ' <span class="txt-size">مقاس: ' + item.size + '</span>' : '';
            return '<div class="order-item-desc">• ' + item.name + col + sz + ' <span class="txt-qty">x' + item.quantity + '</span></div>';
          }).join('');

           // If custom order, show customization preview indicator with thumbnails & locations
           var customIndicator = '';
           if (order.rowCustomLayer) {
             var areaLabel = window.getAreaLabel(order.rowCustomLayer.area);
             var resolvedImgUrl = window.resolveAssetUrl(order.rowCustomLayer.img);
             var positionText = 'X=' + Math.round(order.rowCustomLayer.left || 0) + ', Y=' + Math.round(order.rowCustomLayer.top || 0);
             var angleText = 'زاوية: ' + Math.round(order.rowCustomLayer.angle || 0) + '°';
             customIndicator = '<div class="custom-order-layer-summary-card">'
               + '  <img src="' + resolvedImgUrl + '" alt="' + areaLabel + '" class="custom-order-layer-thumb" onerror="window.handleDesignThumbError(this)" />'
               + '  <div class="custom-order-layer-meta">'
               + '    <strong>تصميم ' + (order.rowLayerIndex + 1) + ' / ' + (order.customOrder.layers || []).length + '</strong>'
               + '    <span>' + areaLabel + '</span>'
               + '    <span>' + positionText + ' | ' + angleText + '</span>'
               + '  </div>'
               + '</div>';
           } else if (order.customOrder) {
             var co = order.customOrder;
             var layerCount = (co.layers || []).length;
             
             var layersListHtml = (co.layers || []).map(function(layer, idx) {
               var areaLabel = window.getAreaLabel(layer.area);
               var resolvedImgUrl = window.resolveAssetUrl(layer.img);
               var positionText = 'X=' + Math.round(layer.left || 0) + ', Y=' + Math.round(layer.top || 0);
               var angleText = 'زاوية: ' + Math.round(layer.angle || 0) + '°';
               return '<div class="custom-order-layer-chip" title="' + areaLabel + ' — ' + positionText + ' | ' + angleText + '">'
                 + '  <img src="' + resolvedImgUrl + '" alt="' + areaLabel + '" onerror="window.handleDesignThumbError(this)" />'
                 + '  <div class="custom-order-layer-meta">'
                 + '    <strong>' + areaLabel + '</strong>'
                 + '    <span>' + positionText + ' | ' + angleText + '</span>'
                 + '  </div>'
                 + '</div>';
             }).join('');

            customIndicator = '<div class="custom-order-layers-summary">'
              + '  <div class="custom-order-layers-header">'
              + '    <span class="src-badge src-custom" onclick="window.viewCustomOrderDetails(\'' + order.id + '\')">🎨 تصميم مخصص / Custom</span>'
              + '    <span class="custom-order-layer-count">' + layerCount + ' تصميمات</span>'
              + '  </div>'
              + '  <div class="custom-order-layers-row">' + layersListHtml + '</div>'
              + '</div>';
          }

          // ZR Tracking info
          var trackingHtml = '';
          if (order.trackingNumber) {
            var zrStateLabel = '';
            if (order.zrStatus && order.zrStatus.state) {
              var stateMap = {
                'OrderReceived': 'تم استلام الطلب', 'CourierAssigned': 'تم تعيين ساعي', 'PickupInitiated': 'بدء الاستلام',
                'InTransit': 'في الطريق', 'CustomerCalled': 'تم الاتصال بالعميل', 'Delivered': 'تم التسليم',
                'Returned': 'مُرجع', 'ReturnCreated': 'طلب إرجاع', 'ReturnReceived': 'استلام الإرجاع',
                'Settled': 'مسوّى', 'Cancelled': 'ملغى'
              };
              var situationLabel = (order.zrStatus.situation) ? ' - ' + order.zrStatus.situation : '';
              zrStateLabel = '<span class="zr-status-chip">' + (stateMap[order.zrStatus.state] || order.zrStatus.state) + situationLabel + '</span>';
            }
            trackingHtml = '<div class="tracking-row">'
              + '<span class="tracking-badge">🚀 ' + order.trackingNumber + '</span>'
              + zrStateLabel
              + '<button class="btn-action btn-sync" onclick="window.syncOrderStatus(\'' + order.id + '\')">🔄 تحديث</button>'
              + '</div>';
          }

          // Actions Dropdown HTML - Workflow System
          var dropdownHtml = '<div class="admin-dropdown">'
            + '  <button class="btn-dropdown-toggle" onclick="event.stopPropagation(); window.toggleActionsDropdown(event, this, \'' + (order.rowId || order.id) + '\')">الإجراءات / Actions <span class="arrow">▼</span></button>'
            + '  <div class="admin-dropdown-menu" id="dropdown-menu-' + (order.rowId || order.id) + '">';

          // WORKFLOW STEPS
          // Step 1: Initial (Pending) - Accept or Reject
          if (!order.status || order.status === 'Pending') {
            dropdownHtml += '    <div class="dropdown-submenu-header">خطوة 1: القبول / Step 1: Accept</div>'
              + '    <button class="dropdown-item" onclick="window.changeOrderStatus(\'' + order.id + '\', \'confirmé\')">✓ قبول الطلب / Accept</button>'
              + '    <button class="dropdown-item" onclick="window.changeOrderStatus(\'' + order.id + '\', \'annulé\')">✗ رفض الطلب / Reject</button>';
          }
          // Step 2: en attente - Confirm or Cancel
          else if (order.status === 'en attente') {
            dropdownHtml += '    <div class="dropdown-submenu-header">خطوة 2: التأكيد / Step 2: Confirm</div>'
              + '    <button class="dropdown-item" onclick="window.changeOrderStatus(\'' + order.id + '\', \'confirmé\')">✓ تأكيد الطلب / Confirm</button>'
              + '    <button class="dropdown-item" onclick="window.changeOrderStatus(\'' + order.id + '\', \'annulé\')">✗ إلغاء الطلب / Cancel</button>';
          }
          // Step 3: confirmé / Confirmed / ReadyToShip / InDelivery - Shipped or Not Shipped
          else if (order.status === 'confirmé' || order.status === 'Confirmed' || order.status === 'ReadyToShip' || order.status === 'InDelivery') {
            dropdownHtml += '    <div class="dropdown-submenu-header">خطوة 3: الشحن / Step 3: Shipping</div>'
              + '    <button class="dropdown-item btn-zr-ship" onclick="window.shipOrderViaZR(\'' + order.id + '\')" title="إرسال لشحن عبر ZR Express" style="color: #2563eb; font-weight: 500;"><span style="font-size: 1rem;">🚚</span> شحن ZR / Ship ZR</button>'
              + '    <button class="dropdown-item" onclick="window.changeOrderStatus(\'' + order.id + '\', \'livré\')">✅ تم الشحن / Shipped</button>'
              + '    <button class="dropdown-item" onclick="window.changeOrderStatus(\'' + order.id + '\', \'retourné\')">📦 لم يتم الشحن / Not Shipped</button>';
          }
          // Final states - no workflow
          else if (order.status === 'livré' || order.status === 'retourné' || order.status === 'annulé' || order.status === 'Delivered' || order.status === 'Returned' || order.status === 'Cancelled') {
            dropdownHtml += '    <div class="dropdown-submenu-header">حالة نهائية / Final Status</div>'
              + '    <span class="dropdown-item-text" style="display: block; padding: 0.5rem 1rem; color: #999; cursor: default; font-size: 0.8rem;">✓ ' + statusText + '</span>';
          }

          // Additional options for all statuses
          dropdownHtml += '    <div class="dropdown-divider"></div>';
          
          if (order.customOrder && order.status !== 'annulé') {
            dropdownHtml += '    <button class="dropdown-item btn-view-custom" data-order-id="' + order.id + '" onclick="window.viewCustomOrderDetails(\'' + order.id + '\')">🎨 عرض التصميم / Mockup</button>'
              + '    <button class="dropdown-item btn-view-advanced" onclick="window.openLayerPreviewModal(\'' + order.id + '\')" style="color:#2563eb;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline-block;margin-left:0.4rem;"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> معاينة متقدمة / Advanced Preview</button>'
              + '    <div class="dropdown-divider"></div>';
          }

          if (order.trackingNumber && order.status !== 'annulé') {
            dropdownHtml += '    <button class="dropdown-item btn-tracking" onclick="window.syncOrderStatus(\'' + order.id + '\')" title="تحديث حالة الشحن من ZR"><span style="font-size: 0.9rem;">🔄</span> تحديث ZR / Sync ZR</button>';
          }

          if (order.status !== 'annulé') {
            dropdownHtml += '    <button class="dropdown-item" onclick="window.editCustomerInfo(\'' + order.id + '\')">✏️ تعديل البيانات / Edit Info</button>';
          }
          
          dropdownHtml += '  </div>'
            + '</div>';
          
          var _tRow = window.t || function(k){return k;};
          return '<tr>'
            + '<td data-label="' + _tRow('admin_col_order_id') + '"><strong>#' + (order.rowId || order.id) + '</strong></td>'
            + '<td data-label="' + _tRow('admin_col_date') + '"><span class="txt-date">' + dt + '</span></td>'
            + '<td data-label="' + _tRow('admin_col_customer') + '"><strong>' + order.customer.name + '</strong></td>'
            + '<td data-label="' + _tRow('admin_col_phone') + '"><a href="tel:' + order.customer.phone + '" class="tel-link">' + order.customer.phone + '</a></td>'
            + '<td data-label="' + _tRow('admin_col_wilaya') + '">' + order.customer.wilaya + '</td>'
            + '<td data-label="' + _tRow('admin_col_delivery') + '">' + deliveryLabel + '</td>'
            + '<td data-label="' + _tRow('admin_col_items') + '"><div style="display: flex; flex-direction: column; width: 100%; align-items: flex-end; gap: 0.25rem;"><div class="ordered-items-box" style="width: 100%; text-align: right;">' + itemsHtml + '</div>' + customIndicator + trackingHtml + '</div></td>'
            + '<td data-label="' + _tRow('admin_col_total') + '"><strong>' + order.total.toLocaleString() + ' DZD</strong></td>'
            + '<td data-label="' + _tRow('admin_col_status') + '"><span class="status-badge ' + statusClass + '">' + statusText + '</span></td>'
            + '<td>' + dropdownHtml + '</td>'
            + '</tr>';
        }).join('');
      }

      /* ── Custom Orders table (طلبات خاصة) ── */
      async function renderCustomOrdersTable(filter, forceRefresh) {
        var orders = [];
        try {
          orders = await getOrders(forceRefresh);
        } catch(err) {
          console.error('Error loading custom orders:', err);
        }

        var tbody = document.getElementById('admin-custom-orders-list');
        if (!tbody) return;

        // Only custom orders
        var customOrders = orders.filter(function(o) { return !!o.customOrder; });

        // Update badge and stats
        var customBadge = document.getElementById('custom-orders-badge');
        if (customBadge) {
          customBadge.textContent = customOrders.length;
          customBadge.style.display = customOrders.length > 0 ? 'flex' : 'none';
        }
        var customCountEl = document.getElementById('custom-orders-count');
        if (customCountEl) customCountEl.textContent = customOrders.length;

        var list;
        if (filter === 'all') {
          list = customOrders;
        } else if (filter === 'Confirmed') {
          list = customOrders.filter(function(o) {
            return o.status === 'Confirmed' || o.status === 'ReadyToShip' || o.status === 'InDelivery' || o.status === 'confirmé' || o.status === 'livré';
          });
        } else if (filter === 'Delivered') {
          list = customOrders.filter(function(o) { return o.status === 'Delivered' || o.status === 'livré'; });
        } else if (filter === 'Returned') {
          list = customOrders.filter(function(o) { return o.status === 'Returned' || o.status === 'retourné'; });
        } else if (filter === 'Cancelled') {
          list = customOrders.filter(function(o) { return o.status === 'Cancelled' || o.status === 'annulé'; });
        } else {
          list = customOrders.filter(function(o) { return o.status === filter; });
        }

        list.sort(function(a,b){ return new Date(b.date || b.createdAt || b.created_at || b.orderDate || 0) - new Date(a.date || a.createdAt || a.created_at || a.orderDate || 0); });

        if (list.length === 0) {
          tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:3rem;">' + ((window.t && window.t('admin_custom_orders_empty')) || 'لا توجد طلبات خاصة مطابقة.') + '</td></tr>';
          return;
        }

        function explodeCustomOrderRows(order) {
          if (!order.customOrder || !Array.isArray(order.customOrder.layers) || order.customOrder.layers.length <= 1) {
            return [order];
          }
          return order.customOrder.layers.map(function(layer, idx) {
            return Object.assign({}, order, {
              rowCustomLayer: layer,
              rowLayerIndex: idx,
              rowId: order.id + '-' + (idx + 1)
            });
          });
        }

        var normalizedList = list.flatMap(explodeCustomOrderRows);

        tbody.innerHTML = normalizedList.map(function(order) {
          var statusText, statusClass;
          var statusMap = {
            'Confirmed': window.t('status_confirmed') || 'مؤكد',
            'ReadyToShip': window.t('status_ready') || 'جاهز للشحن',
            'InDelivery': window.t('status_delivery') || 'قيد التوصيل',
            'Delivered': window.t('status_delivered') || 'تم التسليم',
            'Returned': window.t('status_returned') || 'مُرجع',
            'Cancelled': window.t('status_cancelled') || 'ملغى',
            'confirmé': 'مؤكد',
            'livré': 'تم التسليم',
            'retourné': 'مُرجع',
            'annulé': 'ملغى'
          };
          statusText = statusMap[order.status] || order.status;

          var classMap = {
            'Confirmed': 'status-confirmed', 'ReadyToShip': 'status-ready',
            'InDelivery': 'status-delivery', 'Delivered': 'status-delivered', 'Returned': 'status-returned',
            'Cancelled': 'status-cancelled',
            'confirmé': 'status-confirmed', 'livré': 'status-delivered',
            'retourné': 'status-returned', 'annulé': 'status-cancelled'
          };
          statusClass = classMap[order.status] || 'status-confirmed';

          var orderDate = order.date || order.createdAt || order.created_at || order.orderDate;
          var currentLang = localStorage.getItem('aizo_lang') || 'fr';
          var dtLocale = currentLang === 'ar' ? 'ar-DZ' : currentLang === 'fr' ? 'fr-FR' : 'en-US';
          var dt = orderDate ? new Date(orderDate).toLocaleDateString(dtLocale, { month:'numeric', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '—';

          var rawDelivery = order.customer.delivery || order.delivery || order.customer.deliveryType || 'Home';
          var deliveryLabel = rawDelivery;
          if (rawDelivery.toLowerCase().includes('office') || rawDelivery.includes('مكتب')) {
            deliveryLabel = window.t('delivery_office') || 'توصيل للمكتب';
          } else {
            deliveryLabel = window.t('delivery_home') || 'توصيل للمنزل';
          }

          var itemsHtml = order.items.map(function(item) {
            var col = item.color ? ' <span class="txt-color">(' + item.color + ')</span>' : '';
            var sz  = item.size  ? ' <span class="txt-size">مقاس: ' + item.size + '</span>' : '';
            return '<div class="order-item-desc">• ' + item.name + col + sz + ' <span class="txt-qty">x' + item.quantity + '</span></div>';
          }).join('');

          // Custom order indicator (small thumbnail + button)
          var customIndicator = '';
          if (order.rowCustomLayer) {
            var areaLabel = window.getAreaLabel(order.rowCustomLayer.area);
            var resolvedImgUrl = window.resolveAssetUrl(order.rowCustomLayer.img);
            customIndicator = '<div class="custom-order-layer-summary-card" style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem; padding: 0.35rem 0.5rem; border-radius: 6px; background: #f8fafc; border: 1px solid rgba(37, 99, 235, 0.12); max-width: 280px; width: 100%;">'
              + '  <img src="' + resolvedImgUrl + '" alt="' + areaLabel + '" class="custom-order-layer-thumb" onerror="window.handleDesignThumbError(this)" style="width: 32px !important; height: 32px !important; min-width: 32px !important; min-height: 32px !important; object-fit: contain !important; border-radius: 4px; border: 1px solid rgba(148, 163, 184, 0.3); background: #ffffff; flex-shrink: 0;" />'
              + '  <div class="custom-order-layer-meta" style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; flex-grow: 1; text-align: right;">'
              + '    <strong style="font-size: 0.78rem; color: #0f172a; line-height: 1.2; font-weight: 600;">تصميم ' + (order.rowLayerIndex + 1) + ' / ' + (order.customOrder.layers || []).length + '</strong>'
              + '    <span style="font-size: 0.72rem; color: #64748b; line-height: 1.3;">' + areaLabel + '</span>'
              + '  </div>'
              + '  <button class="btn-action btn-confirm" onclick="window.viewCustomOrderDetails(\'' + order.id + '\')" style="margin-right:auto; font-size:0.7rem; padding:0.25rem 0.5rem; flex-shrink: 0;">🔍 عرض</button>'
              + '</div>';
          } else if (order.customOrder) {
            var co = order.customOrder;
            var layerCount = (co.layers || []).length;

            var layersListHtml = (co.layers || []).map(function(layer, idx) {
              var areaLabel = window.getAreaLabel(layer.area);
              var resolvedImgUrl = window.resolveAssetUrl(layer.img);
              return '<div class="custom-order-layer-chip" title="' + areaLabel + '" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.25rem 0.5rem; border-radius: 6px; background: #f8fafc; border: 1px solid rgba(37, 99, 235, 0.12); margin-right: 0.25rem;">'
                + '  <img src="' + resolvedImgUrl + '" alt="' + areaLabel + '" onerror="window.handleDesignThumbError(this)" style="width: 28px !important; height: 28px !important; min-width: 28px !important; min-height: 28px !important; object-fit: contain !important; border-radius: 4px; border: 1px solid rgba(148, 163, 184, 0.3); background: #ffffff; flex-shrink: 0;" />'
                + '  <div class="custom-order-layer-meta" style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; text-align: right;">'
                + '    <strong style="font-size: 0.7rem; color: #0f172a;">' + areaLabel + '</strong>'
                + '  </div>'
                + '</div>';
            }).join('');

            customIndicator = '<div class="custom-order-layers-summary" style="display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.5rem;">'
              + '  <div class="custom-order-layers-header" style="display: flex; align-items: center; gap: 0.5rem; justify-content: space-between;">'
              + '    <span class="src-badge src-custom" onclick="window.viewCustomOrderDetails(\'' + order.id + '\')" style="cursor: pointer;">🎨 تصميم مخصص / Custom</span>'
              + '    <span class="custom-order-layer-count" style="font-size: 0.7rem; color: #64748b;">' + layerCount + ' تصميمات</span>'
              + '  </div>'
              + '  <div class="custom-order-layers-row" style="display: flex; flex-wrap: wrap; gap: 0.25rem;">' + layersListHtml + '</div>'
              + '</div>';
          }

          // Actions Dropdown HTML - Workflow System
          var dropdownHtml = '<div class="admin-dropdown">'
            + '  <button class="btn-dropdown-toggle" onclick="event.stopPropagation(); window.toggleActionsDropdown(event, this, \'' + (order.rowId || order.id) + '\')">الإجراءات / Actions <span class="arrow">▼</span></button>'
            + '  <div class="admin-dropdown-menu" id="dropdown-menu-' + (order.rowId || order.id) + '">';

          // WORKFLOW STEPS
          // Step 1: Initial (Pending) - Accept or Reject
          if (!order.status || order.status === 'Pending') {
            dropdownHtml += '    <div class="dropdown-submenu-header">خطوة 1: القبول / Step 1: Accept</div>'
              + '    <button class="dropdown-item" onclick="window.changeOrderStatus(\'' + order.id + '\', \'confirmé\')">✓ قبول الطلب / Accept</button>'
              + '    <button class="dropdown-item" onclick="window.changeOrderStatus(\'' + order.id + '\', \'annulé\')">✗ رفض الطلب / Reject</button>';
          }
          // Step 2: en attente - Confirm or Cancel
          else if (order.status === 'en attente') {
            dropdownHtml += '    <div class="dropdown-submenu-header">خطوة 2: التأكيد / Step 2: Confirm</div>'
              + '    <button class="dropdown-item" onclick="window.changeOrderStatus(\'' + order.id + '\', \'confirmé\')">✓ تأكيد الطلب / Confirm</button>'
              + '    <button class="dropdown-item" onclick="window.changeOrderStatus(\'' + order.id + '\', \'annulé\')">✗ إلغاء الطلب / Cancel</button>';
          }
          // Step 3: confirmé / Confirmed / ReadyToShip / InDelivery - Shipped or Not Shipped
          else if (order.status === 'confirmé' || order.status === 'Confirmed' || order.status === 'ReadyToShip' || order.status === 'InDelivery') {
            dropdownHtml += '    <div class="dropdown-submenu-header">خطوة 3: الشحن / Step 3: Shipping</div>'
              + '    <button class="dropdown-item btn-zr-ship" onclick="window.shipOrderViaZR(\'' + order.id + '\')" title="إرسال لشحن عبر ZR Express" style="color: #2563eb; font-weight: 500;"><span style="font-size: 1rem;">🚚</span> شحن ZR / Ship ZR</button>'
              + '    <button class="dropdown-item" onclick="window.changeOrderStatus(\'' + order.id + '\', \'livré\')">✅ تم الشحن / Shipped</button>'
              + '    <button class="dropdown-item" onclick="window.changeOrderStatus(\'' + order.id + '\', \'retourné\')">📦 لم يتم الشحن / Not Shipped</button>';
          }
          // Final states - no workflow
          else if (order.status === 'livré' || order.status === 'retourné' || order.status === 'annulé' || order.status === 'Delivered' || order.status === 'Returned' || order.status === 'Cancelled') {
            dropdownHtml += '    <div class="dropdown-submenu-header">حالة نهائية / Final Status</div>'
              + '    <span class="dropdown-item-text" style="display: block; padding: 0.5rem 1rem; color: #999; cursor: default; font-size: 0.8rem;">✓ ' + statusText + '</span>';
          }

          // Additional options for all statuses
          dropdownHtml += '    <div class="dropdown-divider"></div>';
          
          if (order.customOrder && order.status !== 'annulé') {
            dropdownHtml += '    <button class="dropdown-item btn-view-custom" data-order-id="' + order.id + '" onclick="window.viewCustomOrderDetails(\'' + order.id + '\')">🎨 عرض التصميم / Mockup</button>'
              + '    <button class="dropdown-item btn-view-advanced" onclick="window.openLayerPreviewModal(\'' + order.id + '\')" style="color:#2563eb;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline-block;margin-left:0.4rem;"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> معاينة متقدمة / Advanced Preview</button>'
              + '    <div class="dropdown-divider"></div>';
          }

          if (order.trackingNumber && order.status !== 'annulé') {
            dropdownHtml += '    <button class="dropdown-item btn-tracking" onclick="window.syncOrderStatus(\'' + order.id + '\')" title="تحديث حالة الشحن من ZR"><span style="font-size: 0.9rem;">🔄</span> تحديث ZR / Sync ZR</button>';
          }

          if (order.status !== 'annulé') {
            dropdownHtml += '    <button class="dropdown-item" onclick="window.editCustomerInfo(\'' + order.id + '\')">✏️ تعديل البيانات / Edit Info</button>';
          }
          
          dropdownHtml += '  </div></div>';

          return '<tr>'
            + '<td><strong>#' + (order.rowId || order.id) + '</strong></td>'
            + '<td><span class="txt-date">' + dt + '</span></td>'
            + '<td><strong>' + order.customer.name + '</strong></td>'
            + '<td><a href="tel:' + order.customer.phone + '" class="tel-link">' + order.customer.phone + '</a></td>'
            + '<td>' + order.customer.wilaya + '</td>'
            + '<td>' + deliveryLabel + '</td>'
            + '<td><div style="display: flex; flex-direction: column; width: 100%; align-items: flex-end; gap: 0.25rem;"><div class="ordered-items-box" style="width: 100%; text-align: right;">' + itemsHtml + '</div>' + customIndicator + '</div></td>'
            + '<td><strong>' + order.total.toLocaleString() + ' DZD</strong></td>'
            + '<td><span class="status-badge ' + statusClass + '">' + statusText + '</span></td>'
            + '<td>' + dropdownHtml + '</td>'
            + '</tr>';
        }).join('');
      }

      /* ── Products list with pagination ── */
      var currentProductsPage = 1;
      var productsPerPage = 10;

      async function renderAdminProductsList(forceRefresh) {
        console.log('📝 جاري تحديث قائمة المنتجات...');
        try {
          await loadProducts(forceRefresh);
          console.log('✓ تم تحميل المنتجات، العدد:', PRODUCTS.length);
        } catch(err) {
          console.error('⚠️ خطأ في تحميل المنتجات:', err.message);
        }
        
        var tbody = document.getElementById('admin-products-list');
        if (!tbody) {
          console.error('❌ لم يتم العثور على عنصر admin-products-list');
          return;
        }

        if (!PRODUCTS || PRODUCTS.length === 0) {
          console.warn('⚠️ لا توجد منتجات للعرض');
          tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:2rem;">' + ((window.t && window.t('admin_products_empty')) || 'لم يتم تحميل المنتجات بعد.') + '</td></tr>';
          return;
        }

        // Pagination calculations
        var totalPages = Math.ceil(PRODUCTS.length / productsPerPage);
        if (currentProductsPage > totalPages) currentProductsPage = totalPages;
        if (currentProductsPage < 1) currentProductsPage = 1;

        var startIdx = (currentProductsPage - 1) * productsPerPage;
        var endIdx = startIdx + productsPerPage;
        var paginatedProducts = PRODUCTS.slice(startIdx, endIdx);

        // Update indicator
        var indicator = document.getElementById('page-indicator');
        if (indicator) {
          var _tPage = window.t || function(k){return k;};
          indicator.textContent = _tPage('admin_pagination_page') + ' ' + currentProductsPage + ' ' + _tPage('admin_pagination_of') + ' ' + totalPages;
        }

        // Enable/disable buttons
        var prevBtn = document.getElementById('btn-prev-page');
        var nextBtn = document.getElementById('btn-next-page');
        if (prevBtn) prevBtn.disabled = (currentProductsPage === 1);
        if (nextBtn) nextBtn.disabled = (currentProductsPage === totalPages || totalPages === 0);

        console.log('🔄 جاري تصيير الصفحة', currentProductsPage, 'من المنتجات...');
        var _t = window.t || function(k){return k;};
        tbody.innerHTML = paginatedProducts.map(function(p) {
          var isCustom = p.isCustom === true;
          var sourceText = isCustom
            ? '<span class="src-badge src-custom">' + _t('admin_src_custom') + '</span>'
            : '<span class="src-badge src-default">' + _t('admin_src_default') + '</span>';
          var actionBtn = '<div style="display: flex; gap: 4px;"><button class="btn-action btn-confirm" onclick="window.editProduct(' + p.id + ')">' + _t('admin_col_actions_edit') + '</button>'
              + '<button class="btn-action btn-delete" onclick="window.deleteProduct(' + p.id + ')">' + _t('admin_col_actions_delete') + '</button></div>';
          var sizesText = (p.sizes && p.sizes.length > 0) ? p.sizes.join(', ') : _t('admin_no_sizes');
          var categoryText = p.category || 'غير محدد';

          return '<tr>'
            + '<td data-label="الصورة"><img src="' + p.img + '" alt="' + p.name + '" class="admin-prod-thumb"/></td>'
            + '<td data-label="الاسم"><strong>' + p.name + '</strong></td>'
            + '<td data-label="المجموعة">' + p.sub + '</td>'
            + '<td data-label="الفئة"><span class="category-badge" style="background: #f0f0f0; padding: 4px 8px; border-radius: 4px; font-size: 0.85rem;">' + categoryText + '</span></td>'
            + '<td data-label="السعر"><strong>' + p.price + ' DZD</strong></td>'
            + '<td data-label="الشارة">' + (p.badge ? '<span class="badge-tag">' + p.badge + '</span>' : '-') + '</td>'
            + '<td data-label="التقييم">&#9733; ' + p.stars + ' (' + p.reviews + ')</td>'
            + '<td data-label="المقاسات"><span class="txt-sizes">' + sizesText + '</span></td>'
            + '<td data-label="المصدر">' + sourceText + '</td>'
            + '<td>' + actionBtn + '</td>'
            + '</tr>';
        }).join('');
        console.log('✓ تم تصيير قائمة المنتجات بنجاح');
      }

      /* ── Leads table ── */
      async function renderLeadsTable(forceRefresh) {
        var tbody = document.getElementById('admin-leads-list');
        if (!tbody) return;
        
        var leads = [];
        try {
          leads = await getLeads(forceRefresh);
        } catch(err) {
          console.error('Error loading leads:', err);
        }

        leads.sort(function(a,b){ return new Date(b.date) - new Date(a.date); });

        var totalDisplay = document.getElementById('leads-total-display');
        var latestDate   = document.getElementById('leads-latest-date');
        if (totalDisplay) totalDisplay.textContent = leads.length;
        if (latestDate && leads.length > 0) {
          latestDate.textContent = new Date(leads[0].date).toLocaleDateString('ar-DZ');
        } else if (latestDate) {
          latestDate.textContent = '—';
        }

        if (leads.length === 0) {
          tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;padding:2rem;">' + ((window.t && window.t('admin_leads_empty')) || 'لا يوجد مشتركون بعد.') + '</td></tr>';
          return;
        }

        var _tL = window.t || function(k){return k;};
        var dtLocaleL = (localStorage.getItem('aizo_lang') || 'fr') === 'ar' ? 'ar-DZ' : (localStorage.getItem('aizo_lang') || 'fr') === 'fr' ? 'fr-FR' : 'en-US';
        tbody.innerHTML = leads.map(function(lead, idx) {
          var dt = new Date(lead.date).toLocaleDateString(dtLocaleL, { hour: '2-digit', minute: '2-digit' });
          return '<tr>'
            + '<td data-label="#"><strong>' + (idx + 1) + '</strong></td>'
            + '<td data-label="' + _tL('admin_col_customer') + '"><span class="lead-email-badge">' + lead.email + '</span></td>'
            + '<td data-label="' + _tL('admin_col_date') + '">' + dt + '</td>'
            + '<td><button class="btn-action btn-delete" onclick="window.deleteLead(\'' + lead.email + '\')">🗑️</button></td>'
            + '</tr>';
        }).join('');
      }

      /* ── Dashboard init ── */
      async function initDashboard() {
        console.log('%c=== تحميل الداشبورد ===', 'color: blue; font-size: 14px; font-weight: bold');
        console.log('🌐 API Base URL:', window.API_BASE_URL);
        
        // Load whatever is in localStorage into cache first so the UI is populated instantly
        try {
          var localOrders = JSON.parse(localStorage.getItem('local_orders') || '[]');
          cachedOrders = localOrders;
          var localLeads = JSON.parse(localStorage.getItem('local_leads') || '[]');
          cachedLeads = localLeads;
        } catch(e) {
          console.warn('Could not restore local caches:', e);
        }

        // Render everything instantly from cached/local data (zero delay)
        try {
          loadDashboardStats(false);
          renderOrdersTable('all', false);
          renderAdminProductsList(false);
          renderLeadsTable(false);
        } catch(err) {
          console.warn('Initial cache render warning:', err.message);
        }

        // Trigger background refresh asynchronously (Stale-While-Revalidate)
        (async () => {
          try {
            console.log('📍 جاري جلب البيانات من السيرفر في الخلفية...');
            await Promise.all([
              getOrders(true),
              getLeads(true),
              loadProducts(true)
            ]);
            console.log('✅ تم جلب جميع البيانات من السيرفر في الخلفية بنجاح');
            
            // Update the currently active panel smoothly
            var activePanel = document.querySelector('.admin-panel.active');
            if (activePanel) {
              var target = activePanel.id;
              if      (target === 'panel-stats')    { loadDashboardStats(false); }
              else if (target === 'panel-orders')   {
                var activeFilter = document.querySelector('#panel-orders .filter-btn.active') ? document.querySelector('#panel-orders .filter-btn.active').getAttribute('data-filter') : 'all';
                renderOrdersTable(activeFilter || 'all', false);
              }
              else if (target === 'panel-custom-orders') {
                var activeFilter = document.querySelector('#panel-custom-orders .filter-btn.active') ? document.querySelector('#panel-custom-orders .filter-btn.active').getAttribute('data-filter') : 'all';
                renderCustomOrdersTable(activeFilter || 'all', false);
              }
              else if (target === 'panel-products') { renderAdminProductsList(false); }
              else if (target === 'panel-leads')    { renderLeadsTable(false); }
            }

            // Update badges in the sidebar
            var pendingCount = (cachedOrders || []).filter(function(o){ return o.status === 'Pending'; }).length;
            var badge = document.getElementById('pending-badge');
            if (badge) {
              badge.textContent = pendingCount;
              badge.style.display = pendingCount > 0 ? 'inline-flex' : 'none';
            }
            var leadsBadge = document.getElementById('leads-badge');
            if (leadsBadge) {
              leadsBadge.textContent = (cachedLeads || []).length;
              leadsBadge.style.display = (cachedLeads || []).length > 0 ? 'inline-flex' : 'none';
            }
          } catch (err) {
            console.warn('⚠️ فشل تحديث البيانات في الخلفية:', err.message);
          }
        })();

        console.log('%c✅ انتهى تحميل الداشبورد المبدئي!', 'color: green; font-size: 14px; font-weight: bold');
        console.log('');

        var navBtns    = document.querySelectorAll('.nav-btn');
        var panels     = document.querySelectorAll('.admin-panel');
        var panelTitle = document.getElementById('panel-title');

        navBtns.forEach(function(btn) {
          btn.addEventListener('click', function() {
            navBtns.forEach(function(b){ b.classList.remove('active'); });
            panels.forEach(function(p){ p.classList.remove('active'); });
            btn.classList.add('active');
            var target = btn.getAttribute('data-target');
            document.getElementById(target).classList.add('active');
            var targetTranslationKey = 'admin_title_' + target.replace(/-/g, '_');
            panelTitle.setAttribute('data-i18n', targetTranslationKey);
            panelTitle.textContent = (window.t && window.t(targetTranslationKey)) || btn.textContent.replace(/[^\w\s\u0600-\u06FF]/gi, '').trim();
            // Ensure page indicator language matches
            var indicator = document.getElementById('page-indicator');
            if (indicator) {
              var _tp = window.t || function(k){return k;};
              var parts = indicator.textContent.split('/');
              if (parts.length === 2) { indicator.textContent = _tp('admin_pagination_page') + ' ' + (parts[0].trim().split(' ').pop() || '1') + ' ' + _tp('admin_pagination_of') + ' ' + (parts[1].trim() || '1'); }
            }

            // 1. Render instantly from cache
            if      (target === 'panel-stats')       { loadDashboardStats(false); }
            else if (target === 'panel-orders')      {
              renderOrdersTable('all', false);
              document.querySelectorAll('#panel-orders .filter-btn').forEach(function(fb){ fb.classList.remove('active'); });
              var filterBtn = document.querySelector('#panel-orders .filter-btn[data-filter="all"]');
              if (filterBtn) filterBtn.classList.add('active');
            }
            else if (target === 'panel-custom-orders') {
              renderCustomOrdersTable('all', false);
              document.querySelectorAll('#panel-custom-orders .filter-btn').forEach(function(fb){ fb.classList.remove('active'); });
              var filterBtn = document.querySelector('#panel-custom-orders .filter-btn[data-filter="all"]');
              if (filterBtn) filterBtn.classList.add('active');
            }
            else if (target === 'panel-products')    { renderAdminProductsList(false); }
            else if (target === 'panel-leads')       { renderLeadsTable(false); }

            // 2. Perform background revalidation (fetch from server to check for updates)
            (async () => {
              try {
                if (target === 'panel-stats') {
                  await Promise.all([getOrders(true), getLeads(true)]);
                  loadDashboardStats(false);
                } else if (target === 'panel-orders') {
                  await getOrders(true);
                  var activeFilter = document.querySelector('#panel-orders .filter-btn.active') ? document.querySelector('#panel-orders .filter-btn.active').getAttribute('data-filter') : 'all';
                  renderOrdersTable(activeFilter || 'all', false);
                } else if (target === 'panel-custom-orders') {
                  await getOrders(true);
                  var activeFilter = document.querySelector('#panel-custom-orders .filter-btn.active') ? document.querySelector('#panel-custom-orders .filter-btn.active').getAttribute('data-filter') : 'all';
                  renderCustomOrdersTable(activeFilter || 'all', false);
                } else if (target === 'panel-products') {
                  await loadProducts(true);
                  renderAdminProductsList(false);
                } else if (target === 'panel-leads') {
                  await getLeads(true);
                  renderLeadsTable(false);
                }
              } catch(e) {
                console.warn('Revalidation failed for ' + target + ':', e);
              }
            })();
          });
        });

        document.querySelectorAll('#panel-orders .filter-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            document.querySelectorAll('#panel-orders .filter-btn').forEach(function(b){ b.classList.remove('active'); });
            btn.classList.add('active');
            var filter = btn.getAttribute('data-filter');
            renderOrdersTable(filter, false);

            // Revalidate in background
            (async () => {
              try {
                await getOrders(true);
                renderOrdersTable(filter, false);
              } catch(e) {
                console.warn('Revalidation failed for orders filter:', e);
              }
            })();
          });
        });

        document.querySelectorAll('#panel-custom-orders .filter-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            document.querySelectorAll('#panel-custom-orders .filter-btn').forEach(function(b){ b.classList.remove('active'); });
            btn.classList.add('active');
            var filter = btn.getAttribute('data-filter');
            renderCustomOrdersTable(filter, false);

            // Revalidate in background
            (async () => {
              try {
                await getOrders(true);
                renderCustomOrdersTable(filter, false);
              } catch(e) {
                console.warn('Revalidation failed for custom orders filter:', e);
              }
            })();
          });
        });

        var addForm = document.getElementById('add-product-form');
        var toast   = document.getElementById('product-toast');
        if (addForm && !addForm.dataset.listenerAttached) {
          addForm.dataset.listenerAttached = 'true';
          
          // Toggle color input visibility based on checkbox
          var hasColorsCheckbox = document.getElementById('prod-has-colors');
          var colorsInputGroup = document.getElementById('colors-input-group');
          if (hasColorsCheckbox && colorsInputGroup) {
            hasColorsCheckbox.addEventListener('change', function() {
              colorsInputGroup.style.display = this.checked ? 'block' : 'none';
            });
          }

          addForm.addEventListener('reset', function() {
            delete addForm.dataset.editingId;
            delete addForm.dataset.editingIsCustom;
            var _tReset = window.t || function(k){return k;};
            var formTitle = document.querySelector('#panel-add-product h2');
            if (formTitle) { formTitle.textContent = _tReset('admin_form_add_title') || 'إضافة منتج جديد للمتجر'; delete formTitle.dataset.editing; }
            var submitBtn = document.querySelector('#add-product-form button[type="submit"]');
            if (submitBtn) { submitBtn.textContent = _tReset('admin_form_btn_save') || 'حفظ وإضافة المنتج للمتجر'; delete submitBtn.dataset.editing; }
            if (colorsInputGroup) colorsInputGroup.style.display = 'block';
            if (hasColorsCheckbox) hasColorsCheckbox.checked = true;
          });

          addForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            var submitBtn = addForm.querySelector('button[type="submit"]');
            var originalBtnText = submitBtn ? submitBtn.textContent : 'حفظ وإضافة المنتج للمتجر';
            if (submitBtn) {
              submitBtn.disabled = true;
              submitBtn.textContent = '⏳ جاري الحفظ والنشر...';
            }

            var editingId = addForm.dataset.editingId;
            var editingIsCustom = addForm.dataset.editingIsCustom === 'true' || !editingId;
            var sizes    = Array.from(document.querySelectorAll('input[name="prod-sizes"]:checked')).map(function(cb){ return cb.value; });
            var badgeVal = document.getElementById('prod-badge').value;
            var priceRaw = parseFloat(document.getElementById('prod-price').value);
            var stockRaw = parseInt(document.getElementById('prod-stock').value) || 20;

            // Parse colors: check if enabled
            var colors = [];
            if (hasColorsCheckbox && hasColorsCheckbox.checked) {
              var colorsRaw = document.getElementById('prod-colors').value || '';
              colors = colorsRaw.split(',').map(function(c){ return c.trim(); }).filter(function(c){ return c.length > 0; });
              if (colors.length === 0) colors = ['بدون لون'];
            } else {
              colors = ['بدون لون'];
            }

            var productData = {
              isCustom:  editingIsCustom,
              name:      document.getElementById('prod-name').value.trim(),
              sub:       document.getElementById('prod-sub').value.trim(),
              category:  document.getElementById('prod-category').value.trim(),
              price:     priceRaw.toLocaleString(),
              badge:     badgeVal || null,
              badgeType: badgeVal ? badgeVal.toLowerCase() : null,
              stars:     parseInt(document.getElementById('prod-stars').value),
              reviews:   parseInt(document.getElementById('prod-reviews').value),
              img:       document.getElementById('prod-img').value.trim(),
              alt:       document.getElementById('prod-name').value.trim(),
              sizes:     sizes,
              colors:    colors,
              stock:     stockRaw
            };

            var urlPath = editingId 
              ? (editingIsCustom ? ('/api/custom-products/' + editingId) : ('/api/default-products/' + editingId)) 
              : '/api/custom-products';
            var method  = editingId ? 'PUT' : 'POST';

            if (!editingId) {
              productData.id = Date.now();
            } else {
              productData.id = parseInt(editingId);
            }

            try {
              const localResult = await apiFetch(urlPath, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(productData)
              });

              try {
                const zrPayload = {
                  name: productData.name,
                  sku: (productData.sku || productData.name || 'SKU-' + Date.now()).replace(/\s+/g, '-').replace(/[^A-Za-z0-9\-_]/g, '').toUpperCase() + '-' + Date.now(),
                  basePrice: Number(productData.price ? String(productData.price).replace(/,/g, '') : 0) || 0,
                  purchasePrice: Number(productData.price ? String(productData.price).replace(/,/g, '') : 0) || 0,
                  dimensions: { length: 10, width: 10, height: 10, weight: 1 },
                  localStock: Number(productData.stock || 0) || 0,
                  categoryId: null,
                  subCategoryId: null
                };

                const zrResult = await apiFetch('/api/zr-products', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(zrPayload)
                });

                if (zrResult && zrResult.productId) {
                  console.log('✅ تم إنشاء المنتج في ZR Express:', zrResult.productId);
                }
              } catch (zrErr) {
                console.warn('⚠️ لم يتم إنشاء المنتج في ZR Express:', zrErr.message || zrErr);
              }

              if (toast) {
                var _tToast = window.t || function(k){return k;};
                var zrStatusText = '';
                if (localResult && localResult.id) {
                  zrStatusText = _tToast('admin_toast_zr_success') || ' — تم نشر المنتج إلى ZR Express';
                }
                toast.textContent = editingId
                  ? (_tToast('admin_toast_edit_success') + zrStatusText)
                  : (_tToast('admin_toast_add_success') + zrStatusText);
                toast.classList.add('show');
                setTimeout(function(){ toast.classList.remove('show'); }, 4500);
              }

              addForm.reset();

              await loadProducts(true);
              await renderAdminProductsList(true);
              await loadDashboardStats(true);
            } catch(e) {
              alert('⚠️ ' + ((window.t && window.t('admin_error_generic')) || 'تعذّر حفظ المنتج.'));
              console.error(e);
            } finally {
              if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.textContent = originalBtnText;
              }
            }
          });
        }

        /* ─── Edit Product window helper ─── */
        window.editProduct = function(productId) {
          var p = PRODUCTS.find(function(item) { return item.id === productId; });
          if (!p) return;

          // Switch tab to add product
          var addProductMenuBtn = document.querySelector('.nav-btn[data-target="panel-add-product"]');
          if (addProductMenuBtn) {
            addProductMenuBtn.click();
          }

          // Populate form fields
          document.getElementById('prod-name').value = p.name || '';
          document.getElementById('prod-sub').value = p.sub || '';
          document.getElementById('prod-category').value = p.category || '';
          document.getElementById('prod-price').value = parseFloat(String(p.price).replace(/,/g, '')) || 0;
          document.getElementById('prod-badge').value = p.badge || '';
          document.getElementById('prod-stars').value = p.stars || 5;
          document.getElementById('prod-reviews').value = p.reviews || 12;
          document.getElementById('prod-img').value = p.img || '';

          // Handle colors
          var colors = p.colors || [];
          var hasColors = colors.length > 0 && !(colors.length === 1 && colors[0] === 'بدون لون');
          
          if (hasColorsCheckbox) {
            hasColorsCheckbox.checked = hasColors;
            if (colorsInputGroup) {
              colorsInputGroup.style.display = hasColors ? 'block' : 'none';
            }
          }
          var colorsInput = document.getElementById('prod-colors');
          if (colorsInput) {
            colorsInput.value = hasColors ? colors.join(', ') : '';
          }

          // Handle sizes checkboxes
          var sizeCheckboxes = document.querySelectorAll('input[name="prod-sizes"]');
          sizeCheckboxes.forEach(function(cb) {
            cb.checked = p.sizes ? p.sizes.includes(cb.value) : false;
          });

          // Set stock count
          var firstVariantKey = p.colors && p.colors[0] && p.sizes && p.sizes[0] ? (p.id + '-' + p.colors[0] + '-' + p.sizes[0]) : '';
          var stockInput = document.getElementById('prod-stock');
          if (stockInput) {
            stockInput.value = p.stock || (firstVariantKey && window.PRODUCT_STOCKS && window.PRODUCT_STOCKS[firstVariantKey] !== undefined ? window.PRODUCT_STOCKS[firstVariantKey] : 20);
          }

          // Change form header and submit button text
          var formTitle = document.querySelector('#panel-add-product h2');
          var _tEdit = window.t || function(k){return k;};
          if (formTitle) { formTitle.textContent = (_tEdit('admin_form_edit_title') || 'تعديل منتج: ') + p.name; formTitle.dataset.editing = 'true'; }
          
          var submitBtn = document.querySelector('#add-product-form button[type="submit"]');
          if (submitBtn) { submitBtn.textContent = _tEdit('admin_form_btn_update') || 'تحديث وتعديل المنتج'; submitBtn.dataset.editing = 'true'; }

          // Set editing ID attribute
          if (addForm) {
            addForm.dataset.editingId = productId;
            addForm.dataset.editingIsCustom = p.isCustom ? 'true' : 'false';
          }
        };

        /* ─── Pagination Button Handlers ─── */
        var prevBtn = document.getElementById('btn-prev-page');
        var nextBtn = document.getElementById('btn-next-page');
        if (prevBtn && !prevBtn.dataset.listenerAttached) {
          prevBtn.dataset.listenerAttached = 'true';
          prevBtn.addEventListener('click', async function() {
            if (currentProductsPage > 1) {
              currentProductsPage--;
              await renderAdminProductsList();
            }
          });
        }
        if (nextBtn && !nextBtn.dataset.listenerAttached) {
          nextBtn.dataset.listenerAttached = 'true';
          nextBtn.addEventListener('click', async function() {
            var totalPages = Math.ceil(PRODUCTS.length / productsPerPage);
            if (currentProductsPage < totalPages) {
              currentProductsPage++;
              await renderAdminProductsList();
            }
          });
        }

        /* ─── Direct ZR Express Fallback Helper Functions ─── */
        async function getTerritoryIdsDirectly(wilayaCode, secretKey, tenantId, baseUrl) {
          var url = 'https://corsproxy.io/?' + encodeURIComponent(baseUrl + '/territories/search');
          try {
            var res = await fetch(url, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-Tenant': tenantId,
                'X-Api-Key': secretKey
              },
              body: JSON.stringify({
                pageNumber: 1,
                pageSize: 10,
                advancedFilter: {
                  logic: 'and',
                  filters: [
                    { field: 'code', operator: 'eq', value: String(wilayaCode) },
                    { field: 'level', operator: 'eq', value: 'wilaya' }
                  ]
                }
              })
            });
            if (res.ok) {
              var searchData = await res.json();
              if (searchData.items && searchData.items.length > 0) {
                var cityTerritoryId = searchData.items[0].id;
                
                // Find commune
                var distRes = await fetch(url, {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json',
                    'X-Tenant': tenantId,
                    'X-Api-Key': secretKey
                  },
                  body: JSON.stringify({
                    pageNumber: 1,
                    pageSize: 1,
                    advancedFilter: {
                      logic: 'and',
                      filters: [
                        { field: 'parentId', operator: 'eq', value: cityTerritoryId },
                        { field: 'level', operator: 'eq', value: 'commune' }
                      ]
                    }
                  })
                });
                
                var districtTerritoryId = cityTerritoryId;
                if (distRes.ok) {
                  var distData = await distRes.json();
                  if (distData.items && distData.items.length > 0) {
                    districtTerritoryId = distData.items[0].id;
                  }
                }
                return { cityTerritoryId: cityTerritoryId, districtTerritoryId: districtTerritoryId };
              }
            }
          } catch (err) {
            console.warn('CORS territory fetch failed:', err);
          }
          
          return {
            cityTerritoryId: '53c9e062-9c4e-4c77-8b71-55eabf887f83',
            districtTerritoryId: '8d0b6cd9-7712-47d2-9ea4-460246494c32'
          };
        }


<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script>
    (function() {
      var _originalFetch = window.fetch;
      window.fetch = function(input, init) {
        init = init || {};
        var url = (typeof input === 'string') ? input : (input && input.url) || '';
        if (url.indexOf('/api/') !== -1) {
          var headers = new Headers(init.headers || {});
          headers.set('X-Admin-Password', sessionStorage.getItem('admin_password') || '');
          init.headers = headers;
        }
        return _originalFetch.call(this, input, init);
      };
    })();
  </script>
  <title>لوحة التحكم — aizo.dz</title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  
  <!-- Stylesheet -->
  <link rel="stylesheet" href="css/admin.css">
  <link rel="stylesheet" href="css/admin-modal-fix.css">
  <link rel="stylesheet" href="css/custom-order-layer-modal.css">
</head>
<body>

  <!-- ════════════════════════════════════════════
       LOGIN SCREEN
  ════════════════════════════════════════════ -->
  <div class="login-overlay" id="login-overlay">
    <div class="login-card">
      <div class="login-logo">AIZO.DZ</div>
      
      <!-- Language Selector -->
      <div class="lang-selector" style="margin-bottom: 2rem;">
        <button type="button" class="lang-btn" aria-label="Change Language">
          <span>🇫🇷</span>
        </button>
      </div>

      <h2 data-i18n="admin_login_title">تسجيل الدخول للمشرف</h2>
      <p data-i18n="admin_login_desc">يرجى إدخال الرمز السري للوصول إلى لوحة التحكم</p>
      
      <form id="login-form">
        <div class="form-group">
          <input type="password" id="admin-password" data-i18n-placeholder="admin_login_pwd_ph" placeholder="الرمز السري" required autocomplete="current-password">
          <span class="error-text" id="login-error">الرمز السري غير صحيح!</span>
        </div>
        <button type="submit" class="btn-admin-primary" data-i18n="admin_login_btn" onclick="adminQuickLogin(event)">دخول لوحة التحكم</button>
      </form>
      <a href="/" class="btn-back-store" data-i18n="admin_back_store">← العودة إلى المتجر</a>
    </div>
  </div>

  <!-- ════════════════════════════════════════════
       DASHBOARD CONTENT
  ════════════════════════════════════════════ -->
  <div class="admin-wrapper" id="admin-wrapper" style="display: none;">
    
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-brand">
        <a href="/" class="logo">AIZO.DZ</a>
        <span class="badge-role" data-i18n="admin_sidebar_role">مسؤول المتجر</span>
      </div>
      
      <nav class="sidebar-nav">
        <ul>
          <li><button class="nav-btn active" data-target="panel-stats" data-i18n="admin_nav_stats">✦ الإحصائيات العامة</button></li>
          <li><button class="nav-btn" data-target="panel-orders" id="orders-menu-btn" data-i18n="admin_nav_orders">📦 إدارة الطلبات <span class="nav-badge" id="pending-badge">0</span></button></li>
          <li><button class="nav-btn" data-target="panel-custom-orders" id="custom-orders-menu-btn" data-i18n="admin_nav_custom_orders">🎨 طلبات خاصة <span class="nav-badge nav-badge--blue" id="custom-orders-badge">0</span></button></li>
          <li><button class="nav-btn" data-target="panel-leads" data-i18n="admin_nav_leads">📧 قائمة الإيميلات <span class="nav-badge nav-badge--teal" id="leads-badge">0</span></button></li>
          <li><button class="nav-btn" data-target="panel-add-product" data-i18n="admin_nav_add_product">✨ إضافة منتج جديد</button></li>
          <li><button class="nav-btn" data-target="panel-products" data-i18n="admin_nav_products">🛍️ قائمة المنتجات</button></li>
        </ul>
      </nav>
      
      <div class="sidebar-footer">
        <button class="btn-logout" id="btn-logout" data-i18n="admin_logout">تسجيل الخروج</button>
        <a href="/" class="btn-back-store-sidebar" data-i18n="admin_back_store_sidebar">← العودة للمتجر</a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
      <header class="admin-header">
        <h1 id="panel-title" data-i18n="admin_title_panel_stats">الإحصائيات العامة</h1>
        
        <div class="admin-header-actions" style="display: flex; align-items: center; gap: 1.5rem;">
          <!-- Sidebar toggle (mobile) -->
          <button id="sidebar-toggle" class="btn-sidebar-toggle" aria-expanded="true" aria-label="Toggle sidebar">☰</button>
          <!-- Language Selector -->
          <div class="lang-selector">
            <button type="button" class="lang-btn" aria-label="Change Language">
              <span id="admin-current-lang-label">🇫🇷</span>
            </button>
            </div>
          </div>
          
          <div class="admin-user-profile">
            <span class="dot-status"></span>
            <span id="server-status-text" data-i18n="admin_profile_status">لوحة المشرف متصلة</span>
          </div>
      </header>

      <!-- Error Alert Panel -->
      <div class="admin-error-alert" id="admin-error-alert" style="display: none;">
        <div class="admin-error-content">
          <span class="admin-error-icon">⚠️</span>
          <p id="admin-error-text">حدث خطأ أثناء المعالجة</p>
          <button type="button" class="admin-error-close" id="admin-error-close">×</button>
        </div>
      </div>

      <!-- Panel: Stats -->
      <section class="admin-panel active" id="panel-stats">
        <div class="stats-grid">
          
          <div class="stat-card">
            <div class="stat-icon">💰</div>
            <div class="stat-details">
              <h3 data-i18n="admin_sales_total">إجمالي المبيعات المؤكدة</h3>
              <p class="stat-value" id="stat-sales">0 DZD</p>
              <span class="stat-sub" data-i18n="admin_sales_sub">من الطلبات المؤكدة فقط</span>
            </div>
          </div>
          
          <div class="stat-card">
            <div class="stat-icon">📦</div>
            <div class="stat-details">
              <h3 data-i18n="admin_orders_total">إجمالي عدد الطلبات</h3>
              <p class="stat-value" id="stat-orders-total">0</p>
              <span class="stat-sub" data-i18n="admin_orders_sub">الطلبات المسجلة بالنظام</span>
            </div>
          </div>
          
          <div class="stat-card">
            <div class="stat-icon">👕</div>
            <div class="stat-details">
              <h3 data-i18n="admin_products_active">عدد المنتجات النشطة</h3>
              <p class="stat-value" id="stat-products-total">0</p>
              <span class="stat-sub" data-i18n="admin_products_sub">المعروضة حالياً بالمتجر</span>
            </div>
          </div>

          <div class="stat-card stat-card--accent">
            <div class="stat-icon">📧</div>
            <div class="stat-details">
              <h3 data-i18n="admin_leads_total">إجمالي المشتركين (Leads)</h3>
              <p class="stat-value" id="stat-leads-total">0</p>
              <span class="stat-sub" data-i18n="admin_leads_sub">بريد إلكتروني مسجّل</span>
            </div>
          </div>

          <div class="stat-card stat-card--returned">
            <div class="stat-icon">↩️</div>
            <div class="stat-details">
              <h3 data-i18n="admin_returned_total">الطلبات المُرجعة (Returned)</h3>
              <p class="stat-value" id="stat-returned-total">0</p>
              <span class="stat-sub" data-i18n="admin_returned_sub">مُرجعة من ZR Express</span>
            </div>
          </div>

          <div class="stat-card stat-card--delivered">
            <div class="stat-icon">✅</div>
            <div class="stat-details">
              <h3 data-i18n="admin_delivered_total">الطلبات المسلمة (Delivered)</h3>
              <p class="stat-value" id="stat-delivered-total">0</p>
              <span class="stat-sub" data-i18n="admin_delivered_sub">تم تسليمها للزبائن</span>
            </div>
          </div>

        </div>

        <!-- Latest Orders Section in Stats -->
        <div class="recent-box">
          <h2 data-i18n="admin_recent_orders">آخر الطلبات الواردة</h2>
          <div class="table-responsive">
            <table class="admin-table">
              <thead>
                <tr>
                  <th data-i18n="admin_col_order_id">رقم الطلب</th>
                  <th data-i18n="admin_col_date">تاريخ الطلب</th>
                  <th data-i18n="admin_col_customer">الزبون</th>
                  <th data-i18n="admin_col_wilaya">الولاية</th>
                  <th data-i18n="admin_col_phone">الهاتف</th>
                  <th data-i18n="admin_col_delivery">نوع التوصيل</th>
                  <th data-i18n="admin_col_total">المجموع</th>
                  <th data-i18n="admin_col_status">الحالة</th>
                </tr>
              </thead>
              <tbody id="recent-orders-list">
                <!-- Injected by JS -->
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- Panel: Orders Management -->
      <section class="admin-panel" id="panel-orders">
        <div class="filter-bar">
          <button class="filter-btn active" data-filter="all" data-i18n="cat_all">الكل</button>
          <button class="filter-btn" data-filter="Confirmed" data-i18n="status_confirmed">مؤكدة</button>
          <button class="filter-btn" data-filter="Delivered" data-i18n="status_delivered">تم التسليم</button>
          <button class="filter-btn" data-filter="Returned" data-i18n="status_returned">مُرجعة</button>
          <button class="filter-btn" data-filter="Cancelled" data-i18n="status_cancelled">ملغاة</button>
        </div>

        <div class="table-responsive">
          <table class="admin-table">
            <thead>
              <tr>
                <th data-i18n="admin_col_order_id">رقم الطلب</th>
                <th data-i18n="admin_col_date">التاريخ</th>
                <th data-i18n="admin_col_customer">العميل</th>
                <th data-i18n="admin_col_phone">الهاتف</th>
                <th data-i18n="admin_col_wilaya">الولاية</th>
                <th data-i18n="admin_col_delivery">طريقة الاستلام</th>
                <th data-i18n="admin_col_items">المنتجات المطلوبة</th>
                <th data-i18n="admin_col_total">المجموع الإجمالي</th>
                <th data-i18n="admin_col_status">الحالة</th>
                <th data-i18n="admin_col_actions">الإجراءات</th>
              </tr>
            </thead>
            <tbody id="admin-orders-list">
              <!-- Injected by JS -->
            </tbody>
          </table>
        </div>
      </section>

      <!-- Panel: Custom Orders (طلبات خاصة) -->
      <section class="admin-panel" id="panel-custom-orders">
        <div class="custom-orders-header">
          <h2 data-i18n="admin_title_panel_custom_orders">🎨 طلبات خاصة / Custom Orders</h2>
          <p data-i18n="admin_custom_orders_desc">جميع الطلبات التي تحتوي على تصميمات مخصصة من العملاء.</p>
        </div>

        <div class="custom-orders-stats">
          <div class="custom-stat-card">
            <span class="custom-stat-icon">🎨</span>
            <div>
              <div class="custom-stat-value" id="custom-orders-count">0</div>
              <div class="custom-stat-label" data-i18n="admin_custom_orders_total_label">إجمالي الطلبات الخاصة</div>
            </div>
          </div>
        </div>

        <div class="filter-bar">
          <button class="filter-btn active" data-filter="all" data-custom-filter data-i18n="cat_all">الكل</button>
          <button class="filter-btn" data-filter="Confirmed" data-custom-filter data-i18n="status_confirmed">مؤكدة</button>
          <button class="filter-btn" data-filter="Delivered" data-custom-filter data-i18n="status_delivered">تم التسليم</button>
          <button class="filter-btn" data-filter="Returned" data-custom-filter data-i18n="status_returned">مُرجعة</button>
          <button class="filter-btn" data-filter="Cancelled" data-custom-filter data-i18n="status_cancelled">ملغاة</button>
        </div>

        <div class="table-responsive">
          <table class="admin-table">
            <thead>
              <tr>
                <th data-i18n="admin_col_order_id">رقم الطلب</th>
                <th data-i18n="admin_col_date">التاريخ</th>
                <th data-i18n="admin_col_customer">العميل</th>
                <th data-i18n="admin_col_phone">الهاتف</th>
                <th data-i18n="admin_col_wilaya">الولاية</th>
                <th data-i18n="admin_col_delivery">طريقة الاستلام</th>
                <th data-i18n="admin_col_items">المنتجات المطلوبة</th>
                <th data-i18n="admin_col_total">المجموع الإجمالي</th>
                <th data-i18n="admin_col_status">الحالة</th>
                <th data-i18n="admin_col_actions">الإجراءات</th>
              </tr>
            </thead>
            <tbody id="admin-custom-orders-list">
              <!-- Injected by JS -->
            </tbody>
          </table>
        </div>
      </section>

      <!-- Panel: Add Product -->
      <section class="admin-panel" id="panel-add-product">
        <div class="form-container">
          <h2>إضافة منتج جديد للمتجر</h2>
          <p>املأ التفاصيل التالية ليتم عرض المنتج مباشرة في الصفحة الرئيسية للمتجر.</p>

          <form id="add-product-form">
            <div class="form-grid">
              
              <div class="form-group">
                <label for="prod-name">اسم المنتج *</label>
                <input type="text" id="prod-name" placeholder="مثال: Vescartes Ronin Jacket" required>
              </div>

              <div class="form-group">
                <label for="prod-sub">الوصف المختصر (Collection/Subtitle) *</label>
                <input type="text" id="prod-sub" placeholder="مثال: Edo collection أو Vescartes" required>
              </div>

              <div class="form-group">
                <label for="prod-category">فئة المنتج *</label>
                <select id="prod-category" required>
                  <option value="">-- اختر فئة المنتج --</option>
                  <option value="سراويل">سراويل (Pantalons)</option>
                  <option value="هودي">هودي (Hoodies)</option>
                  <option value="جاكيت">جاكيت (Jackets)</option>
                  <option value="تي شيرت">تي شيرت (T-Shirts)</option>
                  <option value="قميص">قميص (Shirts)</option>
                  <option value="سترة">سترة (Sweaters)</option>
                  <option value="معاطف">معاطف (Coats)</option>
                  <option value="أكسسوارات">أكسسوارات (Accessories)</option>
                  <option value="أخرى">أخرى (Other)</option>
                </select>
              </div>

              <div class="form-group">
                <label for="prod-price">السعر (DZD) *</label>
                <input type="number" id="prod-price" placeholder="مثال: 12500" required>
              </div>

              <div class="form-group">
                <label for="prod-badge">علامة المنتج (Badge) - اختياري</label>
                <select id="prod-badge">
                  <option value="">لا توجد علامة</option>
                  <option value="New">جديد (New)</option>
                  <option value="Sale">تخفيض (Sale)</option>
                  <option value="Limited">محدود (Limited)</option>
                </select>
              </div>

              <div class="form-group">
                <label for="prod-stars">التقييم الافتراضي (النجوم) *</label>
                <select id="prod-stars" required>
                  <option value="5" selected>★★★★★ (5)</option>
                  <option value="4">★★★★☆ (4)</option>
                  <option value="3">★★★☆☆ (3)</option>
                </select>
              </div>

              <div class="form-group">
                <label for="prod-reviews">عدد المراجعات الافتراضي *</label>
                <input type="number" id="prod-reviews" value="12" required>
              </div>

              <div class="form-group">
                <label for="prod-stock">كمية المخزون (Inventory Count) *</label>
                <input type="number" id="prod-stock" value="20" min="0" required>
              </div>

              <div class="form-group full-width">
                <label for="prod-img">رابط صورة المنتج (URL) *</label>
                <input type="url" id="prod-img" placeholder="أدخل رابط صورة مباشر من الإنترنت (أو ضع صورة Pinterest/Imgur)" required>
                <span class="help-text">يمكنك نسخ رابط أي صورة للملابس من الإنترنت لاستخدامها كصورة توضيحية.</span>
              </div>

              <div class="form-group full-width" style="display: flex; align-items: center; gap: 10px; margin-bottom: 0;">
                <input type="checkbox" id="prod-has-colors" checked style="width: auto; height: auto;">
                <label for="prod-has-colors" style="margin-bottom: 0; cursor: pointer; font-weight: 500;">هل يحتوي المنتج على ألوان خيارية؟ (Enable color options)</label>
              </div>

              <div class="form-group full-width" id="colors-input-group">
                <label for="prod-colors">الألوان المتاحة (افصل بينها بفاصلة) *</label>
                <input type="text" id="prod-colors" placeholder="مثال: أسود, أبيض, أزرق" value="أسود, أبيض">
                <span class="help-text">ادخل ألوان المنتج مفصولة بفاصلة. ستُستخدم في خيارات الإضافة للسلة.</span>
              </div>

              <div class="form-group full-width">
                <label>المقاسات المتاحة للمنتج (اختر واحداً أو أكثر) *</label>
                <div class="sizes-checklist">
                  <label class="checkbox-card">
                    <input type="checkbox" name="prod-sizes" value="S">
                    <span>S</span>
                  </label>
                  <label class="checkbox-card">
                    <input type="checkbox" name="prod-sizes" value="M">
                    <span>M</span>
                  </label>
                  <label class="checkbox-card">
                    <input type="checkbox" name="prod-sizes" value="L">
                    <span>L</span>
                  </label>
                  <label class="checkbox-card">
                    <input type="checkbox" name="prod-sizes" value="XL">
                    <span>XL</span>
                  </label>
                  <label class="checkbox-card">
                    <input type="checkbox" name="prod-sizes" value="XXL">
                    <span>XXL</span>
                  </label>
                </div>
                <span class="help-text">إذا لم يتم اختيار أي مقاس، سيُستخدم مقاس M افتراضياً لضمان توفر المخزون.</span>
              </div>

            </div>

            <div class="form-actions">
              <button type="submit" class="btn-admin-primary">حفظ وإضافة المنتج للمتجر</button>
              <button type="reset" class="btn-admin-secondary">إعادة التعيين</button>
            </div>
          </form>

          <div class="toast-success" id="product-toast">✓ تم إضافة المنتج بنجاح وتحديث المتجر!</div>
        </div>
      </section>

      <!-- Panel: Products List -->
      <section class="admin-panel" id="panel-products">
        <div class="products-list-header">
          <h2>المنتجات المعروضة بالمتجر</h2>
          <p>يمكنك استعراض جميع المنتجات (الافتراضية والمضافة يدوياً). كما يمكنك حذف المنتجات المضافة يدوياً.</p>
        </div>

        <div class="table-responsive">
          <table class="admin-table">
            <thead>
              <tr>
                <th data-i18n="admin_col_image">الصورة</th>
                <th data-i18n="admin_col_name">الاسم</th>
                <th data-i18n="admin_col_collection">المجموعة</th>
                <th data-i18n="admin_col_category">الفئة</th>
                <th data-i18n="admin_col_price">السعر</th>
                <th data-i18n="admin_col_badge">العلامة</th>
                <th data-i18n="admin_col_rating">التقييم</th>
                <th data-i18n="admin_col_sizes">المقاسات المتاحة</th>
                <th data-i18n="admin_col_source">المصدر</th>
                <th data-i18n="admin_col_actions">التحكم</th>
              </tr>
            </thead>
            <tbody id="admin-products-list">
              <!-- Injected by JS -->
            </tbody>
          </table>
        </div>
        <!-- Pagination controls -->
        <div class="pagination-controls" id="products-pagination" style="display: flex; justify-content: center; align-items: center; gap: 1rem; margin-top: 1.5rem;">
          <button class="btn-admin-secondary" id="btn-prev-page" style="padding: 0.5rem 1rem; border-radius: 4px; font-weight: 500;">السابق &larr;</button>
          <span id="page-indicator" style="font-weight: 500;">الصفحة 1 من 1</span>
          <button class="btn-admin-secondary" id="btn-next-page" style="padding: 0.5rem 1rem; border-radius: 4px; font-weight: 500;">التالي &rarr;</button>
        </div>
      </section>

      <!-- Panel: Leads / Email Sign-ups -->
      <section class="admin-panel" id="panel-leads">
        <div class="leads-header">
          <div>
            <h2>قائمة المشتركين / Email Leads</h2>
            <p>جميع الإيميلات المسجّلة عبر نافذة الاشتراك في المتجر.</p>
          </div>
          <div class="leads-stats-mini">
            <div class="leads-mini-card">
              <span class="leads-mini-label" data-i18n="admin_leads_total_label">إجمالي المشتركين</span>
              <span class="leads-mini-value" id="leads-total-display">0</span>
            </div>
            <div class="leads-mini-card">
              <span class="leads-mini-label" data-i18n="admin_leads_latest_label">أحدث اشتراك</span>
              <span class="leads-mini-value" id="leads-latest-date">—</span>
            </div>
          </div>
        </div>

        <div class="table-responsive">
          <table class="admin-table">
            <thead>
              <tr>
                <th>#</th>
                <th data-i18n="admin_col_customer">البريد الإلكتروني</th>
                <th data-i18n="admin_col_date">تاريخ الاشتراك</th>
                <th data-i18n="admin_col_actions">الإجراءات</th>
              </tr>
            </thead>
            <tbody id="admin-leads-list">
              <!-- Injected by JS -->
            </tbody>
          </table>
        </div>
      </section>

    </main>
  </div>


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AIZO.DZ — Curated Essentials</title>
  <meta name="description" content="aizo.dz — A curated selection of premium, minimalist products crafted for modern living. Proudly Algerian." />
  <meta name="keywords"    content="aizo, Algeria, premium, minimalist, lifestyle, shop, curated" />
  <meta name="author"      content="aizo.dz" />

  <!-- Open Graph -->
  <meta property="og:title"       content="aizo.dz — Curated Essentials" />
  <meta property="og:description" content="Premium minimalist products curated for intentional living." />
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="https://aizo.dz" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />

  <!-- Stylesheet -->
  <link rel="stylesheet" href="css/style.css" />

  <!-- Preload new hero image -->
  <link rel="preload" as="image" href="https://i.pinimg.com/736x/d5/7e/e7/d57ee7227e07e1a03de00c6188c9c462.jpg" fetchpriority="high" />
</head>
<body>

<!-- ════════════════════════════════════════════
     NAVBAR
════════════════════════════════════════════ -->
<header class="navbar" id="navbar" role="banner">
  <div class="navbar__inner">

    <!-- Desktop navigation -->
    <nav aria-label="Main navigation">
      <ul class="nav-links">
        <li><a href="#collection" class="nav-link" data-i18n="nav_new_arrivals">New Arrivals</a></li>
        <li><a href="/collections" class="nav-link" data-i18n="nav_collection">The Collection</a></li>
        <li><a href="/customize" class="nav-link" data-i18n="pd_custom_order">Custom Order</a></li>
        <li><a href="#about"      class="nav-link" data-i18n="nav_about">About Us</a></li>
        <li><a href="/collections" class="btn-nav" id="shop-now-btn" data-i18n="nav_shop_now">Shop Now</a></li>
      </ul>
    </nav>

    <!-- Actions (Cart & Hamburger) -->
    <div class="navbar__actions">
      <!-- Floating language button (moved beside cart) -->
      <button class="lang-btn lang-btn-floating" aria-label="Change Language">
        <span id="nav-current-lang-label">🇫🇷</span>
      </button>
      <!-- Cart -->
      <button class="cart-trigger" id="cart-trigger" aria-label="Open Cart">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" width="20" height="20">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1,0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0,1-1.12-1.243l1.264-12A1.125 1.125 0 0,1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1,1-.75 0 .375.375 0 0,1 .75 0Zm7.5 0a.375.375 0 1,1-.75 0 .375.375 0 0,1 .75 0Z" />
        </svg>
        <span class="cart-count" id="cart-count">0</span>
      </button>

      <!-- Hamburger (opens mobile menu) -->
      <button
        class="hamburger"
        id="hamburger"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger__bar"></span>
        <span class="hamburger__bar"></span>
        <span class="hamburger__bar"></span>
      </button>
    </div>
  </div>
</header>

<!-- SIDE DRAWER BACKDROP -->
<div class="side-drawer-backdrop" id="side-drawer-backdrop" aria-hidden="true"></div>

<!-- SIDE DRAWER -->
<aside class="side-drawer" id="side-drawer" role="dialog" aria-modal="true" aria-label="Navigation menu">
  <div class="side-drawer__header">
    <button class="side-drawer__close" id="side-drawer-close" aria-label="Close navigation menu">&times;</button>
  </div>
  <div class="side-drawer__body">
    <ul>
      <li><a href="#collection" class="nav-link" data-i18n="nav_new_arrivals">New Arrivals</a></li>
      <li><a href="/collections" class="nav-link" data-i18n="nav_collection">The Collection</a></li>
      <li><a href="/customize" class="nav-link" data-i18n="pd_custom_order">Custom Order</a></li>
      <li><a href="#about" class="nav-link" data-i18n="nav_about">About Us</a></li>
    </ul>
    <a href="/collections" class="btn-nav" data-i18n="nav_shop_now">Shop Now</a>
  </div>
  <div class="side-drawer__footer">
    <button class="side-drawer__lang-btn" id="side-drawer-lang-btn" aria-label="Choose language">
      <span class="side-drawer__lang-current" id="side-drawer-lang-current">🇫🇷</span>
      <span class="side-drawer__lang-arrow">▼</span>
    </button>
  </div>
</aside>

<!-- LANGUAGE SELECTION MODAL -->
<div class="lang-modal-backdrop" id="lang-modal-backdrop" aria-hidden="true"></div>
<div class="lang-modal" id="lang-modal" role="dialog" aria-modal="true" aria-labelledby="lang-modal-title" aria-hidden="true">
  <div class="lang-modal__handle"></div>
  <div class="lang-modal__header">
    <span class="lang-modal__title" id="lang-modal-title" data-i18n="lang_modal_title">Choose Language</span>
    <button class="lang-modal__close" id="lang-modal-close" aria-label="Close language selector">&times;</button>
  </div>
  <div class="lang-modal__list">
    <button class="lang-modal__option" data-lang="ar">
      <span class="lang-modal__flag">🇩🇿</span>
      <div class="lang-modal__info">
        <span class="lang-modal__name">Arabic</span>
        <span class="lang-modal__native">عربي - العربية</span>
      </div>
      <span class="lang-modal__check">✓</span>
    </button>
    <button class="lang-modal__option" data-lang="fr">
      <span class="lang-modal__flag">🇫🇷</span>
      <div class="lang-modal__info">
        <span class="lang-modal__name">Français</span>
        <span class="lang-modal__native">Langue française</span>
      </div>
      <span class="lang-modal__check">✓</span>
    </button>
    <button class="lang-modal__option" data-lang="en">
      <span class="lang-modal__flag">🇺🇸</span>
      <div class="lang-modal__info">
        <span class="lang-modal__name">English</span>
        <span class="lang-modal__native">English language</span>
      </div>
      <span class="lang-modal__check">✓</span>
    </button>
  </div>
</div>



<!-- ════════════════════════════════════════════
     HERO
════════════════════════════════════════════ -->
<main>
<section class="hero" aria-labelledby="hero-title">
  <!-- SEO Heading -->
  <h1 class="sr-only" id="hero-title">AIZO.DZ — Curated Essentials</h1>

  <!-- Single Background Image -->
  <div class="hero__bg-image" aria-hidden="true"></div>
  
  <!-- Dark overlay for contrast -->
  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__content">
    <div class="hero__actions">
      <a href="/collections" class="btn-shop-hero" id="hero-shop-btn">
        <span>SHOP NOW</span>
      </a>
    </div>
  </div>
</section>


<!-- ════════════════════════════════════════════
     MARQUEE
════════════════════════════════════════════ -->
<div class="marquee" aria-hidden="true">
  <div class="marquee__track">
    <span class="marquee__item">Premium Quality</span>
    <span class="marquee__dot">·</span>
    <span class="marquee__item">Fast Delivery 58 Wilayas</span>
    <span class="marquee__dot">·</span>
    <span class="marquee__item">Curated in Algeria</span>
    <span class="marquee__dot">·</span>
    <span class="marquee__item">Mindful Living</span>
    <span class="marquee__dot">·</span>
    <span class="marquee__item">14-Day Returns</span>
    <span class="marquee__dot">·</span>
    <span class="marquee__item">Authenticity Guaranteed</span>
    <span class="marquee__dot">·</span>
    <!-- duplicate for seamless loop -->
    <span class="marquee__item">Premium Quality</span>
    <span class="marquee__dot">·</span>
    <span class="marquee__item">Fast Delivery 58 Wilayas</span>
    <span class="marquee__dot">·</span>
    <span class="marquee__item">Curated in Algeria</span>
    <span class="marquee__dot">·</span>
    <span class="marquee__item">Mindful Living</span>
    <span class="marquee__dot">·</span>
    <span class="marquee__item">14-Day Returns</span>
    <span class="marquee__dot">·</span>
    <span class="marquee__item">Authenticity Guaranteed</span>
    <span class="marquee__dot">·</span>
  </div>
</div>


<!-- ════════════════════════════════════════════
     SHOP BY CATEGORY / BANNERS GRID
     ════════════════════════════════════════════ -->
<section class="category-banners" aria-labelledby="cat-banners-title">
  <div class="category-banners__inner">
    <h2 class="category-banners__title" id="cat-banners-title">Shop by Category</h2>
    <div class="category-banners__grid">
      
      <!-- Denim -->
      <a href="/collections?category=jeans" class="category-banner-card">
        <img class="category-banner-card__img" src="https://i.pinimg.com/736x/5b/0e/55/5b0e55765d14b77877e75fca2315ae6f.jpg" alt="Shop Jeans" loading="lazy" />
        <div class="category-banner-card__overlay">
          <span class="category-banner-card__btn">Shop Denim</span>
        </div>
      </a>

      <!-- Jackets -->
      <a href="/collections?category=jackets" class="category-banner-card">
        <img class="category-banner-card__img" src="https://i.pinimg.com/736x/fa/14/b3/fa14b392e687ec62d0bbe320e81ca10d.jpg" alt="Shop Jackets" loading="lazy" />
        <div class="category-banner-card__overlay">
          <span class="category-banner-card__btn">Shop Jackets</span>
        </div>
      </a>

      <!-- Hoodies -->
      <a href="/collections?category=hoodies" class="category-banner-card">
        <img class="category-banner-card__img" src="https://i.pinimg.com/736x/2b/5d/60/2b5d60ac344515aada335e3ce17938aa.jpg" alt="Shop Hoodies" loading="lazy" />
        <div class="category-banner-card__overlay">
          <span class="category-banner-card__btn">Shop Hoodies</span>
        </div>
      </a>

    </div>
  </div>
</section>


<!-- ════════════════════════════════════════════
     COLLECTION / PRODUCT GRID
════════════════════════════════════════════ -->
<section class="section-collection" id="collection" aria-labelledby="collection-title">
  <div class="section-collection__inner">

    <!-- Header -->
    <div class="collection-header reveal">
      <div>
        <p class="section-eyebrow">New Arrivals</p>
        <h2 id="collection-title">The Collection</h2>
      </div>
      <a href="/collections" class="view-all" id="view-all-btn">View All →</a>
    </div>

    <!-- Category Filter -->
    <div class="category-filter reveal">
      <button class="category-btn category-btn--active" data-category="all">All</button>
      <button class="category-btn" data-category="jeans">Jeans</button>
      <button class="category-btn" data-category="jackets">Jackets</button>
      <button class="category-btn" data-category="hoodies">Hoodies</button>
    </div>

    <!-- Grid (rendered by products.js) -->
    <div class="product-grid" id="product-grid" role="list" aria-label="Products">
      <!-- Cards injected by JS -->
    </div>

    <!-- Load More -->
    <div class="load-more-wrap reveal">
      <button class="btn-outline" id="load-more-btn">Load More</button>
    </div>

  </div>
</section>


<!-- ════════════════════════════════════════════
     ABOUT
════════════════════════════════════════════ -->
<section class="section-about" id="about" aria-labelledby="about-title">
  <div class="section-about__inner reveal">
    <p class="section-eyebrow">Who we are</p>
    <h2 class="section-title" id="about-title">
      Objects that matter.<br/>
      <em>Moments that last.</em>
    </h2>
    <p class="section-body">
      aizo.dz was born from a belief that everyday objects should be beautiful,
      functional, and intentional. We source and curate the finest pieces —
      each one chosen to elevate the ordinary into the extraordinary.
    </p>
    <div class="divider" aria-hidden="true">
      <div class="divider__line"></div>
      <span class="divider__star">✦</span>
      <div class="divider__line"></div>
    </div>
  </div>
</section>


<!-- ════════════════════════════════════════════
     NEWSLETTER
════════════════════════════════════════════ -->
<section class="section-newsletter" aria-labelledby="nl-title">
  <div class="section-newsletter__inner reveal">
    <p class="section-eyebrow">Stay in the know</p>
    <h2 class="section-title" id="nl-title">
      Join the<br/><em>inner circle.</em>
    </h2>
    <p class="section-body">
      Be the first to hear about new arrivals, exclusive offers,
      and the stories behind each piece.
    </p>
    <form class="nl-form" id="nl-form" novalidate>
      <input
        class="nl-input"
        id="nl-email"
        type="email"
        placeholder="Your email address"
        required
        aria-label="Email address"
      />
      <div class="captcha-container" id="nl-captcha-container" style="display: flex; align-items: center; gap: 8px; margin: 10px 0;">
        <span class="captcha-question" id="nl-captcha-question" style="color: var(--color-stone-500); font-size: 0.9rem;"></span>
        <input class="captcha-input" id="nl-captcha-answer" type="number" placeholder="?" required style="width: 60px; padding: 6px; border: 1px solid var(--color-border); text-align: center;" />
      </div>
      <button type="submit" class="btn-subscribe" id="nl-submit">Subscribe</button>
    </form>
    <p class="nl-success" id="nl-success" role="status">
      ✓ Thank you — you're on the list.
    </p>
  </div>
</section>


<!-- ════════════════════════════════════════════
     FEATURES / TRUST BAR
════════════════════════════════════════════ -->
<section class="section-features" aria-label="Our promises">
  <div class="section-features__grid">

    <div class="feature reveal">
      <div class="feature__icon" aria-hidden="true">
        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 13h12l1-13"/>
        </svg>
      </div>
      <p class="feature__title">Fast Delivery</p>
      <p class="feature__body">Fast and secure shipping across all 58 wilayas in Algeria.</p>
    </div>

    <div class="feature reveal delay-1">
      <div class="feature__icon" aria-hidden="true">
        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <p class="feature__title">Authenticity Guarantee</p>
      <p class="feature__body">Every product is hand-verified for quality before it reaches you.</p>
    </div>

    <div class="feature reveal delay-2">
      <div class="feature__icon" aria-hidden="true">
        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9
                   m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
      </div>
      <p class="feature__title">Easy Returns</p>
      <p class="feature__body">14-day hassle-free returns. No questions asked.</p>
    </div>

  </div>
</section>
</main>


<!-- ════════════════════════════════════════════
     FOOTER
════════════════════════════════════════════ -->
<footer class="footer" id="contact" role="contentinfo">
  <div class="footer__inner">
    <div class="footer__grid">

      <!-- Brand column -->
      <div class="footer-col">
        <p class="footer-tagline">
          Curated essentials for a more intentional life.<br/>Proudly Algerian.
        </p>
        <div class="footer-socials">
          <a href="#" class="social-link" id="ig-link" aria-label="Instagram">
            <svg fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058
                       1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664
                       4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07
                       -3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013
                       -3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069
                       4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014
                       8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98
                       6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2
                       6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667
                       -.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0
                       5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8
                       4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a href="#" class="social-link" id="fb-link" aria-label="Facebook">
            <svg fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954
                       10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669
                       1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25
                       h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" class="social-link" id="tt-link" aria-label="TikTok">
            <svg fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88
                       2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01
                       a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34
                       6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.52V6.76a4.85 4.85 0
                       01-1.02-.07z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Shop links -->
      <div class="footer-col">
        <h4 data-i18n="foot_shop">Shop</h4>
        <ul>
          <li><a href="#collection" data-i18n="foot_new_arrivals">New Arrivals</a></li>
          <li><a href="#" data-i18n="foot_best_sellers">Best Sellers</a></li>
          <li><a href="#" data-i18n="foot_home_living">Home & Living</a></li>
          <li><a href="#" data-i18n="foot_accessories">Accessories</a></li>
          <li><a href="#" data-i18n="foot_gift_sets">Gift Sets</a></li>
        </ul>
      </div>

      <!-- Info links -->
      <div class="footer-col">
        <h4 data-i18n="foot_info">Info</h4>
        <ul>
          <li><a href="#about" data-i18n="foot_our_story">Our Story</a></li>
          <li><a href="#" data-i18n="foot_shipping">Shipping & Returns</a></li>
          <li><a href="#" data-i18n="foot_privacy">Privacy Policy</a></li>
          <li><a href="#" data-i18n="foot_terms">Terms of Use</a></li>
          <li><a href="#" data-i18n="foot_faq">FAQ</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h4 data-i18n="foot_contact">Contact</h4>
        <ul>
          <li class="contact-item">
            <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0
                       002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:contact@aizo.dz">contact@aizo.dz</a>
          </li>
          <li class="contact-item">
            <svg fill="currentColor" viewBox="0 0 24 24" width="16" height="16">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <a href="https://wa.me/213655349311" target="_blank" rel="noopener">0655 34 93 11 (WhatsApp)</a>
          </li>
          <li class="contact-item">
            <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8
                       8 0 1111.314 0z"/>

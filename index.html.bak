</footer>


<!-- ════════════════════════════════════════════
     CART DRAWER
════════════════════════════════════════════ -->
<div class="cart-drawer-backdrop" id="cart-drawer-backdrop" aria-hidden="true"></div>
<aside class="cart-drawer" id="cart-drawer" role="dialog" aria-modal="true" aria-labelledby="cart-drawer-title">
  <div class="cart-drawer__header">
    <h2 id="cart-drawer-title">سلة المشتريات <span>/ Cart</span></h2>
    <button class="btn-close-cart" id="btn-close-cart" aria-label="Close cart">×</button>
  </div>

  <div class="cart-drawer__body">
    <!-- Empty State -->
    <div class="cart-empty" id="cart-empty">
      <div class="cart-empty__icon">✦</div>
      <p class="cart-empty__text-ar">السلة فارغة حالياً</p>
      <p class="cart-empty__text-en">Your cart is empty</p>
      <a href="#collection" class="btn-primary" id="btn-empty-shop">تسوق الآن / Shop Now</a>
    </div>

    <!-- Cart Items list -->
    <div class="cart-items" id="cart-items-list">
      <!-- Injected by JS -->
    </div>

    <!-- Summary & Checkout Form -->
    <div class="cart-checkout-section" id="cart-checkout-section" style="display: none;">
      <div class="cart-summary">
        <div class="summary-row">
          <span>المجموع الفرعي / Subtotal</span>
          <span id="cart-subtotal">0 DZD</span>
        </div>
        <div class="summary-row">
          <span>شحن التوصيل / Shipping</span>
          <span id="cart-shipping">-- DZD</span>
        </div>
        <div class="summary-row summary-total">
          <span>الإجمالي / Total</span>
          <span id="cart-total">0 DZD</span>
        </div>
      </div>

      <form class="checkout-form" id="checkout-form" autocomplete="on">
        <h3>معلومات التوصيل <span>/ Delivery Info</span></h3>

        <div class="form-group-row" style="display: flex; gap: 0.75rem;">
          <div class="form-group" style="flex: 1;">
            <label for="checkout-name">الاسم / First Name *</label>
            <input type="text" id="checkout-name" placeholder="الاسم الشخصي" required />
            <span class="error-msg" id="err-name">يرجى إدخال الاسم</span>
          </div>
          <div class="form-group" style="flex: 1;">
            <label for="checkout-surname">اللقب / Last Name *</label>
            <input type="text" id="checkout-surname" placeholder="اللقب العائلي" required />
            <span class="error-msg" id="err-surname">يرجى إدخال اللقب</span>
          </div>
        </div>

        <div class="form-group">
          <label for="checkout-phone">رقم الهاتف / Phone Number *</label>
          <input type="tel" id="checkout-phone" placeholder="05 / 06 / 07 XX XX XX XX" required />
          <span class="error-msg" id="err-phone">يرجى إدخال رقم هاتف صحيح (10 أرقام)</span>
        </div>

        <div class="form-group">
          <label for="checkout-wilaya">الولاية / State *</label>
          <select id="checkout-wilaya" required>
            <option value="" disabled selected>اختر الولاية...</option>
            <option value="1 - أدرار (Adrar)">1 - أدرار (Adrar)</option>
            <option value="2 - الشلف (Chlef)">2 - الشلف (Chlef)</option>
            <option value="3 - الأغواط (Laghouat)">3 - الأغواط (Laghouat)</option>
            <option value="4 - أم البواقي (Oum El Bouaghi)">4 - أم البواقي (Oum El Bouaghi)</option>
            <option value="5 - باتنة (Batna)">5 - باتنة (Batna)</option>
            <option value="6 - بجاية (Béjaïa)">6 - بجاية (Béjaïa)</option>
            <option value="7 - بسكرة (Biskra)">7 - بسكرة (Biskra)</option>
            <option value="8 - بشار (Béchar)">8 - بشار (Béchar)</option>
            <option value="9 - البليدة (Blida)">9 - البليدة (Blida)</option>
            <option value="10 - البويرة (Bouira)">10 - البويرة (Bouira)</option>
            <option value="11 - تمنراست (Tamanrasset)">11 - تمنراست (Tamanrasset)</option>
            <option value="12 - تبسة (Tébessa)">12 - تبسة (Tébessa)</option>
            <option value="13 - تلمسان (Tlemcen)">13 - تلمسان (Tlemcen)</option>
            <option value="14 - تيارت (Tiaret)">14 - تيارت (Tiaret)</option>
            <option value="15 - تيزي وزو (Tizi Ouzou)">15 - تيزي وزو (Tizi Ouzou)</option>
            <option value="16 - الجزائر (Algiers)">16 - الجزائر (Algiers)</option>
            <option value="17 - الجلفة (Djelfa)">17 - الجلفة (Djelfa)</option>
            <option value="18 - جيجل (Jijel)">18 - جيجل (Jijel)</option>
            <option value="19 - سطيف (Sétif)">19 - سطيف (Sétif)</option>
            <option value="20 - سعيدة (Saïda)">20 - سعيدة (Saïda)</option>
            <option value="21 - سكيكدة (Skikda)">21 - سكيكدة (Skikda)</option>
            <option value="22 - سيدي بلعباس (Sidi Bel Abbès)">22 - سيدي بلعباس (Sidi Bel Abbès)</option>
            <option value="23 - عنابة (Annaba)">23 - عنابة (Annaba)</option>
            <option value="24 - قالمة (Guelma)">24 - قالمة (Guelma)</option>
            <option value="25 - قسنطينة (Constantine)">25 - قسنطينة (Constantine)</option>
            <option value="26 - المدية (Médéa)">26 - المدية (Médéa)</option>
            <option value="27 - مستغانم (Mostaganem)">27 - مستغانم (Mostaganem)</option>
            <option value="28 - المسيلة (M'Sila)">28 - المسيلة (M'Sila)</option>
            <option value="29 - معسكر (Mascara)">29 - معسكر (Mascara)</option>
            <option value="30 - ورقلة (Ouargla)">30 - ورقلة (Ouargla)</option>
            <option value="31 - وهران (Oran)">31 - وهران (Oran)</option>
            <option value="32 - البيض (El Bayadh)">32 - البيض (El Bayadh)</option>
            <option value="33 - إليزي (Illizi)">33 - إليزي (Illizi)</option>
            <option value="34 - برج بوعريريج (Bordj Bou Arréridj)">34 - برج بوعريريج (Bordj Bou Arréridj)</option>
            <option value="35 - بومرداس (Boumerdès)">35 - بومرداس (Boumerdès)</option>
            <option value="36 - الطارف (El Tarf)">36 - الطارف (El Tarf)</option>
            <option value="37 - تندوف (Tindouf)">37 - تندوف (Tindouf)</option>
            <option value="38 - تسمسيلت (Tissemsilt)">38 - تسمسيلت (Tissemsilt)</option>
            <option value="39 - الوادي (El Oued)">39 - الوادي (El Oued)</option>
            <option value="40 - خنشلة (Khenchela)">40 - خنشلة (Khenchela)</option>
            <option value="41 - سوق أهراس (Souk Ahras)">41 - سوق أهراس (Souk Ahras)</option>
            <option value="42 - تيبازة (Tipaza)">42 - تيبازة (Tipaza)</option>
            <option value="43 - ميلة (Mila)">43 - ميلة (Mila)</option>
            <option value="44 - عين الدفلة (Aïn Defla)">44 - عين الدفلة (Aïn Defla)</option>
            <option value="45 - النعامة (Naâma)">45 - النعامة (Naâma)</option>
            <option value="46 - عين تموشنت (Aïn Témouchent)">46 - عين تموشنت (Aïn Témouchent)</option>
            <option value="47 - غرداية (Ghardaïa)">47 - غرداية (Ghardaïa)</option>
            <option value="48 - غليزان (Relizane)">48 - غليزان (Relizane)</option>
            <option value="49 - المغير (El M'Ghair)">49 - المغير (El M'Ghair)</option>
            <option value="50 - المنيعة (El Meniaa)">50 - المنيعة (El Meniaa)</option>
            <option value="51 - أولاد جلال (Ouled Djellal)">51 - أولاد جلال (Ouled Djellal)</option>
            <option value="52 - برج باجي مختار (Bordj Baji Mokhtar)">52 - برج باجي مختار (Bordj Baji Mokhtar)</option>
            <option value="53 - بني عباس (Béni Abbès)">53 - بني عباس (Béni Abbès)</option>
            <option value="54 - عين صالح (In Salah)">54 - عين صالح (In Salah)</option>
            <option value="55 - عين قزام (In Guezzam)">55 - عين قزام (In Guezzam)</option>
            <option value="56 - تقرت (Touggourt)">56 - تقرت (Touggourt)</option>
            <option value="57 - جانت (Djanet)">57 - جانت (Djanet)</option>
            <option value="58 - المغير (El M'Ghair)">58 - المغير (El M'Ghair)</option>
          </select>
          <span class="error-msg" id="err-wilaya">يرجى اختيار الولاية</span>
        </div>

        <div class="form-group">
          <label>نوع التوصيل / Delivery Type *</label>
          <div class="delivery-options">
            <label class="delivery-option-card">
              <input type="radio" name="delivery-type" value="home" checked />
              <div class="option-content">
                <span class="option-title" data-i18n="delivery_home">التوصيل إلى المنزل (A DOMICILE)</span>
                <span class="option-desc"><span data-i18n="delivery_home_desc">الدفع عند الاستلام بباب المنزل</span> · <strong id="home-delivery-price"></strong></span>
              </div>
            </label>
            <label class="delivery-option-card">
              <input type="radio" name="delivery-type" value="office" />
              <div class="option-content">
                <span class="option-title" data-i18n="delivery_office">التوصيل إلى المكتب (STOP DESK)</span>
                <span class="option-desc"><span data-i18n="delivery_office_desc">الاستلام من مكتب شركة التوصيل</span> · <strong id="office-delivery-price"></strong></span>
              </div>
            </label>
          </div>
        </div>

        <div class="form-group" id="home-address-group">
          <label for="checkout-address">العنوان التفصيلي / Home Address *</label>
          <div class="input-with-icon" style="position: relative; display: flex; align-items: center;">
            <span class="input-icon" style="position: absolute; right: 10px; top: 12px; color: var(--color-stone-400); pointer-events: none;">
              <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 18px; height: 18px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
              </svg>
            </span>
            <textarea
              id="checkout-address"
              placeholder="مثال: حي السلام، شارع الأمير، رقم 12، الطابق الثاني"
              rows="3"
              style="padding-right: 2.25rem;"
              required
            ></textarea>
          </div>
          <span class="error-msg" id="err-address">يرجى إدخال عنوان المنزل</span>
        </div>

        <div class="form-group" id="office-select-group" style="display: none;">
          <label for="checkout-office">مكتب التوصيل / Shipping Office *</label>
          <div class="input-with-icon" style="position: relative; display: flex; align-items: center;">
            <span class="input-icon" style="position: absolute; right: 10px; top: 12px; color: var(--color-stone-400); pointer-events: none;">
              <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 18px; height: 18px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.053.244-7.5 1.724V21a1.5 1.5 0 001.5 1.5h15a1.5 1.5 0 001.5-1.5z" />
              </svg>
            </span>
            <select id="checkout-office" style="padding-right: 2.25rem;">
              <option value="" disabled selected>اختر مكتب التوصيل...</option>
            </select>
          </div>
          <span class="error-msg" id="err-office">يرجى اختيار مكتب التوصيل</span>
        </div>

        <button type="submit" class="btn-primary btn-checkout" id="btn-confirm-order">
          تأكيد الطلب / Confirm Order
        </button>
        <div class="error-alert" id="checkout-error-alert" style="display: none;">
          <span class="error-icon">⚠️</span>
          <div class="error-content">
            <p id="checkout-error-text">حدث خطأ أثناء معالجة الطلب</p>
          </div>
          <button type="button" class="error-close" id="checkout-error-close">×</button>
        </div>
      </form>
    </div>

    <!-- Success Screen -->
    <div class="order-success-screen" id="order-success-screen" style="display: none;">
      <div class="success-icon">✓</div>
      <h2>تم تسجيل طلبك بنجاح!</h2>
      <p class="success-subtitle">شكراً لثقتكم. سنقوم بالاتصال بكم هاتفياً قريباً لتأكيد الطلب وشحنه.</p>
      
      <div class="order-details-card">
        <div class="details-row">
          <span>رقم الطلب:</span>
          <strong id="success-order-id">#00000</strong>
        </div>
        <div class="details-row">
          <span>الاسم:</span>
          <span id="success-order-name">-</span>
        </div>
        <div class="details-row">
          <span>الهاتف:</span>
          <span id="success-order-phone">-</span>
        </div>
        <div class="details-row">
          <span>الولاية:</span>
          <span id="success-order-wilaya">-</span>
        </div>
        <div class="details-row">
          <span>التوصيل إلى:</span>
          <span id="success-order-delivery">-</span>
        </div>
        <div class="details-row total-row">
          <span>المجموع الإجمالي:</span>
          <strong id="success-order-total">0 DZD</strong>
        </div>
      </div>

      <button class="btn-primary" id="btn-success-close">متابعة التسوق / Continue Shopping</button>
    </div>
  </div>
</aside>

<!-- ════════════════════════════════════════════
     SCRIPTS (products.js first, then main.js)
════════════════════════════════════════════ -->
<!-- EmailJS SDK -->
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<!-- Central API Config (MUST be first) -->
<script src="js/config.js"></script>
<script src="js/products.js"></script>
<script src="js/i18n.js"></script>
<script src="js/sync.js"></script>
<script src="js/main.js"></script>
<!-- ════════════════════════════════════════════
     EMAIL LEAD COLLECTION POPUP
     ════════════════════════════════════════════ -->
<div class="lead-popup-backdrop" id="lead-popup-backdrop" aria-hidden="true"></div>
<div class="lead-popup" id="lead-popup" role="dialog" aria-modal="true" aria-labelledby="lead-popup-title" style="display: none;">
  <div class="lead-popup__inner">
    <button class="btn-close-lead-popup" id="btn-close-lead-popup" aria-label="Close popup">×</button>
    <h2 id="lead-popup-title">انضم إلينا / Join Us</h2>
    <p class="lead-popup__desc-ar">اشترك في قائمتنا البريدية للحصول على آخر التحديثات والمجموعات الجديدة الحصرية.</p>
    <p class="lead-popup__desc-en">Subscribe to our newsletter for updates on new arrivals and exclusive collections.</p>
    
    <form class="lead-popup__form" id="lead-popup-form" action="https://formspree.io/f/YOUR_FORMSPREE_ID" method="POST">
      <div class="form-group">
        <input type="email" id="lead-email" name="email" placeholder="بريدك الإلكتروني / Email address" required />
        <span class="error-msg" id="err-lead-email">يرجى إدخال بريد إلكتروني صحيح</span>
      </div>
      <div class="captcha-container" id="lead-captcha-container" style="display: flex; align-items: center; gap: 8px; margin: 10px 0; justify-content: center;">
        <span class="captcha-question" id="lead-captcha-question" style="color: var(--color-stone-600); font-size: 0.85rem;"></span>
        <input class="captcha-input" id="lead-captcha-answer" type="number" placeholder="?" required style="width: 60px; padding: 8px; border: 1px solid var(--color-border); text-align: center; background: var(--color-bg-main);" />
      </div>
      <button type="submit" class="btn-primary btn-lead-submit" id="btn-lead-submit">
        اشترك الآن / Subscribe
      </button>
    </form>
    
    <div class="lead-popup__success" id="lead-popup-success" style="display: none;">
      <div class="success-icon" style="margin: 0 auto 1rem;">✓</div>
      <h3>شكراً لتسجيلك! / Thank You!</h3>
      <p>تم تسجيل بريدك بنجاح. سنبقيك على اطلاع.</p>
    </div>
  </div>
</div>

</body>
</html>

# ╔════════════════════════════════════════════════════════════╗
# ║          AIZO-DZ — Environment Variables (.env)            ║
# ║    انسخ هذا الملف إلى .env واملأ القيم المطلوبة            ║
# ╚════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────
# Server Configuration — إعدادات الخادم
# ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ──────────────────────────────────────────────
# CORS — الدومينات المسموح لها بالوصول
# (افصل بين الدومينات بفاصلة، بدون مسافات)
# ──────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ──────────────────────────────────────────────
# Database — قاعدة البيانات PostgreSQL
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ──────────────────────────────────────────────
# ZR Express — خدمة الشحن والتوصيل
# ──────────────────────────────────────────────
ZR_SECRET_KEY=
ZR_TENANT_ID=
ZR_BASE_URL=https://api.zrexpress.app/api/v1

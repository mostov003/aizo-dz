app.put('/api/orders/:id/status', async (req, res) => {
  try {
    const { id } = req.params;
    const { status } = req.body;
    
    if (!status) {
      return res.status(400).json({ error: 'Status is required' });
    }
    
    const updatedOrder = await updateOrderStatus(id, status);
    console.log(`✅ Updated order ${id} status to ${status}`);
    res.json(updatedOrder);
  } catch (err) {
    console.error(`❌ Error updating order status: ${err.message}`);
    res.status(500).json({ error: 'Failed to update order status', message: err.message });
  }
});

// PATCH endpoint to support updates from Vue admin dashboard
app.patch('/api/orders/:id', async (req, res) => {
  try {
    const { id } = req.params;
    const { status, ...otherData } = req.body;
    
    // Build update fields
    const updateFields = [];
    const updateParams = [id];
    let paramCount = 1;
    
    if (status !== undefined) {
      updateFields.push(`"status" = $${++paramCount}`);
      updateParams.push(status);
    }
    
    // Handle other fields
    if (otherData.customerName !== undefined) {
      updateFields.push(`"customerName" = $${++paramCount}`);
      updateParams.push(otherData.customerName);
    }
    if (otherData.customerPhone !== undefined) {
      updateFields.push(`"customerPhone" = $${++paramCount}`);
      updateParams.push(otherData.customerPhone);
    }
    if (otherData.customerEmail !== undefined) {
      updateFields.push(`"customerEmail" = $${++paramCount}`);
      updateParams.push(otherData.customerEmail);
    }
    if (otherData.notes !== undefined) {
      updateFields.push(`"notes" = $${++paramCount}`);
      updateParams.push(otherData.notes);
    }
    
    updateFields.push(`"updatedAt" = NOW()`);
    
    if (updateFields.length === 1) { // Only updatedAt
      return res.status(400).json({ error: 'No fields to update' });
    }
    
    const sql = `
      UPDATE "Order" 
      SET ${updateFields.join(', ')}
      WHERE id = $1
      RETURNING *
    `;
    
    const result = await query(sql, updateParams);
    
    if (result.length === 0) {
      return res.status(404).json({ error: 'Order not found', orderId: id });
    }
    
    console.log(`✅ Patched order ${id}`);
    res.json(result[0]);
  } catch (err) {
    console.error(`❌ Error patching order: ${err.message}`);
    res.status(500).json({ error: 'Failed to patch order', message: err.message });
  }
});


// Update customer info endpoint
app.put('/api/orders/:id/customer', async (req, res) => {
  try {
    const { id } = req.params;
    const { name, phone, email, wilaya, address, delivery, deliveryType, officeName, total, shipping, subtotal } = req.body;
    
    const updateFields = [];
    const updateParams = [id];
    let paramCount = 1;
    
    if (name !== undefined) {
      updateFields.push(`"customerName" = $${++paramCount}`);
      updateParams.push(name);
    }
    if (phone !== undefined) {
      updateFields.push(`"customerPhone" = $${++paramCount}`);
      updateParams.push(phone);
    }
    if (email !== undefined) {
      updateFields.push(`"customerEmail" = $${++paramCount}`);
      updateParams.push(email);
    }
    if (wilaya !== undefined) {
      updateFields.push(`"customerWilaya" = $${++paramCount}`);
      updateParams.push(wilaya);
    }
    if (address !== undefined) {
      updateFields.push(`"customerAddress" = $${++paramCount}`);
      updateParams.push(address);
    }
    if (delivery !== undefined) {
      updateFields.push(`"delivery" = $${++paramCount}`);
      updateParams.push(delivery);
    }
    if (deliveryType !== undefined) {
      updateFields.push(`"deliveryOffice" = $${++paramCount}`);
      updateParams.push(deliveryType || officeName);
    }
    if (total !== undefined) {
      updateFields.push(`"total" = $${++paramCount}`);
      updateParams.push(parseFloat(total) || 0);
    }
    if (shipping !== undefined) {
      updateFields.push(`"shippingCost" = $${++paramCount}`);
      updateParams.push(parseFloat(shipping) || 0);
    }
    if (subtotal !== undefined) {
      updateFields.push(`"subtotal" = $${++paramCount}`);
      updateParams.push(parseFloat(subtotal) || 0);
    }
    
    if (updateFields.length === 0) {
      return res.status(400).json({ success: false, error: 'No fields to update' });
    }
    
    updateFields.push('"updatedAt" = NOW()');
    
    const sql = `
      UPDATE "Order" 
      SET ${updateFields.join(', ')}
      WHERE id = $1
      RETURNING *
    `;
    
    const result = await query(sql, updateParams);
    
    if (result.length === 0) {
      return res.status(404).json({ success: false, error: 'Order not found' });
    }
    
    res.json({
      success: true,
      message: 'Customer information updated successfully',
      order: result[0]
    });
  } catch (err) {
    console.error('❌ Error updating customer info:', err.message);
    res.status(500).json({ success: false, error: err.message });
  }
});

// Update custom order design layers & specs endpoint
app.put('/api/orders/:id/custom-order', async (req, res) => {
  try {
    const { id } = req.params;
    const { customOrder } = req.body;
    
    // Check if order exists
    const checkSql = `SELECT id FROM "Order" WHERE id = $1`;
    const checkResult = await query(checkSql, [id]);
    
    if (checkResult.length === 0) {
      return res.status(404).json({ success: false, error: 'Order not found' });
    }
    
    // Update custom order data
    if (customOrder) {
      // Process design layers to save base64 images into physical files
      if (customOrder.layers && Array.isArray(customOrder.layers)) {
        customOrder.layers.forEach((layer, lIdx) => {
          if (layer.img && layer.img.startsWith('data:image/')) {
            layer.img = saveBase64Image(layer.img, 'design', id, lIdx);
          }
        });
      }
      
      const customOrderData = JSON.stringify(customOrder);
      
      // Update the customOrder JSON fields
      const updateSql = `
        UPDATE "Order" 
        SET "customOrder" = true, "customOrderDetails" = $2, "updatedAt" = NOW()
        WHERE id = $1
        RETURNING *
      `;
      
      await query(updateSql, [id, customOrderData]);

      // Sync CustomLayer table
      await query('DELETE FROM "CustomLayer" WHERE "orderId" = $1', [id]);
      if (customOrder.layers && Array.isArray(customOrder.layers)) {
        for (let idx = 0; idx < customOrder.layers.length; idx++) {
          const layer = customOrder.layers[idx];
          const layerId = require('crypto').randomBytes(8).toString('hex');
          await query(
            `INSERT INTO "CustomLayer" (id, "orderId", "layerIndex", "imageUrl", area, text)
             VALUES ($1, $2, $3, $4, $5, $6)`,
            [
              layerId,
              id,
              idx,
              layer.img || layer.imageUrl || '',
              layer.area || null,
              layer.text || null
            ]
          );
        }
      }

      // Fetch and return the fully populated order
      const fullOrder = await getOrderById(id);
      
      res.json({
        success: true,
        message: 'Custom order updated successfully',
        order: fullOrder
      });
    } else {
      res.status(400).json({ success: false, error: 'No custom order data provided' });
    }
  } catch (err) {
    console.error('❌ Error updating custom order:', err);
    res.status(500).json({ success: false, error: err.message });
  }
});


// ║                   Database & Upload Paths                  ║
// ╚════════════════════════════════════════════════════════════╝

const DB_DIR = path.join(__dirname, 'db');
const ORDERS_FILE = path.join(DB_DIR, 'orders.json');
const PRODUCTS_FILE = path.join(DB_DIR, 'custom_products.json');
const LEADS_FILE = path.join(DB_DIR, 'leads.json');
const STOCKS_FILE = path.join(DB_DIR, 'product_stocks.json');
const OVERRIDES_FILE = path.join(DB_DIR, 'default_overrides.json');
const UPLOADS_DIR = path.join(__dirname, 'uploads');

// Ensure db directory exists
if (!fs.existsSync(DB_DIR)) {
  fs.mkdirSync(DB_DIR);
}

// Ensure uploads directory exists
if (!fs.existsSync(UPLOADS_DIR)) {
  fs.mkdirSync(UPLOADS_DIR);
}

// Initialize files if they don't exist
const initializeFile = (filePath, defaultContent) => {
  if (!fs.existsSync(filePath)) {
    fs.writeFileSync(filePath, JSON.stringify(defaultContent, null, 2));
  }
};

initializeFile(ORDERS_FILE, []);
initializeFile(PRODUCTS_FILE, []);
initializeFile(LEADS_FILE, []);
initializeFile(STOCKS_FILE, {});
initializeFile(OVERRIDES_FILE, {});

// ╔════════════════════════════════════════════════════════════╗
// ║                 File I/O Helpers                           ║
// ╚════════════════════════════════════════════════════════════╝

const fsPromises = fs.promises;

async function readJSON(filePath) {
  try {
    const data = await fsPromises.readFile(filePath, 'utf8');
    return JSON.parse(data || '[]');
  } catch (err) {
    console.error(`❌ Error reading ${filePath}:`, err.message);
    return [];
  }
}

async function writeJSON(filePath, data) {
  try {
    await fsPromises.writeFile(filePath, JSON.stringify(data, null, 2));
  } catch (err) {
    console.error(`❌ Error writing ${filePath}:`, err.message);
  }
}

// Helper to save base64 image to uploads/ folder without heavy RegExp (prevent stack overflow on large strings)
function saveBase64Image(base64Str, prefix, orderId, suffix) {
  if (!base64Str || !base64Str.startsWith('data:image/')) return base64Str;
  try {
    const commaIdx = base64Str.indexOf(',');
    if (commaIdx === -1) return base64Str;
    
    const meta = base64Str.substring(0, commaIdx);
    const data = base64Str.substring(commaIdx + 1);
    
    const mimeMatch = meta.match(/^data:([^;]+);base64$/);
    const ext = mimeMatch ? mimeMatch[1].split('/')[1] : 'png';
    
    const buffer = Buffer.from(data, 'base64');
    const filename = `${prefix}-${orderId}${suffix !== undefined && suffix !== null && suffix !== '' ? '-' + suffix : ''}.${ext}`;
    const filePath = path.join(UPLOADS_DIR, filename);
    
    fs.writeFileSync(filePath, buffer);
    console.log(`💾 Saved custom order asset: ${filename}`);
    return `/uploads/${filename}`;
  } catch (err) {
    console.error('❌ Error saving base64 image:', err.message);
    return base64Str;
  }
}

// ╔════════════════════════════════════════════════════════════╗
// ║        In-Memory JSON Cache (Reduces Disk I/O)             ║
// ╚════════════════════════════════════════════════════════════╝

const dataCache = new Map();
const CACHE_TTL = 30000; // 30 seconds

async function readJSONCached(filePath) {
  const cached = dataCache.get(filePath);
  if (cached && (Date.now() - cached.timestamp < CACHE_TTL)) {
    return cached.data;
  }
  const data = await readJSON(filePath);
  dataCache.set(filePath, { data, timestamp: Date.now() });
  return data;
}

function invalidateCache(filePath) {
  dataCache.delete(filePath);
}

async function writeJSONCached(filePath, data) {
  await writeJSON(filePath, data);
  dataCache.set(filePath, { data, timestamp: Date.now() });
}


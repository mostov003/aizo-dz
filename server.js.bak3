app.get('/api/orders', async (req, res) => {
  try {
    const orders = await getAllOrders();
    res.json(orders || []);
  } catch (err) {
    console.error('❌ Error fetching orders:', err.message);
    res.status(500).json({ error: err.message });
  }
});

app.post('/api/orders', async (req, res) => {
  try {
    const newOrder = req.body;

    // Process custom order files if present
    if (newOrder.customOrder) {
      const co = newOrder.customOrder;
      if (co.mockupSnapshot) {
        co.mockupSnapshot = saveBase64Image(co.mockupSnapshot, 'mockup', newOrder.id || 'new', '');
      }
      if (co.layers && Array.isArray(co.layers)) {
        co.layers.forEach((layer, idx) => {
          if (layer.img) {
            layer.img = saveBase64Image(layer.img, 'design', newOrder.id || 'new', idx);
          }
        });
      }
    }

    const order = await createOrder(newOrder);
    res.status(201).json(order);
  } catch (err) {
    console.error('❌ Error creating order:', err.message);
    res.status(500).json({ error: err.message });
  }
});


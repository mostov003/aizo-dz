app.put('/api/products/:id', async (req, res) => {
  try {
    const { id } = req.params;
    const updateFields = [];
    const updateParams = [id];
    let paramCount = 1;
    
    if (req.body.name !== undefined) {
      updateFields.push(`"name" = $${++paramCount}`);
      updateParams.push(req.body.name);
    }
    if (req.body.price !== undefined) {
      updateFields.push(`"price" = $${++paramCount}`);
      updateParams.push(req.body.price);
    }
    if (req.body.description !== undefined) {
      updateFields.push(`"description" = $${++paramCount}`);
      updateParams.push(req.body.description);
    }
    if (req.body.image !== undefined) {
      updateFields.push(`"image" = $${++paramCount}`);
      updateParams.push(req.body.image);
    }
    if (req.body.sizes !== undefined) {
      updateFields.push(`"sizes" = $${++paramCount}`);
      updateParams.push(JSON.stringify(req.body.sizes));
    }
    if (req.body.colors !== undefined) {
      updateFields.push(`"colors" = $${++paramCount}`);
      updateParams.push(JSON.stringify(req.body.colors));
    }
    if (req.body.customizable !== undefined) {
      updateFields.push(`"customizable" = $${++paramCount}`);
      updateParams.push(req.body.customizable);
    }
    
    if (updateFields.length === 0) {
      return res.status(400).json({ error: 'No fields to update' });
    }
    
    updateFields.push('"updatedAt" = NOW()');
    
    const sql = `
      UPDATE "Product" 
      SET ${updateFields.join(', ')}
      WHERE "productId" = $1
      RETURNING *
    `;
    
    const result = await query(sql, updateParams);
    
    if (result.length === 0) {
      return res.status(404).json({ error: 'Product not found' });
    }
    
    res.json(result[0]);
  } catch (err) {
    console.error('❌ Error updating product:', err.message);
    res.status(500).json({ error: err.message });
  }
});

app.delete('/api/products/:id', async (req, res) => {
  try {
    const { id } = req.params;
    const sql = `
      DELETE FROM "Product" 
      WHERE "productId" = $1
      RETURNING id
    `;
    
    const result = await query(sql, [id]);
    
    if (result.length === 0) {
      return res.status(404).json({ error: 'Product not found' });
    }
    
    res.json({ success: true });
  } catch (err) {
    console.error('❌ Error deleting product:', err.message);
    res.status(500).json({ error: err.message });
  }
});

app.get('/api/custom-products', async (req, res) => {
  const products = await readJSONCached(PRODUCTS_FILE);
  res.json(products || []);
});

app.post('/api/custom-products', async (req, res) => {
  const products = await readJSONCached(PRODUCTS_FILE);
  const newProduct = { ...req.body, id: req.body.id || Date.now().toString(), isCustom: true };
  products.push(newProduct);
  await writeJSONCached(PRODUCTS_FILE, products);
  res.status(201).json(newProduct);
});

app.put('/api/custom-products/:id', async (req, res) => {
  const { id } = req.params;
  const products = await readJSONCached(PRODUCTS_FILE);
  const idx = products.findIndex(p => String(p.id) === String(id));
  if (idx === -1) return res.status(404).json({ error: 'Custom product not found' });
  products[idx] = { ...products[idx], ...req.body, id: products[idx].id, isCustom: true };
  await writeJSONCached(PRODUCTS_FILE, products);
  res.json(products[idx]);
});

app.delete('/api/custom-products/:id', async (req, res) => {
  const { id } = req.params;
  let products = await readJSONCached(PRODUCTS_FILE);
  const initialLength = products.length;
  products = products.filter(p => String(p.id) !== String(id));
  if (products.length < initialLength) {
    await writeJSONCached(PRODUCTS_FILE, products);
    res.json({ success: true });
  } else {
    res.status(404).json({ error: 'Custom product not found' });
  }
});


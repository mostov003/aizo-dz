// ╔════════════════════════════════════════════════════════════╗
// ║                API Routes - Status Updates                 ║
// ╚════════════════════════════════════════════════════════════╗

app.post('/api/orders/:id/sync-zr', async (req, res) => {
  try {
    const { id } = req.params;
    const orders = await readJSONCached(ORDERS_FILE);
    const order = orders.find(o => String(o.id) === String(id));

    if (!order) {
      return res.status(404).json({ success: false, error: `Order #${id} not found` });
    }

    if (!order.zrParcelId) {
      return res.status(400).json({ 
        success: false, 
        error: `Order #${id} has no ZR Parcel ID` 
      });
    }

    // Sync with ZR API (fetch current status)
    const syncResponse = await fetch(`${ZR_BASE_URL}/parcels/${order.zrParcelId}`, {
      method: 'GET',
      headers: {
        'X-Tenant': ZR_TENANT_ID,
        'X-Api-Key': ZR_SECRET_KEY
      }
    });

    if (!syncResponse.ok) {
      return res.status(400).json({ 
        success: false, 
        error: 'Failed to sync with ZR Express' 
      });
    }

    const zrData = await syncResponse.json();
    
    // Extract state and situation from zrData
    const zrState = zrData.status?.state || zrData.status || 'OrderReceived';
    const zrSituation = zrData.status?.situation || '';
    
    order.zrStatus = {
      state: zrState,
      situation: zrSituation
    };
    
    // Map ZR status to local order status
    if (zrState === 'Delivered') {
      order.status = 'Delivered';
    } else if (zrState === 'Returned' || zrState === 'ReturnReceived' || zrState === 'ReturnCreated') {
      order.status = 'Returned';
    } else if (zrState === 'Cancelled') {
      order.status = 'Cancelled';
    } else {
      order.status = 'Confirmed'; // Keep it Confirmed while in transit
    }

    order.lastSyncedAt = new Date().toISOString();

    const orderIdx = orders.findIndex(o => String(o.id) === String(id));
    if (orderIdx > -1) {
      orders[orderIdx] = order;
      await writeJSONCached(ORDERS_FILE, orders);
    }

    res.json({ success: true, order, zrData });
  } catch (err) {
    console.error(`Error syncing ZR:`, err.message);
    res.status(500).json({ success: false, error: err.message });
  }
});

// Fallback for single page application (SPA) routes to support Vue router
app.get('*', (req, res, next) => {
  if (req.path.startsWith('/api') || req.path.startsWith('/uploads') || req.path.includes('.')) {
    return next();
  }
  res.sendFile(path.join(__dirname, 'index.html'));
});


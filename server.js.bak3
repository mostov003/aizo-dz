app.post('/api/orders/:id/deliver', async (req, res) => {
  try {
    const { id } = req.params;

    const order = await getOrderById(id);
    if (!order) {
      console.error(`❌ Order #${id} not found`);
      return res.status(404).json({
        success: false,
        error: `Order #${id} not found`
      });
    }

    // Create shipment
    const { zrParcelId, trackingNumber } = await createZRShipment(order);

    // Update order with shipping info
    const updatedOrder = await updateOrderShipping(id, {
      trackingNumber,
      zrParcelId,
      zrStatus: { state: 'OrderReceived', situation: '' }
    });

    res.json({
      success: true,
      trackingNumber,
      zrParcelId,
      order: updatedOrder
    });

  } catch (error) {
    console.error('❌ Error delivering order:', error.message);
    res.status(500).json({
      success: false,
      error: error.message
    });
  }
});

// ✅ Ship order via ZR Express
app.post('/api/orders/:id/ship-zr', async (req, res) => {
  try {
    const { id } = req.params;
    const { customerName, customerPhone, wilaya, address } = req.body;

    const order = await getOrderById(id);
    if (!order) {
      console.error(`❌ Order #${id} not found`);
      return res.status(404).json({
        success: false,
        error: `Order #${id} not found`
      });
    }

    console.log(`🚚 Shipping order #${id} via ZR Express...`);

    try {
      // Try to create ZR shipment
      const { zrParcelId, trackingNumber } = await createZRShipment(order);

      // Update order with tracking info (persist to PostgreSQL)
      const zrStatus = {
        state: 'OrderReceived',
        situation: 'تم استقبال الطلب'
      };
      await updateOrderShipping(id, {
        trackingNumber,
        zrParcelId,
        zrStatus
      });
      order.zrStatus = zrStatus;

      console.log(`✅ Order #${id} shipped successfully. Tracking: ${trackingNumber}`);

      res.json({
        success: true,
        trackingNumber,
        parcelId: zrParcelId,
        status: order.zrStatus,
        message: `✅ تم إرسال الطلب إلى ZR Express بنجاح`
      });
    } catch (zrError) {
      console.warn(`⚠️ ZR shipment failed for order #${id}:`, zrError.message);
      
      // Fallback: still mark the order as shipped locally (persist to PostgreSQL)
      order.trackingNumber = `LOCAL-${id}-${Date.now()}`;
      await updateOrderShipping(id, {
        trackingNumber: order.trackingNumber,
        zrParcelId: null,
        zrStatus: { state: 'Shipped', situation: 'تم تسليم الطلب محلياً' }
      });

      res.json({
        success: true,
        trackingNumber: order.trackingNumber,
        parcelId: null,
        status: { state: 'Shipped', situation: 'تم تسليم الطلب محلياً' },
        warning: 'تم التسليم محلياً (ZR غير متاح حالياً)'
      });
    }

  } catch (error) {
    console.error(`❌ Error shipping order:`, error);
    res.status(500).json({
      success: false,
      error: error.message
    });
  }
});


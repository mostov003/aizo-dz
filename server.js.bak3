const express = require('express');
const cors = require('cors');
const fs = require('fs');
const path = require('path');
const dotenv = require('dotenv');
const os = require('os');
const { createZRProduct } = require('./utils/zrProduct');
const { query, getAllOrders, getOrderById, getOrderByNumber, createOrder, updateOrderStatus, updateOrderShipping, deleteOrder, getAllLeads, createLead, deleteLead, getAllProducts, createProduct, closePrisma } = require('./utils/db');

// تحميل المتغيرات
dotenv.config();

// Global error handlers to prevent server crash
process.on('uncaughtException', (err) => {
  console.error('🔥 CRITICAL: Uncaught Exception:', err);
});
process.on('unhandledRejection', (reason, promise) => {
  console.error('🔥 CRITICAL: Unhandled Rejection at:', promise, 'reason:', reason);
});
const config = require('./config');

const app = express();
const PORT = config.port;

// Middleware
app.use(cors({
  origin: (origin, callback) => {
    // Allow requests with no origin (like mobile apps, curl, or server-to-server requests)
    if (!origin) return callback(null, true);
    
    const isAllowed = config.allowedOrigins.includes('*') || 
                      config.allowedOrigins.includes(origin) ||
                      (config.nodeEnv === 'development' && (origin.includes('localhost') || origin.includes('127.0.0.1')));
                      
    if (isAllowed) {
      callback(null, true);
    } else {
      callback(new Error(`Not allowed by CORS: ${origin}`));
    }
  },
  credentials: true,
  methods: ['GET', 'POST', 'PUT', 'PATCH', 'DELETE', 'OPTIONS'],
  allowedHeaders: ['Content-Type', 'Authorization', 'X-Requested-With', 'Accept', 'Origin'],
  exposedHeaders: ['Content-Length', 'Content-Range']
}));
// Set a larger limit to support base64 mockup uploads
app.use(express.json({ limit: '50mb' }));
app.use(express.urlencoded({ limit: '50mb', extended: true }));

// Vue build is intentionally NOT served — the static site at the project root is the live frontend.

// 2. Serve uploads statically (with CORS headers for Fabric.js canvas compatibility)
app.use('/uploads', express.static(path.join(__dirname, 'uploads'), {
  maxAge: '1d',
  etag: true,
  lastModified: true,
  setHeaders: (res) => {
    // Required for Fabric.js: allow cross-origin image loading without tainting the canvas
    res.setHeader('Cross-Origin-Resource-Policy', 'cross-origin');
    res.setHeader('Access-Control-Allow-Origin', '*');
  }
}));

// 3. Fallback serve root directory (so they can still access admin.html etc. if they want)
app.use(express.static(__dirname, {
  maxAge: '1d',
  etag: true,
  lastModified: true,
  setHeaders: (res, filePath) => {
    if (filePath.endsWith('.html')) {
      res.setHeader('Cache-Control', 'no-cache, no-store, must-revalidate');
    }
  }
}));


let territoryCache = {};

async function getTerritoryIds(wilayaCode) {
  console.log(`\n🔍 Fetching Territory IDs for Wilaya Code: ${wilayaCode}`);
  
  if (territoryCache[wilayaCode]) {
    console.log(`   ✓ Using cached territory`);
    return territoryCache[wilayaCode];
  }

  try {
    // Search for Wilaya
    const searchRes = await fetch(`${ZR_BASE_URL}/territories/search`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Tenant': ZR_TENANT_ID,
        'X-Api-Key': ZR_SECRET_KEY
      },
      body: JSON.stringify({
        pageNumber: 1,
        pageSize: 10,
        advancedFilter: {
          logic: 'and',
          filters: [
            { field: 'code', operator: 'eq', value: wilayaCode },
            { field: 'level', operator: 'eq', value: 'wilaya' }
          ]
        }
      })
    });

    const searchData = await searchRes.json();
    
    if (searchData.items && searchData.items.length > 0) {
      const cityTerritoryId = searchData.items[0].id;
      console.log(`   ✓ Found City Territory: ${cityTerritoryId}`);

      // Get first commune/district
      const distRes = await fetch(`${ZR_BASE_URL}/territories/search`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Tenant': ZR_TENANT_ID,
          'X-Api-Key': ZR_SECRET_KEY
        },
        body: JSON.stringify({
          pageNumber: 1,
          pageSize: 1,
          advancedFilter: {
            logic: 'and',
            filters: [
              { field: 'parentId', operator: 'eq', value: cityTerritoryId },
              { field: 'level', operator: 'eq', value: 'commune' }
            ]
          }
        })
      });

      let districtTerritoryId = cityTerritoryId; // Fallback to city ID
      const distData = await distRes.json();
      
      if (distData.items && distData.items.length > 0) {
        districtTerritoryId = distData.items[0].id;
        console.log(`   ✓ Found District Territory: ${districtTerritoryId}`);
      }

      const result = { cityTerritoryId, districtTerritoryId };
      territoryCache[wilayaCode] = result;
      return result;
    }
  } catch (err) {
    console.warn(`   ⚠️ Error fetching territories: ${err.message}`);
  }

  console.log(`   ⚠️ Using default territories`);
  return {
    cityTerritoryId: '53c9e062-9c4e-4c77-8b71-55eabf887f83',
    districtTerritoryId: '8d0b6cd9-7712-47d2-9ea4-460246494c32'
  };
}
let cachedHubs = [];

async function getHubs() {
  if (cachedHubs.length > 0) return cachedHubs;
  try {
    const res = await fetch(`${ZR_BASE_URL}/hubs/search`, {
      method: 'POST',
      headers: {
        'X-Tenant': ZR_TENANT_ID,
        'X-Api-Key': ZR_SECRET_KEY,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ pageNumber: 1, pageSize: 500 })
    });
    if (res.ok) {
      const data = await res.json();
      cachedHubs = data.items || [];
      console.log(`✓ Loaded ${cachedHubs.length} hubs from ZR Express API`);
    }
  } catch (err) {
    console.error(`⚠️ Failed to load hubs from ZR:`, err.message);
  }
  if (cachedHubs.length === 0) {
    console.log('⚠️ Using fallback ZR hubs list');
    cachedHubs = ZR_HUBS;
  }
  return cachedHubs;
}

function findMatchingHub(officeName, wilayaCode) {
  if (!officeName) return null;
  const hubs = cachedHubs || [];
  
  console.log(`\n🔍 findMatchingHub called with officeName="${officeName}" and wilayaCode=${wilayaCode}`);

  // Clean officeName
  const cleanOffice = officeName
    .replace(/^توصيل للمكتب\s*\(Office\)\s*-\s*/i, '')
    .replace(/^توصيل للمكتب\s*-\s*/i, '')
    .replace(/^التوصيل إلى المكتب\s*\(STOP DESK\)\s*-\s*/i, '')
    .replace(/^التوصيل إلى المكتب\s*-\s*/i, '')
    .replace(/\s*-\s*\(.*?\)/g, '')
    .trim()
    .toLowerCase();

  console.log(`   Cleaned Office Name: "${cleanOffice}"`);

  // Parse target wilaya code
  const targetWilaya = parseInt(wilayaCode || cleanOffice.match(/\b\d+\b/)?.[0] || '16', 10);
  console.log(`   Target Wilaya Code: ${targetWilaya}`);

  let bestMatch = null;
  let highestScore = 0;
  const sameWilayaHubs = [];

  for (const hub of hubs) {
    const hubName = (hub.name || '').toLowerCase();
    let score = 0;

    // Check if hub belongs to target wilaya
    const hubWilayaMatch = hubName.match(/\b\d+\b/);
    const hubWilayaCode = hubWilayaMatch ? parseInt(hubWilayaMatch[0], 10) : null;

    const wilayaMatches = hubWilayaCode === targetWilaya;
    if (wilayaMatches) {
      sameWilayaHubs.push(hub);
      score += 15; // High priority for correct wilaya
    }

    // Token matching (allow tokens of length > 1 to keep codes like 18, 09)
    const cleanTokens = (str) => str.replace(/[^a-zA-Z0-9\u0600-\u06FF]/g, ' ').split(/\s+/).filter(t => t.length > 1);
    const officeTokens = cleanTokens(cleanOffice);
    const hubTokens = cleanTokens(hubName);

    for (const token of officeTokens) {
      if (hubTokens.includes(token) || hubName.includes(token)) {
        score += 5;
      }
    }

    // Additional exact keyword check (exclude generic words)
    const genericWords = ['hub', 'tri', 'transit', 'مكتب', 'مركز', 'فرز', 'توصيل'];
    for (const token of officeTokens) {
      if (!genericWords.includes(token) && hubName.includes(token)) {
        score += 10;
      }
    }

    if (score > highestScore) {
      highestScore = score;
      bestMatch = hub;
    }
  }

  // Fallback check:
  if ((!bestMatch || highestScore < 15) && sameWilayaHubs.length > 0) {
    const preferredHub = sameWilayaHubs.find(h => h.name.toLowerCase().includes('hub') || h.name.includes('مكتب')) || sameWilayaHubs[0];
    console.log(`   ⚠️ Precise match failed. Falling back to same-wilaya hub: "${preferredHub.name}"`);
    return preferredHub;
  }

  if (bestMatch) {
    console.log(`   ✓ Found best match: "${bestMatch.name}" (Score: ${highestScore})`);
  } else {
    console.log(`   ❌ No match found.`);
  }

  return bestMatch;
}

async function createZRShipment(order) {
  console.log(`\n${'═'.repeat(60)}`);
  console.log(`📦 Creating ZR Shipment for Order: #${order.id}`);
  console.log(`${'═'.repeat(60)}`);

  const customer = order.customer || {};
  const safeName = String(customer.name || 'Client').trim() || 'Client';
  const safePhone = String(customer.phone || '+213000000000').trim() || '+213000000000';
  const safeWilaya = String(customer.wilaya || '16 - الجزائر').trim() || '16 - الجزائر';
  
  // Determine if it is a desk delivery (pickup office) or home delivery
  const isDeskDelivery = customer.delivery && (customer.delivery.toLowerCase().includes('office') || customer.delivery.includes('مكتب'));
  const deliveryType = isDeskDelivery ? 'pickup-point' : 'home';
  
  // Extract proper address
  let safeAddress = '';
  if (isDeskDelivery) {
    safeAddress = (customer.delivery || '').replace(/^توصيل للمكتب\s*\(Office\)\s*-\s*/, '').replace(/^توصيل للمكتب\s*-\s*/, '').trim() || 'مكتب توصيل غير محدد';
  } else {
    safeAddress = String(customer.address || '').trim() || (customer.delivery || '').replace(/^توصيل للممنزل\s*\(Home\)\s*—\s*/, '').replace(/^توصيل للمنزل\s*—\s*/, '').trim() || 'العنوان غير محدد';
  }
  
  const safeEmail = String(customer.email || 'customer@example.com').trim() || 'customer@example.com';

  console.log(`✓ Customer: ${safeName}`);
  console.log(`  Phone: ${safePhone}`);
  console.log(`  Wilaya: ${safeWilaya}`);
  console.log(`  Delivery Type: ${deliveryType}`);
  console.log(`  Address: ${safeAddress}`);
  console.log(`  Total: ${order.total || 0} DZD`);

  // Format phone number
  let phone = safePhone;
  if (phone.startsWith('0')) {
    phone = '+213' + phone.substring(1);
  } else if (!phone.startsWith('+')) {
    phone = '+213' + phone;
  }
  console.log(`  Formatted Phone: ${phone}`);

  // Get territory IDs
  const wilayaCode = parseInt(safeWilaya.match(/\d+/)?.[0] || '16', 10) || 16;
  console.log(`\nFetching territory IDs for wilaya code: ${wilayaCode}`);
  
  let cityTerritoryId, districtTerritoryId;
  try {
    const ids = await getTerritoryIds(wilayaCode);
    cityTerritoryId = ids.cityTerritoryId;
    districtTerritoryId = ids.districtTerritoryId;
    console.log(`✓ Territory IDs fetched successfully`);
    console.log(`  City Territory: ${cityTerritoryId}`);
    console.log(`  District Territory: ${districtTerritoryId}`);
  } catch (err) {
    console.warn(`⚠️ Error fetching territory IDs: ${err.message}`);
    console.warn(`   Using default territory IDs`);
    cityTerritoryId = '53c9e062-9c4e-4c77-8b71-55eabf887f83';
    districtTerritoryId = '8d0b6cd9-7712-47d2-9ea4-460246494c32';
  }

  // Get hub ID for pickup points
  let hubId = null;
  if (deliveryType === 'pickup-point') {
    console.log(`\n🔍 Finding Hub ID for office: "${customer.delivery}"`);
    try {
      const hubs = await getHubs();
      const match = findMatchingHub(customer.delivery, wilayaCode);
      if (match) {
        hubId = match.id;
        console.log(`   ✓ Found matching hub: "${match.name}" (ID: ${hubId})`);
      } else {
        console.warn(`   ⚠️ No matching hub found for: "${customer.delivery}"`);
      }
    } catch (err) {
      console.error(`   ⚠️ Error matching hub:`, err.message);
    }
    
    if (!hubId) {
      throw new Error(`لم نتمكن من تحديد فرع التوصيل (Hub ID) في ZR Express لـ "${customer.delivery}". يرجى التأكد من اسم المكتب.`);
    }
  }

  // Create shipment payload with documented ZR fields
  const customerId = (globalThis.crypto && typeof globalThis.crypto.randomUUID === 'function')
    ? globalThis.crypto.randomUUID()
    : '11111111-1111-4111-8111-111111111111';
  const uniqueExternalId = `${String(order.id || 'ORDER').replace(/\s+/g, '-').toUpperCase()}-${Date.now()}-${Math.floor(Math.random() * 1000)}`;

  // Fallback payload if ZR expects different format
  const payload = {
    customer: {
      customerId: customerId,
      name: safeName,
      email: safeEmail,
      phone: {
        number1: phone
      }
    },
    deliveryAddress: {
      street: safeAddress,
      city: safeWilaya.replace(/^\d+\s*-\s*/, ''),
      zipCode: '',
      district: 'Commune',
      cityTerritoryId: cityTerritoryId,
      districtTerritoryId: districtTerritoryId
    },
    orderedProducts: (order.items || []).map((item, idx) => ({
      productName: item.name || item.productName || `Product ${idx + 1}`,
      productSku: item.sku || item.productSku || `SKU-${order.id}-${idx + 1}`,
      quantity: parseInt(item.quantity || item.qty || 1, 10) || 1,
      unitPrice: parseFloat(item.price || item.unitPrice || 0) || 0,
      weight: Math.max(1, parseFloat(item.weight || item.itemWeight || 1) || 1),
      stockType: item.stockType || 'none'
    })),
    amount: parseFloat(order.total || 0) || 0,
    weight: {
      weight: 1,
      dimensionalWeight: 1
    },
    description: `Order #${order.id}`,
    deliveryType: deliveryType,
    hubId: hubId,
    externalId: uniqueExternalId,
    notes: ''
  };

  console.log(`\n📦 Full Payload:`);
  console.log(JSON.stringify(payload, null, 2));

  console.log(`\n🚀 Sending to ZR Express API...`);
  console.log(`   URL: POST ${ZR_BASE_URL}/parcels`);

  // Send request to ZR Express
  const response = await fetch(`${ZR_BASE_URL}/parcels`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-Tenant': ZR_TENANT_ID,
      'X-Api-Key': ZR_SECRET_KEY
    },
    body: JSON.stringify(payload)
  });

  console.log(`\n📨 Response from ZR Express:`);
  console.log(`   HTTP Status: ${response.status} ${response.statusText}`);

  const responseText = await response.text();
  let errorBody = null;
  try {
    errorBody = responseText ? JSON.parse(responseText) : null;
  } catch (_) {}

  // Check if request was successful
  if (!response.ok) {
    const detailMessage = errorBody?.detail || errorBody?.message || errorBody?.errors?.[0]?.description || responseText || 'Empty response';
    if (String(detailMessage).toLowerCase().includes('duplicateexternalid') || String(detailMessage).toLowerCase().includes('already exists within the last 12 hours')) {
      console.warn('⚠️ Duplicate external ID detected. Retrying with a fresh ID once...');
      const retryPayload = { ...payload, externalId: `${String(order.id || 'ORDER').replace(/\s+/g, '-').toUpperCase()}-${Date.now()}-${Math.floor(Math.random() * 1000)}` };
      const retryResponse = await fetch(`${ZR_BASE_URL}/parcels`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Tenant': ZR_TENANT_ID,
          'X-Api-Key': ZR_SECRET_KEY
        },
        body: JSON.stringify(retryPayload)
      });
      const retryText = await retryResponse.text();
      let retryBody = null;
      try { retryBody = retryText ? JSON.parse(retryText) : null; } catch (_) {}
      if (!retryResponse.ok) {
        const retryDetail = retryBody?.detail || retryBody?.message || retryBody?.errors?.[0]?.description || retryText || 'Empty response';
        throw new Error(`ZR API Error ${retryResponse.status}: ${retryDetail}`);
      }
      const retryData = JSON.parse(retryText);
      return await finalizeShipment(retryData, retryResponse, retryText);
    }
    throw new Error(`ZR API Error ${response.status}: ${detailMessage}`);
  }

  // Parse successful response
  let parcelData;
  try {
    parcelData = JSON.parse(responseText);
  } catch (e) {
    throw new Error(`ZR API returned invalid JSON: ${responseText}`);
  }

  return await finalizeShipment(parcelData);

  async function finalizeShipment(parcelData) {
    const zrParcelId = parcelData.id || parcelData.parcelId || parcelData.reference;

    if (!zrParcelId) {
      throw new Error(`ZR API response missing parcel ID`);
    }

    console.log(`✅ Shipment Created Successfully!`);
    let trackingNumber = `ZR-${zrParcelId}`;
    try {
      const detailResponse = await fetch(`${ZR_BASE_URL}/parcels/${zrParcelId}`, {
        method: 'GET',
        headers: {
          'X-Tenant': ZR_TENANT_ID,
          'X-Api-Key': ZR_SECRET_KEY
        }
      });

      if (detailResponse.ok) {
        const detail = await detailResponse.json();
        if (detail.trackingNumber) {
          trackingNumber = detail.trackingNumber;
        }
      }
    } catch (err) {
      console.warn(`⚠️ Could not retrieve tracking number: ${err.message}`);
    }

    return { zrParcelId, trackingNumber };
  }
}

